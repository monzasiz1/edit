<main class="strikeboard-app">
  <%- include('partials/page_hero', {
        kicker: 'Strafenverwaltung',
        title: 'Strafen\u00fcbersicht',
        subtitle: 'Alle Mitglieder \u00b7 Stand ' + new Date().toLocaleDateString('de-DE'),
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
        actions: (user.is_admin ? [
          { href: '/penalties/add', label: 'Neu', variant: 'primary', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' },
          { href: '/dashboard', label: 'Zur\u00fcck', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
        ] : [
          { href: '/dashboard', label: 'Zur\u00fcck', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
        ])
      }) %>

  <div class="strikeboard-stats-row" style="display:flex;gap:0.6rem;flex-wrap:wrap;margin:-0.8rem 0 1.3rem;">
    <div class="strikeboard-stat-chip">
      <span class="stat-chip-value"><%= strafen.length %></span>
      <span class="stat-chip-label">Eintr&auml;ge</span>
    </div>
    <div class="strikeboard-stat-chip highlight-chip">
      <span class="stat-chip-value"><%= strafen.reduce((s, p) => s + Number(p.amount), 0).toFixed(2) %> &euro;</span>
      <span class="stat-chip-label">Gesamt</span>
    </div>
    <div class="strikeboard-stat-chip danger-chip">
      <span class="stat-chip-value"><%= strafen.filter(s => s.status === 'offen').length %></span>
      <span class="stat-chip-label">Offen</span>
    </div>
  </div>

  <section class="strikeboard-list">
    <% 
      const grouped = {};
      strafen.forEach(s => {
        if (!grouped[s.user_name]) grouped[s.user_name] = [];
        grouped[s.user_name].push(s);
      });
      Object.entries(grouped).forEach(([username, userStrafen], idx) => { 
    %>
    <div class="strikeboard-user-card fadein-up" style="--order:<%= idx+3 %>">
      <button class="usercard-head" tabindex="0" aria-expanded="false" aria-controls="usercard-content-<%= idx %>">
        <span class="user-avatar-lg" aria-label="Avatar von <%= username %>"><%= username[0].toUpperCase() %></span>
        <span class="user-name"><%= username %></span>
        <span class="user-strike-count"><%= userStrafen.length %></span>
        <span class="chevron" aria-hidden="true">&#8250;</span>
      </button>
      <div id="usercard-content-<%= idx %>" class="usercard-content" hidden>
        <% if (userStrafen.length > 0) { %>
        <ul class="strike-ultra-list">
          <% userStrafen.forEach(strafe => { %>
            <li class="strike-card <%= strafe.status %>">
              <div class="strike-card-top">
                <span class="strike-card-dot <%= strafe.status %>"></span>
                <span class="strike-card-reason"><%= strafe.reason %></span>
                <span class="strike-card-amount"><%= strafe.amount.toFixed(2) %> €</span>
              </div>
              <div class="strike-card-meta">
                <span class="strike-card-meta-item">📅 <%= new Date(strafe.created_at).toLocaleDateString('de-DE') %></span>
                <% if (strafe.event) { %><span class="strike-card-meta-item">🎪 <%= strafe.event %></span><% } %>
                <span class="strike-card-badge <%= strafe.status %>"><%= strafe.status === 'bezahlt' ? 'Bezahlt' : 'Offen' %></span>
              </div>
              <% if (user.is_admin) { %>
                <div class="strike-card-actions">
                  <a href="/penalties/edit/<%= strafe.id %>" class="strike-card-btn edit">✏️ Bearbeiten</a>
                  <form action="/penalties/delete/<%= strafe.id %>" method="POST" style="display:inline">
                    <button type="submit" class="strike-card-btn delete" onclick="return confirm('Wirklich löschen?')">🗑️ Löschen</button>
                  </form>
                </div>
              <% } %>
            </li>
          <% }) %>
        </ul>
        <% } else { %>
          <div class="strikeboard-empty">Keine Strafen</div>
        <% } %>
      </div>
    </div>
    <% }) %>
  </section>
</main>

<style>
  :root {
    --apple-bg: #ffffff;
    --glass-blur: 22px;
    --strike-green: #1ae68d;
    --strike-red: #fe495c;
    --widget-grad: linear-gradient(93deg, #e3ffe7 0%, #c8ebfa 100%);
    --avatar-grad: linear-gradient(128deg,#3aeed0 10%,#3b8bff 90%);
    --widget-shadow: 0 8px 32px #38bde630;
    --highlight: #16e080;
    --danger: #fe495c;
  }

  html, body {
    background: var(--apple-bg);
    min-height: 100vh;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    letter-spacing: -0.22px;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    margin: 0; padding: 0;
  }
  .strikeboard-app {
    max-width: 900px;
    margin: 2.3rem auto 2rem auto;
    padding: 0 1.4rem;
    position: relative;
  }

  /* === HERO HEADER === */
  .strikeboard-hero {
    position: relative;
    padding: 1.5rem 1.6rem 1.5rem 1.6rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    border-radius: 1.35rem 1.35rem 2rem 2rem;
    margin: -0.55rem -0.25rem 2.3rem;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(160, 212, 183, 0.42);
    box-shadow: 0 15px 34px rgba(18, 66, 43, 0.34), 0 4px 12px rgba(0, 0, 0, 0.1);
    animation: fadein 1.0s cubic-bezier(.4,0,0,1.12);
  }
  .strikeboard-hero::after {
    content: '';
    position: absolute;
    left: 1.2rem;
    right: 1.2rem;
    top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.55), rgba(255,255,255,0.02));
    pointer-events: none;
    z-index: 2;
  }
  .strikeboard-glass-bg {
    display: none;
  }
  .strikeboard-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    opacity: 0.36;
    filter: blur(36px);
  }
  .strikeboard-orb-1 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #a8f4d2 0%, transparent 70%);
    top: -50px; right: -30px;
  }
  .strikeboard-orb-2 {
    width: 140px; height: 140px;
    background: radial-gradient(circle, #b8e8ff 0%, transparent 70%);
    bottom: -30px; left: 8%;
  }
  .strikeboard-header-content {
    position: relative; z-index: 2;
  }
  .strikeboard-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    gap: 0.7rem;
  }
  .strikeboard-kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.68);
    opacity: 1;
  }
  .strikeboard-title {
    font-size: 2.23rem;
    font-weight: 900;
    margin: 0 0 0.13em 0;
    letter-spacing: -1.1px;
    line-height: 1.09;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.18);
  }
  .strikeboard-subline {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(234, 255, 242, 0.9);
    opacity: 1;
    letter-spacing: 0.02em;
    margin-bottom: 0.1em;
  }
  /* Stat-Chips */
  .strikeboard-stats-row {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .strikeboard-stat-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #ffffff;
    border: 1px solid #e1e7eb;
    border-radius: 10px;
    padding: 0.7rem 1rem;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
    min-width: 80px;
    flex: 1 1 auto;
  }
  .strikeboard-stat-chip .stat-chip-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .strikeboard-stat-chip .stat-chip-label {
    font-size: 0.66rem;
    font-weight: 700;
    color: #64748b;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.3em;
  }
  .highlight-chip {
    background: #15803d;
    border-color: #15803d;
  }
  .highlight-chip .stat-chip-value { color: #fff; }
  .highlight-chip .stat-chip-label { color: rgba(255,255,255,0.85); }
  .danger-chip {
    background: #dc2626;
    border-color: #dc2626;
  }
  .danger-chip .stat-chip-value { color: #fff; }
  .danger-chip .stat-chip-label { color: rgba(255,255,255,0.85); }

  /* FAB Pill */
  .strikeboard-add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
    background: rgba(255,255,255,0.18);
    color: #fff;
    border-radius: 2em;
    padding: 0.5rem 1.05rem;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    border: 1px solid rgba(255,255,255,0.28);
    text-decoration: none;
    transition: background 0.13s, box-shadow 0.13s, transform 0.1s;
    outline: none;
    cursor: pointer;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .strikeboard-add-btn:hover {
    background: rgba(255,255,255,0.28);
    box-shadow: 0 10px 26px rgba(0,0,0,0.2);
    transform: translateY(-1px);
  }
  .strikeboard-add-btn:active { transform: scale(0.96); }
  .strikeboard-fab-icon { font-size: 1.4rem; font-weight: 800; line-height: 1; }
  .strikeboard-fab-label { font-size: 0.88rem; font-weight: 700; letter-spacing: 0.04em; }

  .strikeboard-list {
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .strikeboard-user-card {
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
    background: #ffffff;
    transition: box-shadow 0.18s, border-color 0.18s;
    overflow: hidden;
    border: 1px solid #e1e7eb;
    margin-bottom: 0;
    animation: fadein-up 0.45s ease both;
    animation-delay: calc(var(--order, 3) * 0.05s);
  }
  .strikeboard-user-card.open {
    border-color: #cbd5d8;
    box-shadow: 0 4px 12px rgba(15,23,42,0.07);
  }
  .usercard-head {
    display: flex; align-items: center; width: 100%;
    gap: 0.85rem; padding: 0.85rem 1rem;
    background: #ffffff;
    border: none; outline: none;
    box-sizing: border-box;
    text-align: left;
    cursor: pointer; color: #0f172a;
    transition: background 0.15s;
    position: relative;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
  }
  .usercard-head:hover { background: #f8fafc; }
  .strikeboard-user-card.open .usercard-head {
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
  }
  .usercard-head .user-avatar-lg {
    flex: 0 0 auto;
    width: 2.2em; height: 2.2em;
    background: #15803d;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    font-weight: 700; font-size: 0.92em;
    letter-spacing: 0;
    box-shadow: none;
    border: none;
  }
  .usercard-head .user-name {
    flex: 1 1 auto; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    font-size: 1rem; font-weight: 600; color: #0f172a;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .usercard-head .user-strike-count {
    flex: 0 0 auto;
    background: #f1f5f9;
    color: #334155;
    font-size: 0.78rem; font-weight: 700;
    padding: 0.15em 0.6em;
    border-radius: 999px;
    border: 1px solid #e2e8f0;
    box-shadow: none;
    margin: 0;
    letter-spacing: 0;
    min-width: 1.7em; text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .usercard-head .chevron {
    flex: 0 0 auto;
    width: 1.3em; height: 1.3em;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15em; color: #94a3b8;
    margin: 0;
    transition: transform 0.2s ease;
  }
  .strikeboard-user-card.open .usercard-head .chevron {
    transform: rotate(90deg);
    color: #334155;
  }
  .usercard-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.25s ease;
    background: #f8fafc;
  }
  .strikeboard-user-card.open .usercard-content {
    max-height: 1200px;
    opacity: 1;
  }
  /* === STRIKE CARDS === */
  .strike-ultra-list {
    list-style: none;
    margin: 0;
    padding: 0.55rem 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .strike-card {
    background: #fff;
    border-radius: 8px;
    padding: 0.7rem 0.85rem 0.65rem;
    border: 1px solid #e2e8f0;
    box-shadow: none;
    transition: border-color 0.15s;
  }
  .strike-card.offen   { border-left: 3px solid #dc2626; }
  .strike-card.bezahlt { border-left: 3px solid #15803d; }
  .strike-card-top {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.35rem;
  }
  .strike-card-dot {
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .strike-card-dot.bezahlt { background: #15803d; }
  .strike-card-dot.offen   { background: #dc2626; }
  .strike-card-reason {
    flex: 1;
    font-weight: 600;
    font-size: 0.95rem;
    color: #0f172a;
    letter-spacing: -0.01em;
  }
  .strike-card-amount {
    font-weight: 700;
    font-size: 0.98rem;
    color: #0f172a;
    letter-spacing: -0.01em;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .strike-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem 0.95rem;
    font-size: 0.78rem;
    color: #64748b;
  }
  .strike-card-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
  }
  .strike-card-meta-item svg { color: #94a3b8; flex-shrink: 0; }
  .strike-card-badge {
    margin-left: auto;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18em 0.6em;
    border-radius: 4px;
  }
  .strike-card-badge.bezahlt {
    background: #ecfdf5;
    color: #15803d;
    border: 1px solid #bbf7d0;
  }
  .strike-card-badge.offen {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
  }
  .strike-card-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.55rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e2e8f0;
  }
  .strike-card-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.35em 0.75em;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s;
    font-family: inherit;
  }
  .strike-card-btn.edit {
    background: #f8fafc;
    color: #334155;
    border-color: #e2e8f0;
  }
  .strike-card-btn.edit:hover { background: #f1f5f9; border-color: #cbd5e1; }
  .strike-card-btn.delete {
    background: #ffffff;
    color: #dc2626;
    border-color: #fecaca;
  }
  .strike-card-btn.delete:hover { background: #fef2f2; border-color: #fca5a5; }
  @keyframes fadein-up {
    from { opacity: 0; transform: translateY(27px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes status-pulse {
    0%, 100% { box-shadow: 0 0 12px 3px #fe495c77; }
    50% { box-shadow: 0 0 18px 5px #fe495c99; }
  }
  .strike-row-actions {
    margin-left: 0.6em;
    display: flex;
    gap: 0.15em;
  }
  .strike-action-icon {
    border: none;
    background: none;
    font-size: 1.1em;
    cursor: pointer;
    color: #b9c5d5;
    padding: 0.14em 0.08em;
    border-radius: 50%;
    transition: background 0.13s, color 0.13s;
  }
  .strike-action-icon:hover {
    color: #13c074;
    background: #e2faf0;
  }
  .strike-action-icon.danger:hover {
    color: #d72626;
    background: #fff4f4;
  }
  .strikeboard-empty {
    padding: 1.15rem 1rem;
    color: #aaa;
    text-align: center;
    font-size: 0.95em;
    font-style: italic;
  }

  @media (max-width: 680px) {
    .strikeboard-app { max-width: 100%; margin: 0; }
  }
  @media (max-width: 700px) {
    .strikeboard-app { padding: 0 0.05rem; }
    .strikeboard-hero {
      padding: 1.2rem 1.1rem 1.2rem 1.1rem;
      border-radius: 1rem 1rem 1.5rem 1.5rem;
      margin: -0.25rem -0.1rem 1.4rem;
      box-shadow: 0 12px 24px rgba(18, 66, 43, 0.28), 0 3px 10px rgba(0, 0, 0, 0.1);
    }
    .strikeboard-title { font-size: 1.55rem; }
    .strikeboard-stats-row { gap: 0.45rem; margin-top: 0.75rem; }
    .strikeboard-stat-chip { padding: 0.26rem 0.65rem; min-width: 46px; }
    .strikeboard-stat-chip .stat-chip-value { font-size: 1.15rem; }
    .strikeboard-stat-chip .stat-chip-label { font-size: 0.62rem; }
    .strikeboard-orb-1 { width: 120px; height: 120px; top: -25px; right: -15px; }
    .strikeboard-orb-2 { width: 90px; height: 90px; }
    .usercard-head { font-size: 0.92rem; padding: 0.58rem 0.7rem; }
    .user-avatar-lg { width: 1.12em; height: 1.12em; font-size: 0.74em; }
    .strike-ultra-list { padding: 0.4rem 0.45rem; gap: 0.45rem; }
    .strike-card { padding: 0.65rem 0.75rem 0.55rem 0.75rem; }
    .strike-card-reason { font-size: 0.91rem; }
    .strike-card-amount { font-size: 0.95rem; }
    .strike-card-meta { font-size: 0.72rem; gap: 0.3rem 0.6rem; }
    .strike-card-actions { gap: 0.4rem; }
    .strike-card-btn { font-size: 0.73rem; padding: 0.28em 0.7em; }
  }
</style>

<script>
  const IS_ADMIN = <%= user.is_admin ? 'true' : 'false' %>;

  document.addEventListener('DOMContentLoaded', () => {
    const toggles = document.querySelectorAll('.usercard-head');

    // Für Admins: alle Karten direkt aufgeklappt
    if (IS_ADMIN) {
      document.querySelectorAll('.strikeboard-user-card').forEach(card => {
        card.classList.add('open');
        card.querySelector('.usercard-content').hidden = false;
        card.querySelector('.usercard-head').setAttribute('aria-expanded', 'true');
      });
    }

    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const card = toggle.closest('.strikeboard-user-card');
        const content = card.querySelector('.usercard-content');
        const isOpen = card.classList.contains('open');

        if (!IS_ADMIN) {
          // Normaler Modus: nur eine Karte auf einmal
          document.querySelectorAll('.strikeboard-user-card.open').forEach(openCard => {
            openCard.classList.remove('open');
            openCard.querySelector('.usercard-content').hidden = true;
            openCard.querySelector('.usercard-head').setAttribute('aria-expanded', 'false');
          });
        }

        // Aktuelle Karte toggeln
        if (!isOpen) {
          card.classList.add('open');
          content.hidden = false;
          toggle.setAttribute('aria-expanded', 'true');
        } else if (IS_ADMIN) {
          card.classList.remove('open');
          content.hidden = true;
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
</script>
