<%- include('partials/zeugwart_page_styles') %>

<main class="apple-dashboard">
  <header class="page-hero">
    <div class="page-hero-clip">
      <div class="page-hero-orb page-hero-orb-1"></div>
      <div class="page-hero-orb page-hero-orb-2"></div>
    </div>
    <div class="page-hero-content">
      <div class="page-hero-title-wrap">
        <span class="page-hero-kicker">Rechteverwaltung</span>
        <h1 class="page-hero-title">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Neue Rolle
        </h1>
      </div>
      <div class="page-hero-actions">
        <a href="/roles" class="page-hero-btn ghost">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Zurück
        </a>
      </div>
    </div>
  </header>

  <div class="dev-card" style="max-width: 700px;">

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="role-error-banner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><%= error %></span>
      </div>
    <% } %>

    <% if (typeof existingRoles !== 'undefined' && existingRoles && existingRoles.length) { %>
      <div class="existing-roles-block" id="existingRolesBlock" data-names='<%- JSON.stringify(existingRoles.map(function(r){return (r.name||"").toLowerCase();})) %>'>
        <div class="existing-roles-label">Bereits vorhandene Rollen <span class="existing-roles-count"><%= existingRoles.length %></span></div>
        <div class="existing-roles-list">
          <% existingRoles.forEach(function(r){ %>
            <span class="existing-role-chip<%= r.is_admin ? ' is-admin' : (r.is_board ? ' is-board' : '') %>" title="<%= r.description || '' %>">
              <%= r.name %>
              <% if (r.is_admin) { %><small>Admin</small><% } else if (r.is_board) { %><small>Vorstand</small><% } %>
            </span>
          <% }); %>
        </div>
        <p class="existing-roles-hint">Bitte keinen dieser Namen erneut verwenden &ndash; sie sind bereits vergeben.</p>
      </div>
    <% } %>

    <form method="POST" action="/roles/add" id="roleAddForm">
      <div class="apple-form-group">
        <label>Rollenname *</label>
        <input type="text" name="name" id="roleNameInput" class="apple-input" placeholder="z.B. Kassenwart" required value="<%= typeof prefillName !== 'undefined' ? prefillName : '' %>" autocomplete="off">
        <div id="roleNameWarning" class="role-name-warning" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Diese Rolle existiert bereits.
        </div>
      </div>
      </div>

      <div class="apple-form-group">
        <label>Beschreibung</label>
        <textarea name="description" class="apple-input" rows="3" placeholder="Optionale Beschreibung der Rolle"></textarea>
      </div>

      <div class="apple-form-group">
        <label style="margin-bottom: 1rem; display: block; font-weight: 700;">Berechtigungen</label>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem;">
          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_manage_members">
            <span class="perm-chip-icon" style="background:#dbeafe;color:#1d4ed8;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <span>Mitglieder verwalten</span>
          </label>

          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_manage_penalties">
            <span class="perm-chip-icon" style="background:#fef3c7;color:#b45309;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </span>
            <span>Aktionen verwalten<small>Erstellen, Bearbeiten, Löschen aller Aktionen</small></span>
          </label>

          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_view_all_penalties">
            <span class="perm-chip-icon" style="background:#e0e7ff;color:#4338ca;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </span>
            <span>Alle Aktionen sehen<small>Übersicht über alle Einträge im Verein</small></span>
          </label>

          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_manage_equipment">
            <span class="perm-chip-icon" style="background:#dcfce7;color:#15803d;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </span>
            <span>Equipment verwalten</span>
          </label>

          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_assign_equipment">
            <span class="perm-chip-icon" style="background:#cffafe;color:#0e7490;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            </span>
            <span>Equipment zuweisen</span>
          </label>

          <label class="perm-chip">
            <input type="checkbox" name="permissions" value="can_manage_roles">
            <span class="perm-chip-icon" style="background:#fce7f3;color:#be185d;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </span>
            <span>Rollen verwalten</span>
          </label>
        </div>
      </div>

      <div class="apple-form-group">
        <label style="margin-bottom: 1rem; display: block; font-weight: 700;">Besondere Rollen</label>
        
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem; background: #fef3c7; border-radius: 8px; cursor: pointer;">
            <input type="checkbox" name="permissions" value="is_board">
            <span><strong>Vorstand</strong> - Zugriff auf Vorstandsbereich</span>
          </label>

          <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem; background: #fee2e2; border-radius: 8px; cursor: pointer;">
            <input type="checkbox" name="permissions" value="is_admin">
            <span><strong>Administrator</strong> - Volle Rechte im Club</span>
          </label>
        </div>
      </div>

      <button type="submit" class="dev-btn-primary" style="margin-top: 1.5rem;">Rolle erstellen</button>
    </form>
  </div>
</main>

<style>
  .perm-chip {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 0.85rem;
    background: #f9fafb;
    border: 1.5px solid #e5e7eb;
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.1s;
    position: relative;
  }
  .perm-chip:hover { border-color: #3da973; background: #f3faf6; }
  .perm-chip:has(input:checked) {
    border-color: #2d8f55;
    background: linear-gradient(135deg, #f3faf6 0%, #e6f4ec 100%);
    box-shadow: 0 2px 10px rgba(45, 143, 85, 0.12);
  }
  .perm-chip input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #2d8f55;
    cursor: pointer;
    flex-shrink: 0;
  }
  .perm-chip-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .perm-chip-icon svg {
    width: 19px;
    height: 19px;
    display: block;
  }
  .perm-chip > span:last-child {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-weight: 700;
    color: #1a3d2a;
    font-size: 0.92rem;
    line-height: 1.25;
  }
  .perm-chip > span:last-child small {
    font-weight: 500;
    color: #6b7280;
    font-size: 0.72rem;
  }
  @media (max-width: 640px) {
    .perm-chip { padding: 0.55rem 0.7rem; gap: 0.55rem; }
    .perm-chip-icon { width: 32px; height: 32px; border-radius: 9px; }
    .perm-chip-icon svg { width: 17px; height: 17px; }
    .perm-chip > span:last-child { font-size: 0.85rem; }
  }

  /* Bereits vorhandene Rollen */
  .existing-roles-block {
    margin: 0 0 1.4rem;
    padding: 0.95rem 1rem 1rem;
    background: linear-gradient(135deg, #f7fbf8 0%, #eef5ee 100%);
    border: 1px solid #d6e6d8;
    border-radius: 12px;
  }
  .existing-roles-label {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #2d6a45;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.55rem;
  }
  .existing-roles-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    padding: 0 0.45rem;
    height: 20px;
    border-radius: 999px;
    background: #2d8f55;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0;
  }
  .existing-roles-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .existing-role-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid #c5e8d2;
    color: #1a7a45;
    font-size: 0.82rem;
    font-weight: 700;
  }
  .existing-role-chip small {
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
    background: #e6f4ec;
  }
  .existing-role-chip.is-admin { color: #a82a2a; border-color: #f6c6c6; }
  .existing-role-chip.is-admin small { background: #fde8e8; color: #a82a2a; }
  .existing-role-chip.is-board { color: #3a5ec0; border-color: #c8d3f4; }
  .existing-role-chip.is-board small { background: #e8edfb; color: #3a5ec0; }
  .existing-roles-hint {
    margin: 0.65rem 0 0;
    font-size: 0.76rem;
    color: #6b7280;
  }

  .role-error-banner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    margin-bottom: 1.1rem;
    background: #fde8e8;
    color: #a82a2a;
    border: 1px solid #f6c6c6;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .role-name-warning {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.4rem;
    color: #a82a2a;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .apple-input.is-duplicate {
    border-color: #d96363 !important;
    box-shadow: 0 0 0 3px rgba(217,99,99,0.16) !important;
  }
</style>

<script>
(function(){
  const block = document.getElementById('existingRolesBlock');
  const input = document.getElementById('roleNameInput');
  const warn  = document.getElementById('roleNameWarning');
  const form  = document.getElementById('roleAddForm');
  if (!input || !form) return;
  let names = [];
  if (block) {
    try { names = JSON.parse(block.dataset.names || '[]'); } catch(e) { names = []; }
  }
  function isDup() {
    const v = (input.value || '').trim().toLowerCase();
    return v.length > 0 && names.indexOf(v) !== -1;
  }
  function update() {
    const dup = isDup();
    if (warn) warn.hidden = !dup;
    input.classList.toggle('is-duplicate', dup);
  }
  input.addEventListener('input', update);
  input.addEventListener('blur', update);
  form.addEventListener('submit', function(e){
    if (isDup()) {
      e.preventDefault();
      update();
      input.focus();
    }
  });
  update();
})();
</script>
