<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <% if (typeof allowUserZoom !== 'undefined' && allowUserZoom) { %>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <% } else { %>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
  <% } %>
  <title><%= typeof title !== 'undefined' ? title : 'Spießbuch' %></title>
  <meta name="theme-color" content="#e6ede0">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Spießbuch">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/logo-192.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/logo-192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/icons/logo-512.png">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
  <link rel="stylesheet" href="/dev-center.css?v=20260513" />
  <link rel="stylesheet" href="/css/page-hero.css?v=20260513" />
 
  <style>
    :root {
      --green-dark: #3b413c;
      --nav-bg: rgba(255, 255, 255, 0.65);
      --radius: 1.85rem;
      --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      --blur: blur(12px);
      --accent: #7f857b;
      --menu-glass: rgba(241, 250, 233, 0.96);
      --menu-shadow: 0 14px 44px 0 #b6f6e77c, 0 2px 18px 0 #b9e8b342;
      --menu-border: 1.9px solid #c2e7d599;
      --hamburger-glow: 0 2px 12px #a7d7a726;
    }
    html, body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
      width: 100vw;
      box-sizing: border-box;
      font-family: var(--font);
      font-size: 17.5px;
      background-color: #ffffff;
      color: #222;
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    *, *::before, *::after { box-sizing: inherit; }
    body {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      /* Platz fuer den fixierten Header (Logo 138px + Paddings + Notch) */
      padding-top: calc(158px + env(safe-area-inset-top, 0px));
    }

    /* --- Navigation --- */
    .main-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      z-index: 120;
      display: flex;
      align-items: center;
      justify-content: space-between;
      /* Reicht bis unter Notch / Statusleiste */
      padding:
        calc(0.6rem + env(safe-area-inset-top, 0px))
        calc(2.4rem + env(safe-area-inset-right, 0px))
        0.6rem
        env(safe-area-inset-left, 0px);
      margin: 0;
      /* Reine vertikale Verlaufsfarbe ohne hellen Top-Glow, damit Notch + Header eine Flaeche bilden */
      background: linear-gradient(180deg, #e6ede0 0%, #dde6d6 55%, #d2dccb 100%);
      border-radius: 0 0 var(--radius) var(--radius);
      min-height: 130px;
      backdrop-filter: var(--blur);
      -webkit-backdrop-filter: var(--blur);
      user-select: none;
      border: 1.4px solid #c8d4be;
      border-top: none;
      /* Inset-Highlight oben entfernt – sah aus wie Trennlinie zur Statusleiste */
      box-shadow:
        inset 0 -2px 6px rgba(85,110,75,0.18),
        0 6px 22px rgba(85,110,75,0.14),
        0 1.5px 6px rgba(181,198,164,0.10);
    }
    .main-nav .logo {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 22px;
      text-decoration: none;
      text-align: left;
      user-select: text;
      line-height: 1;
      padding-left: 1.4rem;
      white-space: nowrap;
      transition: transform 0.25s ease, filter 0.25s ease;
    }
    .main-nav .logo:hover { transform: none; }
    .main-nav .logo:focus-visible { outline: 2px solid #2d8f55; outline-offset: 4px; border-radius: 14px; }
    .main-nav.has-user .logo { cursor: default; }
    .main-nav.has-user .logo:hover { transform: none; filter: none; }
    .main-nav.has-user .logo:hover img { transform: none; }

    /* Logo-Bild „eingefräst" — nahtlos im Header, ohne Kreis */
    .main-nav .logo-img-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 138px;
      height: 138px;
      flex-shrink: 0;
      background: transparent;
      box-shadow: none;
      border-radius: 0;
    }
    .main-nav .logo img {
      position: relative;
      z-index: 1;
      height: 128px;
      width: 128px;
      object-fit: contain;
      border-radius: 0;
      box-shadow: none;
      background: none;
      filter:
        drop-shadow(0 -1px 0 rgba(40,60,40,0.55))
        drop-shadow(-1px -1px 1px rgba(40,60,40,0.35))
        drop-shadow(0 1px 0 rgba(255,255,255,0.7))
        drop-shadow(1px 2px 1px rgba(255,255,255,0.4));
      user-select: none;
      pointer-events: none;
      mix-blend-mode: multiply;
      opacity: 0.95;
    }
    .main-nav .logo:hover img { transform: none; filter: none; }

    /* Wordmark — als wäre der Name in das Material des Headers eingestanzt */
    .main-nav .logo-wordmark {
      position: relative;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      font-size: clamp(26px, 5.6vw, 52px);
      font-weight: 900;
      letter-spacing: -1.8px;
      line-height: 0.95;
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
      hyphens: auto;
      color: #b6c3ab;
      text-shadow:
        0 -1px 0 rgba(40,60,40,0.55),
        0 -2px 1px rgba(40,60,40,0.18),
        0 1px 0 rgba(255,255,255,0.85),
        0 2px 1px rgba(255,255,255,0.45);
      padding-bottom: 4px;
    }
    .main-nav .logo-wordmark::after {
      content: '';
      position: absolute;
      left: 2px;
      right: 8px;
      bottom: -2px;
      height: 2px;
      border-radius: 99px;
      background: linear-gradient(90deg, rgba(40,60,40,0.25) 0%, rgba(40,60,40,0.05) 60%, transparent 100%);
      box-shadow: 0 1px 0 rgba(255,255,255,0.7);
    }
    .nav-menu {
      display: flex;
      gap: 0.38em;
      align-items: center;
      list-style: none;
      margin: 0;
      padding: 0;
      user-select: none;
      transition: none;
    }
    .nav-menu li { position: relative; }
    .nav-menu a,
    .btn-logout {
      display: flex;
      align-items: center;
      gap: 0.31em;
      background: none;
      border: none;
      font-size: 1.1rem;
      color: var(--green-dark);
      text-decoration: none;
      padding: 0.64em 1.27em;
      border-radius: 1.1rem;
      transition:
        background 0.22s,
        color 0.18s,
        box-shadow 0.3s,
        filter 0.18s;
      font-weight: 500;
      cursor: pointer;
      outline: none;
      position: relative;
      overflow: hidden;
      will-change: background, box-shadow, filter;
      user-select: text;
    }
    .nav-menu a:hover,
    .btn-logout:hover {
      background: #dce1d5;
      color: var(--green-dark);
      box-shadow: none;
      filter: none;
    }
    .nav-menu a:focus-visible,
    .btn-logout:focus-visible {
      outline-offset: 4px;
      outline: 3px solid #a0bb8ccc;
      background: rgba(170 188 150 / 0.15);
    }
    .btn-logout svg {
      vertical-align: middle;
      margin-left: 3px;
      stroke-width: 2.3;
      stroke-linejoin: round;
    }

    /* --- Hamburger Button --- */
    .hamburger-btn {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      background: linear-gradient(160deg, rgba(255,255,255,0.9), rgba(237,247,236,0.92));
      border: 1.4px solid rgba(122, 164, 130, 0.28);
      cursor: pointer;
      padding: 0;
      border-radius: 14px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65), 0 2px 12px rgba(61,169,115,0.12), 0 1px 4px rgba(0,0,0,0.05);
      transition: background 0.18s, box-shadow 0.18s, border-color 0.18s, transform 0.14s;
      position: relative;
      z-index: 130;
      width: 42px;
      height: 42px;
      opacity: 1;
      outline: none;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      overflow: hidden;
    }
    .hamburger-btn span {
      display: block;
      width: 21px;
      height: 2.4px;
      background: #2b5f3b;
      border-radius: 99px;
      transition:
        transform 0.38s cubic-bezier(.23,1.2,.64,1),
        opacity   0.22s ease,
        width     0.28s cubic-bezier(.23,1.2,.64,1);
      transform-origin: center center;
      will-change: transform, opacity, width;
    }
    .hamburger-btn span:nth-child(1) { width: 21px; }
    .hamburger-btn span:nth-child(2) { width: 15px; }
    .hamburger-btn span:nth-child(3) { width: 21px; }
    /* open state → X */
    .hamburger-btn.open {
      background: rgba(230,245,235,0.95);
      border-color: rgba(61,169,115,0.38);
      box-shadow: 0 4px 22px rgba(61,169,115,0.18), 0 1px 6px rgba(0,0,0,0.07);
    }
    .hamburger-btn.open span:nth-child(1) {
      transform: translateY(7.5px) rotate(45deg);
      width: 22px;
    }
    .hamburger-btn.open span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    .hamburger-btn.open span:nth-child(3) {
      transform: translateY(-7.5px) rotate(-45deg);
      width: 22px;
    }
    .hamburger-btn:hover:not(.open) {
      background: linear-gradient(160deg, rgba(247,252,246,0.98), rgba(223,240,229,0.95));
      border-color: rgba(61,169,115,0.35);
      box-shadow: 0 3px 18px rgba(61,169,115,0.18);
      transform: translateY(-1px);
    }
    .hamburger-btn:active {
      transform: scale(0.93);
    }
    .hamburger-btn:focus-visible {
      outline: 3px solid #a0bb8ccc;
      outline-offset: 3px;
    }

    /* --- Overlay für mobile nav --- */
    .nav-fancy-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 108;
      background: rgba(0,0,0,0.38);
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
    }
    @keyframes overlayFadeIn { from{opacity:0;} to{opacity:1;} }

    /* Sheet-Elemente + Icons: auf Desktop ausblenden */
    .nav-sheet-handle,
    .nav-sheet-section,
    .nav-sheet-divider { display: none; }
    .nav-item-icon { display: none; }
    .nav-logout-text { display: none; }
    .nav-logout-desktop-icon { display: inline-flex; align-items: center; }

    /* Bottom Sheet: versteckt per display:none, JS setzt display:flex vor Animation */
    @media (max-width: 1199px) {
      .main-nav {
        min-height: 64px;
        padding:
          calc(0.56rem + env(safe-area-inset-top, 0px))
          calc(0.75rem + env(safe-area-inset-right, 0px))
          0.56rem
          calc(0.75rem + env(safe-area-inset-left, 0px));
        justify-content: center;
      }
      .main-nav .logo {
        font-size: 34px;
        gap: 10px;
        position: static;
        left: auto;
        transform: none;
        padding-left: 0;
        margin: 0 auto;
      }
      .main-nav.has-user {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr) 42px;
        align-items: center;
      }
      .main-nav.has-user::before {
        content: '';
        grid-column: 1;
        width: 42px;
        height: 42px;
        visibility: hidden;
      }
      .main-nav.has-user .logo {
        grid-column: 2;
        justify-self: center;
        margin: 0;
      }
      .main-nav.has-user .hamburger-btn {
        grid-column: 3;
        justify-self: end;
      }
      .main-nav .logo img { height: 40px; width: 40px; }
      .main-nav .logo-img-wrap { width: 48px; height: 48px; }
      .main-nav .logo-wordmark { font-size: 28px; letter-spacing: -0.8px; }

      /* Bottom Sheet – transition-basiert, kein keyframe */
      .nav-menu {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        position: fixed;
        bottom: 0; left: 0; right: 0; top: auto;
        background: #f3f5f2;
        padding: 0 0 1.2rem 0;
        border-radius: 1.7rem 1.7rem 0 0;
        box-shadow: 0 -6px 48px rgba(0,0,0,0.20), 0 -1px 12px rgba(61,169,115,0.10);
        min-width: unset;
        max-width: 100%;
        max-height: 90dvh;
        overflow-y: auto;
        border: none;
        border-top: 1.5px solid rgba(100,180,140,0.14);
        z-index: 110;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
        user-select: none;
        /* versteckt: unterhalb des Bildschirms */
        transform: translateY(100%);
        visibility: hidden;
        pointer-events: none;
        transition: transform 0.36s cubic-bezier(0.32, 1.12, 0.5, 1),
                    visibility 0s linear 0.36s;
      }
      .nav-menu.open {
        transform: translateY(0);
        visibility: visible;
        pointer-events: all;
        transition: transform 0.36s cubic-bezier(0.32, 1.12, 0.5, 1),
                    visibility 0s linear 0s;
      }

      /* Drag Handle */
      .nav-sheet-handle {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0.65rem 0 0.3rem;
        flex-shrink: 0;
        cursor: grab;
        list-style: none;
      }
      .nav-sheet-handle::before {
        content: '';
        display: block;
        width: 38px; height: 4px;
        background: rgba(80,100,80,0.2);
        border-radius: 999px;
      }

      /* Section Label */
      .nav-sheet-section {
        display: block;
        padding: 0.65rem 1.3rem 0.18rem;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #8a9485;
        list-style: none;
      }

      /* Divider */
      .nav-sheet-divider {
        display: block;
        height: 1px;
        background: rgba(100,140,110,0.13);
        margin: 0.3rem 1.1rem;
        list-style: none;
      }

      .nav-menu li { width: 100%; list-style: none; }

      .nav-menu a,
      .btn-logout {
        display: flex;
        align-items: center;
        gap: 0.82em;
        font-size: 1rem;
        color: #1a2d25;
        padding: 0.6em 1em;
        margin: 0.04rem 0.75rem;
        border-radius: 1em;
        transition: background 0.14s, transform 0.1s;
        background: none;
        box-shadow: none;
        width: calc(100% - 1.5rem);
        justify-content: flex-start;
        font-weight: 600;
        letter-spacing: -0.01em;
        filter: none;
      }
      .nav-menu a.active {
        background: rgba(61,169,115,0.13) !important;
        color: #1a7a45 !important;
      }
      .nav-menu a:active,
      .btn-logout:active {
        background: rgba(61,169,115,0.1);
        transform: scale(0.985);
        color: #1a7a45;
      }
      .nav-menu a:focus-visible,
      .btn-logout:focus-visible {
        background: #e4f2eb;
        color: #238a50;
        outline: 3px solid #a0bb8ccc;
      }

      /* Icon-Kreis */
      .nav-item-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px; height: 36px;
        border-radius: 10px;
        flex-shrink: 0;
      }

      /* Logout in Sheet */
      .nav-logout-text { display: inline; font-weight: 600; color: #c0282a; }
      .nav-logout-desktop-icon { display: none !important; }
      .nav-logout-form { display: block; margin: 0.1rem 0.75rem 0.4rem; }
      .nav-logout-form .btn-logout { width: 100%; margin: 0; border-radius: 1em; }

      .hamburger-btn { display: flex; }
    }

    /* --- Main Content Container --- */
    main.container {
      flex: 1;
      width: 100%;
      max-width: 680px;
      box-sizing: border-box;
      margin: 2.6rem auto 2.8rem auto;
      background: #ffffff;
      border-radius: 0;
      box-shadow: 0 12px 40px rgba(122 142 111 / 0.14), 0 4px 16px rgba(181 198 164 / 0.09);
      padding: 2.8rem 2.3rem 2.3rem 2.3rem;
      min-height: 66dvh;
      backdrop-filter: var(--blur);
      -webkit-backdrop-filter: var(--blur);
      border: 1.4px solid #d4dfcfcc;
      border-top: none;
      transition: box-shadow 0.28s ease, border-color 0.28s ease;
      will-change: box-shadow;
      user-select: text;
      overflow-wrap: break-word;
      word-break: break-word;
    }
    main.container.container--flush { padding: 0; overflow: hidden; }
    @media (max-width: 680px) {
      main.container {
        margin: 0;
        border-radius: 0;
        border-left: none;
        border-right: none;
        box-shadow: none;
        min-height: calc(100dvh - 64px);
        padding: 1.5rem 1rem 2rem 1rem;
      }
      main.container.container--flush { padding: 0; border: none; }
    }
    main.container:focus-within, main.container:hover {
      box-shadow: 0 18px 66px 0 #b0b99b33, 0 6px 22px 0 #a0bb8c2e;
      border-color: var(--accent);
    }
    /* --- Footer --- */
    .footer {
      text-align: center;
      font-size: 0.78rem;
      color: #7d8e7a;
      margin-bottom: 0.9rem;
      margin-top: 1.9rem;
      letter-spacing: 0.01em;
      background: none;
      opacity: 0.91;
      user-select: none;
      -webkit-user-select: none;
    }
    /* --- Scrollbar Styling --- */
    ::-webkit-scrollbar { width: 8px; height: 8px; background: transparent; }
    ::-webkit-scrollbar-thumb { background-color: rgba(181 198 164 / 0.18); border-radius: 8px; }
    /* --- Verhindert horizontales Scrollen bei breiten Inhalten --- */
    img, table, video, iframe, input, textarea, select { max-width: 100%; box-sizing: border-box; word-wrap: break-word; overflow-wrap: break-word; }

    /* Desktop Navigation Details */
    .nav-desktop { display: none; }
    @media (min-width: 1200px) {
      .main-nav .nav-menu, body > .nav-menu { display: none !important; }
      .main-nav .hamburger-btn, .hamburger-btn { display: none !important; }
      .nav-desktop { display: flex; align-items: center; gap: 0.3rem; margin-left: auto; padding-right: 0.8rem; }
      .nav-d-link, .nav-d-btn, .nav-d-icon-link {
        display: inline-flex; align-items: center; gap: 0.42em; font-family: inherit; font-size: 0.92rem; font-weight: 600;
        color: #1f4a30; background: transparent; border: 1.2px solid transparent; padding: 0.5em 0.85em; border-radius: 0.85em;
        cursor: pointer; text-decoration: none; line-height: 1;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease, transform 0.12s ease;
      }
      .nav-d-link svg, .nav-d-btn svg, .nav-d-icon-link svg { color: #2d8f55; }
      .nav-d-link:hover, .nav-d-btn:hover, .nav-d-icon-link:hover { background: rgba(255,255,255,0.7); border-color: rgba(45,143,85,0.22); color: #154e2c; }
      .nav-d-link.active, .nav-d-icon-link.active { background: rgba(61,169,115,0.18); border-color: rgba(45,143,85,0.35); color: #15532e; box-shadow: inset 0 1px 0 rgba(255,255,255,0.6); }
      .nav-d-link:focus-visible, .nav-d-btn:focus-visible, .nav-d-icon-link:focus-visible { outline: 2px solid #2d8f55; outline-offset: 2px; }
      .nav-d-icon-link { padding: 0.55em; gap: 0; }
      .nav-d-logout-form { margin: 0; display: inline-flex; }
      .nav-d-logout { background: transparent; border: 1.2px solid transparent; }
      .nav-d-logout svg { color: #c0282a; }
      .nav-d-logout:hover { background: #fdecec; border-color: rgba(192,40,42,0.3); }
    }
  </style>
</head>
<body>

  <nav class="main-nav <%= user ? 'has-user' : '' %>">
    <a href="/" class="logo">
      <div class="logo-img-wrap">
        <img src="/icons/logo-192.png" alt="Logo" />
      </div>
      <span class="logo-wordmark">Spießbuch</span>
    </a>

    <% if (user) { %>
      <ul class="nav-menu">
        <li class="nav-sheet-handle"></li>
        <li class="nav-sheet-section">Navigation</li>
        
        <li class="<%= path === '/' ? 'active' : '' %>">
          <a href="/" class="<%= path === '/' ? 'active' : '' %>">
            <span class="nav-item-icon">📋</span>
            <span>Dashboard</span>
          </a>
        </li>
        <li class="<%= path === '/penalties' ? 'active' : '' %>">
          <a href="/penalties" class="<%= path === '/penalties' ? 'active' : '' %>">
            <span class="nav-item-icon">💸</span>
            <span>Strafen</span>
          </a>
        </li>
        <li class="<%= path === '/events' ? 'active' : '' %>">
          <a href="/events" class="<%= path === '/events' ? 'active' : '' %>">
            <span class="nav-item-icon">📅</span>
            <span>Termine</span>
          </a>
        </li>
        
        <li class="<%= path === '/drinkrounds' ? 'active' : '' %>">
          <a href="/drinkrounds" class="<%= path === '/drinkrounds' ? 'active' : '' %>">
            <span class="nav-item-icon">🍺</span>
            <span>Getränkerunden</span>
          </a>
        </li>

        <li class="nav-sheet-divider"></li>
        <li class="nav-sheet-section">Konto</li>
        <li class="<%= path === '/profile' ? 'active' : '' %>">
          <a href="/profile" class="<%= path === '/profile' ? 'active' : '' %>">
            <span class="nav-item-icon">👤</span>
