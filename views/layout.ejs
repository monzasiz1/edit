      .nav-d-logout svg { color: #c0282a; }
      .nav-d-logout:hover { background: #fdecec; border-color: rgba(192,40,42,0.3); }

      .nav-d-group { position: relative; }
      .nav-d-group::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        height: 12px;
        background: transparent;
      }
      .nav-d-btn .nav-d-caret { transition: transform 0.2s ease; opacity: 0.7; }
      .nav-d-group:hover .nav-d-btn,
      .nav-d-group:focus-within .nav-d-btn {
        background: rgba(255,255,255,0.85);
        border-color: rgba(45,143,85,0.28);
      }
      .nav-d-group:hover .nav-d-caret,
      .nav-d-group:focus-within .nav-d-caret { transform: rotate(180deg); }

      .nav-d-pop {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 280px;
        background: #ffffff;
        border: 1px solid rgba(45,143,85,0.18);
        border-radius: 1em;
        box-shadow:
          0 18px 40px rgba(20,60,40,0.18),
          0 4px 14px rgba(20,60,40,0.10);
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        opacity: 0;
        transform: translateY(-6px) scale(0.98);
        transform-origin: top right;
        pointer-events: none;
        transition: opacity 0.18s ease, transform 0.18s ease;
        z-index: 200;
      }
      .nav-d-pop::after {
        content: '';
        position: absolute;
        top: -14px;
        left: 0;
        right: 0;
        height: 14px;
        background: transparent;
      }
      .nav-d-pop::before {
        content: '';
        position: absolute;
        top: -8px;
        right: 1.6em;
        width: 14px;
        height: 14px;
        background: #ffffff;
        border-left: 1px solid rgba(45,143,85,0.18);
        border-top: 1px solid rgba(45,143,85,0.18);
        transform: rotate(45deg);
      }
      .nav-d-group:hover .nav-d-pop,
      .nav-d-group:focus-within .nav-d-pop {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
      }

      .nav-d-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.55rem 0.7rem;
        border-radius: 0.7em;
        text-decoration: none;
        color: #1c3a25;
        transition: background 0.14s ease;
      }
      .nav-d-item:hover { background: #f1f7f2; }
      .nav-d-item span:not(.nav-d-ic) {
        display: flex;
        flex-direction: column;
        gap: 2px;
        line-height: 1.15;
      }
      .nav-d-item strong { font-size: 0.93rem; font-weight: 700; color: #154e2c; }
      .nav-d-item small  { font-size: 0.76rem; font-weight: 500; color: #6f8678; }
      .nav-d-ic {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 0.6em;
      }
    }

    @media (min-width: 1100px) {
      .nav-d-link,
      .nav-d-btn { font-size: 0.97rem; padding: 0.55em 0.95em; }
    }
  </style>
