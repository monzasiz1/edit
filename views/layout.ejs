<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'Spießbuch' %></title>
  <meta name="theme-color" content="#3da973">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Spießbuch">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/logo-192.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/logo-192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/icons/logo-512.png">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
  <link rel="stylesheet" href="/dev-center.css?v=20260513" />
 
  <style>
    :root {
      --green-dark: #3b413c;
      --nav-bg: rgba(255, 255, 255, 0.65);
      --radius: 1.85rem;
      --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      --blur: blur(12px);
      --accent: #7f857b;
      --menu-glass: rgba(241, 250, 233, 0.96);
      --menu-shadow: 0 14px 44px 0 #b6f6e77c, 0 2px 18px 0 #b9e8b342;
      --menu-border: 1.9px solid #c2e7d599;
      --hamburger-glow: 0 2px 12px #a7d7a726;
    }
    html, body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
      width: 100vw;
      box-sizing: border-box;
      font-family: var(--font);
      font-size: 17.5px;
      background: #ffffff;
      color: #222;
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    *, *::before, *::after { box-sizing: inherit; }
    body { min-height: 100dvh; display: flex; flex-direction: column; }

    /* --- Navigation --- */
    .main-nav {
      position: sticky;
      top: 0;
      z-index: 99;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.7rem 2.4rem 0.7rem 0;
      background: var(--nav-bg);
      border-radius: 0 0 var(--radius) var(--radius);
      min-height: 64px;
      backdrop-filter: var(--blur);
      -webkit-backdrop-filter: var(--blur);
      user-select: none;
      border: 1.4px solid #d4dfcfcc;
      border-top: none;
      box-shadow: 0 4px 18px rgba(122,142,111,0.10), 0 1.5px 6px rgba(181,198,164,0.08);
    }
    .main-nav .logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      font-size: 42px;
      font-weight: 900;
      color: var(--green-dark);
      letter-spacing: -0.025em;
      text-decoration: none;
      text-align: center;
      user-select: text;
      line-height: 1;
      padding-left: 1rem;
      white-space: nowrap;
    }
    .main-nav .logo img {
      height: 56px;
      width: 56px;
      object-fit: contain;
      border-radius: 0;
      box-shadow: none;
      background: none;
      filter: none;
      user-select: none;
      pointer-events: none;
      transition: none;
    }
    .nav-menu {
      display: flex;
      gap: 0.38em;
      align-items: center;
      list-style: none;
      margin: 0;
      padding: 0;
      user-select: none;
      transition: none;
    }
    .nav-menu li { position: relative; }
    .nav-menu a,
    .btn-logout {
      display: flex;
      align-items: center;
      gap: 0.31em;
      background: none;
      border: none;
      font-size: 1.1rem;
      color: var(--green-dark);
      text-decoration: none;
      padding: 0.64em 1.27em;
      border-radius: 1.1rem;
      transition:
        background 0.22s,
        color 0.18s,
        box-shadow 0.3s,
        filter 0.18s;
      font-weight: 500;
      cursor: pointer;
      outline: none;
      position: relative;
      overflow: hidden;
      will-change: background, box-shadow, filter;
      user-select: text;
    }
    .nav-menu a:hover,
    .btn-logout:hover {
      background: #dce1d5;
      color: var(--green-dark);
      box-shadow: none;
      filter: none;
    }
    .nav-menu a:focus-visible,
    .btn-logout:focus-visible {
      outline-offset: 4px;
      outline: 3px solid #a0bb8ccc;
      background: rgba(170 188 150 / 0.15);
    }
    .btn-logout svg {
      vertical-align: middle;
      margin-left: 3px;
      stroke-width: 2.3;
      stroke-linejoin: round;
    }

    /* --- Hamburger Button --- */
    .hamburger-btn {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      background: linear-gradient(160deg, rgba(255,255,255,0.9), rgba(237,247,236,0.92));
      border: 1.4px solid rgba(122, 164, 130, 0.28);
      cursor: pointer;
      padding: 0;
      border-radius: 14px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65), 0 2px 12px rgba(61,169,115,0.12), 0 1px 4px rgba(0,0,0,0.05);
      transition: background 0.18s, box-shadow 0.18s, border-color 0.18s, transform 0.14s;
      position: relative;
      z-index: 130;
      width: 42px;
      height: 42px;
      opacity: 1;
      outline: none;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      overflow: hidden;
    }
    .hamburger-btn span {
      display: block;
      width: 21px;
      height: 2.4px;
      background: #2b5f3b;
      border-radius: 99px;
      transition:
        transform 0.38s cubic-bezier(.23,1.2,.64,1),
        opacity   0.22s ease,
        width     0.28s cubic-bezier(.23,1.2,.64,1);
      transform-origin: center center;
      will-change: transform, opacity, width;
    }
    .hamburger-btn span:nth-child(1) { width: 21px; }
    .hamburger-btn span:nth-child(2) { width: 15px; }
    .hamburger-btn span:nth-child(3) { width: 21px; }
    /* open state → X */
    .hamburger-btn.open {
      background: rgba(230,245,235,0.95);
      border-color: rgba(61,169,115,0.38);
      box-shadow: 0 4px 22px rgba(61,169,115,0.18), 0 1px 6px rgba(0,0,0,0.07);
    }
    .hamburger-btn.open span:nth-child(1) {
      transform: translateY(7.5px) rotate(45deg);
      width: 22px;
    }
    .hamburger-btn.open span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    .hamburger-btn.open span:nth-child(3) {
      transform: translateY(-7.5px) rotate(-45deg);
      width: 22px;
    }
    .hamburger-btn:hover:not(.open) {
      background: linear-gradient(160deg, rgba(247,252,246,0.98), rgba(223,240,229,0.95));
      border-color: rgba(61,169,115,0.35);
      box-shadow: 0 3px 18px rgba(61,169,115,0.18);
      transform: translateY(-1px);
    }
    .hamburger-btn:active {
      transform: scale(0.93);
    }
    .hamburger-btn:focus-visible {
      outline: 3px solid #a0bb8ccc;
      outline-offset: 3px;
    }

    /* --- Overlay für mobile nav --- */
    .nav-fancy-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 108;
      background: rgba(0,0,0,0.38);
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
    }
    @keyframes overlayFadeIn { from{opacity:0;} to{opacity:1;} }

    /* Sheet-Elemente + Icons: auf Desktop ausblenden */
    .nav-sheet-handle,
    .nav-sheet-section,
    .nav-sheet-divider { display: none; }
    .nav-item-icon { display: none; }
    .nav-logout-text { display: none; }
    .nav-logout-desktop-icon { display: inline-flex; align-items: center; }

    /* Bottom Sheet: versteckt per display:none, JS setzt display:flex vor Animation */
    @media (max-width: 680px) {
      .main-nav {
        padding: 0.56rem 0.75rem;
        justify-content: center;
      }
      .main-nav .logo {
        font-size: 34px; gap: 10px;
        position: static;
        left: auto;
        transform: none;
        padding-left: 0;
        margin: 0 auto;
      }
      .main-nav.has-user {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr) 42px;
        align-items: center;
      }
      .main-nav.has-user::before {
        content: '';
        grid-column: 1;
        width: 42px;
        height: 42px;
        visibility: hidden;
      }
      .main-nav.has-user .logo {
        grid-column: 2;
        justify-self: center;
        margin: 0;
      }
      .main-nav.has-user .hamburger-btn {
        grid-column: 3;
        justify-self: end;
      }
      .main-nav .logo img { height: 40px; width: 40px; }

      /* Bottom Sheet – transition-basiert, kein keyframe */
      .nav-menu {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        position: fixed;
        bottom: 0; left: 0; right: 0; top: auto;
        background: #f3f5f2;
        padding: 0 0 1.2rem 0;
        border-radius: 1.7rem 1.7rem 0 0;
        box-shadow: 0 -6px 48px rgba(0,0,0,0.20), 0 -1px 12px rgba(61,169,115,0.10);
        min-width: unset;
        max-width: 100%;
        max-height: 90dvh;
        overflow-y: auto;
        border: none;
        border-top: 1.5px solid rgba(100,180,140,0.14);
        z-index: 110;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
        user-select: none;
        /* versteckt: unterhalb des Bildschirms */
        transform: translateY(100%);
        visibility: hidden;
        pointer-events: none;
        transition: transform 0.36s cubic-bezier(0.32, 1.12, 0.5, 1),
                    visibility 0s linear 0.36s;
      }
      .nav-menu.open {
        transform: translateY(0);
        visibility: visible;
        pointer-events: all;
        transition: transform 0.36s cubic-bezier(0.32, 1.12, 0.5, 1),
                    visibility 0s linear 0s;
      }

      /* Drag Handle */
      .nav-sheet-handle {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0.65rem 0 0.3rem;
        flex-shrink: 0;
        cursor: grab;
        list-style: none;
      }
      .nav-sheet-handle::before {
        content: '';
        display: block;
        width: 38px; height: 4px;
        background: rgba(80,100,80,0.2);
        border-radius: 999px;
      }

      /* Section Label */
      .nav-sheet-section {
        display: block;
        padding: 0.65rem 1.3rem 0.18rem;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #8a9485;
        list-style: none;
      }

      /* Divider */
      .nav-sheet-divider {
        display: block;
        height: 1px;
        background: rgba(100,140,110,0.13);
        margin: 0.3rem 1.1rem;
        list-style: none;
      }

      .nav-menu li { width: 100%; list-style: none; }

      .nav-menu a,
      .btn-logout {
        display: flex;
        align-items: center;
        gap: 0.82em;
        font-size: 1rem;
        color: #1a2d25;
        padding: 0.6em 1em;
        margin: 0.04rem 0.75rem;
        border-radius: 1em;
        transition: background 0.14s, transform 0.1s;
        background: none;
        box-shadow: none;
        width: calc(100% - 1.5rem);
        justify-content: flex-start;
        font-weight: 600;
        letter-spacing: -0.01em;
        filter: none;
      }
      .nav-menu a.active {
        background: rgba(61,169,115,0.13) !important;
        color: #1a7a45 !important;
      }
      .nav-menu a:active,
      .btn-logout:active {
        background: rgba(61,169,115,0.1);
        transform: scale(0.985);
        color: #1a7a45;
      }
      .nav-menu a:focus-visible,
      .btn-logout:focus-visible {
        background: #e4f2eb;
        color: #238a50;
        outline: 3px solid #a0bb8ccc;
      }

      /* Icon-Kreis */
      .nav-item-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px; height: 36px;
        border-radius: 10px;
        flex-shrink: 0;
      }

      /* Logout in Sheet */
      .nav-logout-text { display: inline; font-weight: 600; color: #c0282a; }
      .nav-logout-desktop-icon { display: none !important; }
      .nav-logout-form { display: block; margin: 0.1rem 0.75rem 0.4rem; }
      .nav-logout-form .btn-logout { width: 100%; margin: 0; border-radius: 1em; }

      .hamburger-btn { display: flex; }
    }

    /* --- Spieße Subbar --- */
    .spiesse-subbar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      max-width: 860px;
      margin: 0.45rem auto 0 auto;
      padding: 0.45rem 1.1rem;
      background: rgba(255,255,255,0.55);
      border: 1px solid rgba(100,180,145,0.18);
      border-radius: 0 0 1.4em 1.4em;
      backdrop-filter: blur(14px) saturate(1.3);
      -webkit-backdrop-filter: blur(14px) saturate(1.3);
      box-shadow: 0 4px 18px rgba(26,230,141,0.08);
      animation: spiesse-slidein 0.45s cubic-bezier(.48,.15,0,1.12);
    }
    @keyframes spiesse-slidein {
      from { opacity: 0; transform: translateY(-8px); }
      to   { opacity: 1; transform: none; }
    }
    .spiesse-subbar-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: #3da973;
      opacity: 0.8;
      white-space: nowrap;
    }
    .spiesse-subbar-chips {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .spiesse-subbar-chip {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(240,255,245,0.82);
      border: 1px solid rgba(80,190,140,0.2);
      border-radius: 2em;
      padding: 0.18rem 0.62rem 0.18rem 0.26rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: #215137;
      transition: background 0.15s;
    }
    .spiesse-subbar-chip:hover {
      background: rgba(200,245,225,0.9);
    }
    .spiesse-subbar-avatar {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 1.5em;
      height: 1.5em;
      border-radius: 50%;
      background: linear-gradient(120deg, #3aeed0 10%, #3b8bff 90%);
      color: #fff;
      font-size: 0.62em;
      font-weight: 900;
      flex-shrink: 0;
    }
    .spiesse-subbar-name {
      color: #1b4d34;
      font-weight: 700;
    }
    @media (max-width: 680px) {
      .spiesse-subbar {
        border-radius: 0 0 1em 1em;
        padding: 0.4rem 0.85rem;
        gap: 0.5rem;
        margin: 0.3rem auto 0 auto;
      }
      .spiesse-subbar-chip { font-size: 0.78rem; }
    }

    /* --- Main Content Container --- */
    main.container {
      flex: 1;
      width: 100%;
      max-width: 680px;
      box-sizing: border-box;
      margin: 2.6rem auto 2.8rem auto;
      background: #ffffff;
      border-radius: 0;
      box-shadow: 0 12px 40px rgba(122 142 111 / 0.14), 0 4px 16px rgba(181 198 164 / 0.09);
      padding: 2.8rem 2.3rem 2.3rem 2.3rem;
      min-height: 66dvh;
      backdrop-filter: var(--blur);
      -webkit-backdrop-filter: var(--blur);
      border: 1.4px solid #d4dfcfcc;
      border-top: none;
      transition: box-shadow 0.28s ease, border-color 0.28s ease;
      will-change: box-shadow;
      user-select: text;
      overflow-wrap: break-word;
      word-break: break-word;
    }
    main.container.container--flush {
      padding: 0;
      overflow: hidden;
    }
    @media (max-width: 680px) {
      main.container {
        margin: 0;
        border-radius: 0;
        border-left: none;
        border-right: none;
        box-shadow: none;
        min-height: calc(100dvh - 64px);
        padding: 1.5rem 1rem 2rem 1rem;
      }
      main.container.container--flush {
        padding: 0;
        border: none;
      }
    }
    main.container:focus-within,
    main.container:hover {
      box-shadow: 0 18px 66px 0 #b0b99b33, 0 6px 22px 0 #a0bb8c2e;
      border-color: var(--accent);
    }
    /* --- Footer --- */
    .footer {
      text-align: center;
      font-size: 0.78rem;
      color: #7d8e7a;
      margin-bottom: 0.9rem;
      margin-top: 1.9rem;
      letter-spacing: 0.01em;
      background: none;
      opacity: 0.91;
      user-select: none;
      -webkit-user-select: none;
    }
    /* --- Scrollbar Styling --- */
    ::-webkit-scrollbar {
      width: 8px; height: 8px; background: transparent;
    }
    ::-webkit-scrollbar-thumb {
      background-color: rgba(181 198 164 / 0.18); border-radius: 8px;
    }
    /* --- Verhindert horizontales Scrollen bei breiten Inhalten --- */
    img, table, video, iframe, input, textarea, select {
      max-width: 100%;
      box-sizing: border-box;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
  </style>
</head>
<body>
  <nav class="main-nav<% if (user) { %> has-user<% } %>" role="navigation" aria-label="Hauptnavigation">
    <a href="/" class="logo" tabindex="0" aria-label="Spießbuch Startseite">
      <img src="/logo.png" alt="Logo Spießbuch" />
      Spießbuch
    </a>
    <% if (user) { %>
      <button class="hamburger-btn" id="hamburger-btn" aria-label="Menü öffnen" aria-expanded="false" aria-controls="main-menu" tabindex="0">
        <span></span><span></span><span></span>
      </button>
    <% } %>
  </nav>

  <% if (user) { %>
    <div class="nav-fancy-overlay" id="nav-fancy-overlay"></div>
    <ul class="nav-menu" id="main-menu" role="menu" tabindex="-1">
        <li class="nav-sheet-handle" aria-hidden="true" role="presentation"></li>
        <li class="nav-sheet-section" aria-hidden="true" role="presentation">Navigation</li>

        <li role="none"><a role="menuitem" href="/dashboard"
          <% if (typeof path !== 'undefined' && path === '/dashboard') { %>class="active" aria-current="page"<% } %>
          tabindex="-1">
          <span class="nav-item-icon" style="background:#e6f4ec;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d8f55" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
          Dashboard
        </a></li>

        <% if (user.is_admin) { %>
          <li role="none"><a role="menuitem" href="/penalties"
            <% if (typeof path !== 'undefined' && path === '/penalties') { %>class="active" aria-current="page"<% } %>
            tabindex="-1">
            <span class="nav-item-icon" style="background:#f2eafa;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b4cc8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span>
            Strafen
          </a></li>
          <li role="none"><a role="menuitem" href="/spiess-board"
            <% if (typeof path !== 'undefined' && path === '/spiess-board') { %>class="active" aria-current="page"<% } %>
            tabindex="-1">
            <span class="nav-item-icon" style="background:#fdeaea;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c84c4c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            Spießboard
          </a></li>
        <% } %>

        <% if (user.is_admin || user.is_board) { %>
          <li role="none"><a role="menuitem" href="/users"
            <% if (typeof path !== 'undefined' && path === '/users') { %>class="active" aria-current="page"<% } %>
            tabindex="-1">
            <span class="nav-item-icon" style="background:#eaeffa;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b5bbf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
            Nutzer
          </a></li>
        <% } %>

        <% if (user.is_admin || (typeof canManageEquipment !== 'undefined' && canManageEquipment) || (typeof canAssignEquipment !== 'undefined' && canAssignEquipment)) { %>
          <li role="none"><a role="menuitem" href="/equipment"
            <% if (typeof path !== 'undefined' && path && path.indexOf('/equipment') === 0) { %>class="active" aria-current="page"<% } %>
            tabindex="-1">
            <span class="nav-item-icon" style="background:#e6f4ec;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d8f55" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></span>
            Zeugwart
          </a></li>
        <% } %>

        <% if (user.is_admin || (typeof canManageRoles !== 'undefined' && canManageRoles)) { %>
          <li role="none"><a role="menuitem" href="/roles"
            <% if (typeof path !== 'undefined' && path && path.indexOf('/roles') === 0) { %>class="active" aria-current="page"<% } %>
            tabindex="-1">
