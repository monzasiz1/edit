  </style>

  <script>
    (() => {
      const STORAGE_KEY = 'pwa_banner_dismissed';
      if (localStorage.getItem(STORAGE_KEY)) return;

      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
      const isAndroid = /android/i.test(navigator.userAgent);
      const isStandalone = window.matchMedia('(display-mode: standalone)').matches
                        || window.navigator.standalone === true;

      if (isStandalone) return; // Already installed

      const banner = document.getElementById('pwa-banner');
      const actionBtn = document.getElementById('pwa-banner-action');
      const closeBtn = document.getElementById('pwa-banner-close');
      const iosModal = document.getElementById('pwa-ios-modal');
      const modalClose = document.getElementById('pwa-modal-close');
      const backdrop = document.getElementById('pwa-modal-backdrop');

      function dismiss() {
        localStorage.setItem(STORAGE_KEY, '1');
        banner.style.animation = 'pwa-slide-up 0.3s reverse both';
        setTimeout(() => banner.style.display = 'none', 280);
      }

      closeBtn.addEventListener('click', dismiss);

      if (isIOS) {
        setTimeout(() => { banner.style.display = 'block'; }, 1800);
        actionBtn.addEventListener('click', () => {
          iosModal.style.display = 'flex';
        });
        function closeModal() {
          iosModal.style.display = 'none';
          dismiss();
        }
        modalClose.addEventListener('click', closeModal);
        backdrop.addEventListener('click', closeModal);

      } else if (isAndroid) {
        let deferredPrompt = null;
        window.addEventListener('beforeinstallprompt', e => {
          e.preventDefault();
          deferredPrompt = e;
          document.getElementById('pwa-banner-title').textContent = 'Spießbuch installieren';
          document.getElementById('pwa-banner-sub').textContent = 'Als App auf dem Home-Bildschirm speichern';
          actionBtn.textContent = 'Installieren';
          setTimeout(() => { banner.style.display = 'block'; }, 1800);
        });
        actionBtn.addEventListener('click', async () => {
          if (!deferredPrompt) return;
          deferredPrompt.prompt();
          const { outcome } = await deferredPrompt.userChoice;
          deferredPrompt = null;
          dismiss();
        });
        closeBtn.addEventListener('click', dismiss);
      }
    })();
  </script>
  <script src="/register-sw.js" defer></script>
