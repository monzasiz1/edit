  <script>
    (function() {
      var btn     = document.getElementById('hamburger-btn');
      var menu    = document.getElementById('main-menu');
      var overlay = document.getElementById('nav-fancy-overlay');
      if (!btn || !menu || !overlay) return;

      function openMenu() {
        menu.classList.add('open');
        btn.classList.add('open');
        overlay.style.display = 'block';
        btn.setAttribute('aria-expanded', 'true');
      }

      function closeMenu() {
        menu.classList.remove('open');
        btn.classList.remove('open');
        overlay.style.display = 'none';
        btn.setAttribute('aria-expanded', 'false');
      }

      btn.addEventListener('click', function(e) {
        e.stopImmediatePropagation();
        if (menu.classList.contains('open')) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      overlay.addEventListener('click', closeMenu);
      window.addEventListener('resize', closeMenu);

      /* Swipe-down zum Schließen */
      var touchStartY = 0;
      var touchStartScrollTop = 0;
      var swipeBlocked = false;
      menu.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchStartScrollTop = menu.scrollTop;
        swipeBlocked = false;
      }, { passive: true });
      menu.addEventListener('touchmove', function(e) {
        var dy = e.touches[0].clientY - touchStartY;
        /* Wenn nach unten gewischt UND Sheet ganz oben: Scroll der Seite verhindern */
        if (dy > 0 && touchStartScrollTop <= 0) {
          e.preventDefault();
          swipeBlocked = true;
        }
      }, { passive: false });
      menu.addEventListener('touchend', function(e) {
        var dy = e.changedTouches[0].clientY - touchStartY;
        if (dy > 60 && touchStartScrollTop <= 0) {
          closeMenu();
        }
      }, { passive: true });
    })();
  </script>

