<div class="music-view-page">
  <div class="music-view-header">
    <a href="/music" class="music-back-link">Zurück</a>
    <div class="music-view-title-wrap">
      <h1><%= piece.title %></h1>
      <% if (piece.composer) { %>
        <p><%= piece.composer %></p>
      <% } %>
    </div>
    <a href="<%= downloadUrl %>" class="music-btn music-btn-secondary music-view-download" download="<%= piece.original_name %>">Download</a>
  </div>

  <div class="music-view-actions">
    <% if (prevUrl) { %>
      <a href="<%= prevUrl %>" class="music-btn music-btn-outline">← Vorheriges</a>
    <% } else { %>
      <span class="music-btn music-btn-outline music-btn-disabled">← Vorheriges</span>
    <% } %>
    <% if (nextUrl) { %>
      <a href="<%= nextUrl %>" class="music-btn music-btn-outline">Nächstes →</a>
    <% } else { %>
      <span class="music-btn music-btn-outline music-btn-disabled">Nächstes →</span>
    <% } %>
  </div>

  <div class="music-view-frame">
    <iframe src="<%= contentUrl %>" class="music-view-iframe"></iframe>
  </div>
</div>

<style>
  .music-view-page {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: #0e1210;
    color: #fff;
    overflow: hidden;
  }

  .music-view-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(12px);
    z-index: 20;
  }

  .music-view-title-wrap h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .music-view-title-wrap p {
    margin: 0.25rem 0 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .music-view-download {
    white-space: nowrap;
  }

  .music-view-actions {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.45);
    z-index: 20;
  }

  .music-view-frame {
    position: absolute;
    top: 4.2rem;
    bottom: 3.75rem;
    left: 0;
    right: 0;
    background: #111;
  }

  .music-view-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .music-btn {
    padding: 0.75rem 1rem;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    min-width: 9rem;
    white-space: nowrap;
  }

  .music-btn-outline {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .music-btn-secondary {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  .music-btn-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .music-back-link {
    color: #9ec1ff;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .music-view-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }
    .music-view-actions {
      flex-wrap: wrap;
      justify-content: stretch;
    }
  }

  @media (max-width: 640px) {
    .music-view-actions {
      flex-direction: column;
      gap: 0.5rem;
    }
    .music-view-frame {
      top: 4.8rem;
      bottom: 5.6rem;
    }
  }
</style>
