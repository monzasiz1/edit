<div class="music-view-page">
  <div class="music-view-header">
    <a href="/music" class="music-back-link">Zurück</a>
    <div class="music-view-title-wrap">
      <h1><%= piece.title %></h1>
      <% if (piece.composer) { %>
        <p><%= piece.composer %></p>
      <% } %>
    </div>
    <a href="<%= downloadUrl %>" class="music-btn music-btn-secondary music-view-download" download="<%= piece.original_name %>">Download</a>
  </div>

  <div class="music-view-actions">
    <% if (prevUrl) { %>
      <a href="<%= prevUrl %>" class="music-btn music-btn-outline">← Vorheriges</a>
    <% } else { %>
      <span class="music-btn music-btn-outline music-btn-disabled">← Vorheriges</span>
    <% } %>
    <% if (nextUrl) { %>
      <a href="<%= nextUrl %>" class="music-btn music-btn-outline">Nächstes →</a>
    <% } else { %>
      <span class="music-btn music-btn-outline music-btn-disabled">Nächstes →</span>
    <% } %>
  </div>

  <div class="music-view-hotspot top" aria-hidden="true"></div>
  <div class="music-view-hotspot bottom" aria-hidden="true"></div>

  <div class="music-view-frame">
    <iframe src="<%= contentUrl %>" class="music-view-iframe" scrolling="no" allowfullscreen></iframe>
  </div>
</div>

<style>
  html, body {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0 !important;
    overflow: hidden !important;
    background: #020202;
    color: #fff;
    touch-action: auto;
  }

  body {
    position: fixed;
    inset: 0;
    font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .main-nav,
  .page-hero,
  .footer,
  .nav-menu,
  .nav-sheet,
  .nav-sheet-handle,
  .page-hero-clip {
    display: none !important;
  }

  .music-view-page {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: #000;
    color: #fff;
    overflow: hidden;
  }

  .music-view-header,
  .music-view-actions {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.95rem 1rem;
    background: rgba(6, 12, 24, 0.82);
    backdrop-filter: blur(24px);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .music-view-header.visible,
  .music-view-actions.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .music-view-header {
    top: 0;
    padding-top: calc(0.95rem + env(safe-area-inset-top, 0));
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
  }

  .music-view-actions {
    bottom: 0;
    padding-bottom: calc(0.95rem + env(safe-area-inset-bottom, 0));
  }

  .music-view-title-wrap {
    min-width: 0;
    padding: 0 0.35rem;
    justify-self: center;
    text-align: center;
  }

  .music-view-title-wrap h1 {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
    overflow-wrap: anywhere;
    letter-spacing: -0.02em;
    text-align: center;
    white-space: normal;
  }

  .music-view-title-wrap p {
    margin: 0.25rem 0 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.72);
    text-align: center;
  }

  .music-view-download,
  .music-view-actions .music-btn,
  .music-view-header a {
    white-space: nowrap;
  }

  .music-view-frame {
    position: absolute;
    inset: 0;
    background: #050608;
    overflow: hidden;
    touch-action: none;
  }

  .music-view-iframe {
    width: 100%;
    height: 100%;
    min-height: 100%;
    max-width: 100%;
    border: none;
    display: block;
    overflow: hidden;
  }

  .music-view-hotspot {
    position: absolute;
    left: 0;
    right: 0;
    height: 20vmin;
    z-index: 25;
    pointer-events: auto;
    cursor: pointer;
  }

  .music-view-hotspot.top { top: 0; }
  .music-view-hotspot.bottom { bottom: 0; }

  .music-view-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .music-btn {
    padding: 0.72rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    cursor: pointer;
    min-width: 7.5rem;
    white-space: nowrap;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease;
  }

  .music-btn:hover {
    transform: translateY(-1px);
  }

  .music-btn-outline {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .music-btn-secondary {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  .music-btn-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .music-back-link {
    color: #bbdefb;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: 0.68rem 0.95rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.05);
    transition: background 0.16s ease, border-color 0.16s ease;
  }

  .music-back-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.28);
  }

  @media (max-width: 900px) {
    .music-view-header,
    .music-view-actions {
      padding: 0.75rem 0.9rem;
    }
    .music-view-title-wrap h1 {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .music-view-header,
    .music-view-actions {
      padding: 0.8rem 0.75rem;
      gap: 0.65rem;
      border-radius: 0;
    }

    .music-view-header {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }

    .music-view-title-wrap h1 {
      font-size: 0.98rem;
      line-height: 1.2;
    }

    .music-view-actions {
      flex-direction: column;
      gap: 0.55rem;
      padding-left: 0.9rem;
      padding-right: 0.9rem;
    }

    .music-back-link,
    .music-btn {
      width: 100%;
      text-align: center;
    }

    .music-view-download {
      flex-shrink: 0;
      width: 100%;
    }
  }
</style>

<script>
  (function() {
    const header = document.querySelector('.music-view-header');
    const actions = document.querySelector('.music-view-actions');
    let hideTimer = null;

    function showControls() {
      header.classList.add('visible');
      actions.classList.add('visible');
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        header.classList.remove('visible');
        actions.classList.remove('visible');
      }, 2500);
    }

    function init() {
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      header.classList.remove('visible');
      actions.classList.remove('visible');

      const hotspots = document.querySelectorAll('.music-view-hotspot');
      hotspots.forEach((hotspot) => {
        hotspot.addEventListener('touchstart', (event) => {
          event.preventDefault();
          showControls();
        }, { passive: false });
        hotspot.addEventListener('click', showControls);
      });

      document.addEventListener('keydown', showControls);
      showControls();
    }

    window.addEventListener('load', init);
  })();
</script>
