<% layout('layout', { user: user, path: path, title: title }) -%>

<div class="page-hero page-hero--slim">
  <div class="page-hero-content">
    <h2 class="page-hero-title">Getränkerunden</h2>
    <p class="page-hero-desc">Hier kannst du Getränkerunden für den Verein aufnehmen.</p>
  </div>
</div>

<div class="main-content">
  <div class="block-group">
    <div class="block-row">
      <div class="block block-75">
        <div class="block-content">
          <h3>Getränke aufnehmen</h3>
          <div class="drink-selection">
            <% if (drinks && drinks.length > 0) { %>
              <div class="drink-list">
                <% drinks.forEach(function(drink) { %>
                  <button class="drink-item" data-id="<%= drink.id %>" data-name="<%= drink.name %>" data-price="<%= drink.price %>">
                    <%= drink.name %> (<%= drink.price.toFixed(2) %> €)
                  </button>
                <% }); %>
              </div>
            <% } else { %>
              <p>Keine Getränke verfügbar. Bitte fügen Sie zuerst Getränke hinzu.</p>
            <% } %>
          </div>
          <div class="beer-mat-container">
            <canvas id="beerMatCanvas"></canvas>
            <p class="instructions">Wische über den Bierdeckel, um Getränke aufzunehmen!</p>
          </div>
        </div>
      </div>
      <div class="block block-25">
        <div class="block-content">
          <h3>Aktuelle Runde</h3>
          <ul id="currentRoundList">
            <!-- Hier werden die ausgewählten Getränke angezeigt -->
          </ul>
          <p>Gesamt: <span id="currentRoundTotal">0.00</span> €</p>
          <button id="submitRoundBtn" class="btn btn-primary">Runde abschicken</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('beerMatCanvas');
    const ctx = canvas.getContext('2d');
    const drinkItems = document.querySelectorAll('.drink-item');
    const currentRoundList = document.getElementById('currentRoundList');
    const currentRoundTotal = document.getElementById('currentRoundTotal');
    const submitRoundBtn = document.getElementById('submitRoundBtn');

    let selectedDrink = null;
    let currentRound = {}; // { drinkId: count }

    // Canvas setup
    const resizeCanvas = () => {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
      drawBeerMat();
    };
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function drawBeerMat() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#f0e6c8'; // Beer mat color
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.strokeStyle = '#a09b8f';
      ctx.lineWidth = 2;
      ctx.strokeRect(0, 0, canvas.width, canvas.height);

      ctx.font = '20px Arial';
      ctx.fillStyle = '#333';
      ctx.textAlign = 'center';
      ctx.fillText('Bierdeckel', canvas.width / 2, canvas.height / 2);
    }

    // Drink selection
    drinkItems.forEach(item => {
      item.addEventListener('click', () => {
        drinkItems.forEach(btn => btn.classList.remove('active'));
        item.classList.add('active');
        selectedDrink = {
          id: item.dataset.id,
          name: item.dataset.name,
          price: parseFloat(item.dataset.price)
        };
      });
    });

    // Swipe gestures on canvas
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;

    function drawLine(x1, y1, x2, y2) {
      ctx.beginPath();
      ctx.strokeStyle = '#000';
      ctx.lineWidth = 5;
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
    }

    canvas.addEventListener('mousedown', (e) => {
      if (!selectedDrink) {
        alert('Bitte wähle zuerst ein Getränk aus!');
        return;
      }
      isDrawing = true;
      [lastX, lastY] = [e.offsetX, e.offsetY];
    });

    canvas.addEventListener('mousemove', (e) => {
      if (!isDrawing) return;
      drawLine(lastX, lastY, e.offsetX, e.offsetY);
      [lastX, lastY] = [e.offsetX, e.offsetY];
    });

    canvas.addEventListener('mouseup', () => {
      isDrawing = false;
      if (selectedDrink) {
        addDrinkToRound(selectedDrink.id);
      }
      drawBeerMat(); // Redraw beer mat to clear strokes
    });

    canvas.addEventListener('mouseout', () => {
      if (isDrawing) {
        isDrawing = false;
        if (selectedDrink) {
          addDrinkToRound(selectedDrink.id);
        }
        drawBeerMat();
      }
    });

    // Touch events for mobile
    canvas.addEventListener('touchstart', (e) => {
      if (!selectedDrink) {
        alert('Bitte wähle zuerst ein Getränk aus!');
        return;
      }
      isDrawing = true;
      const touch = e.touches[0];
      const rect = canvas.getBoundingClientRect();
      [lastX, lastY] = [touch.clientX - rect.left, touch.clientY - rect.top];
      e.preventDefault();
    });

    canvas.addEventListener('touchmove', (e) => {
      if (!isDrawing) return;
      const touch = e.touches[0];
      const rect = canvas.getBoundingClientRect();
      drawLine(lastX, lastY, touch.clientX - rect.left, touch.clientY - rect.top);
      [lastX, lastY] = [touch.clientX - rect.left, touch.clientY - rect.top];
      e.preventDefault();
    });

    canvas.addEventListener('touchend', () => {
      isDrawing = false;
      if (selectedDrink) {
        addDrinkToRound(selectedDrink.id);
      }
      drawBeerMat();
    });


    function addDrinkToRound(drinkId) {
      if (currentRound[drinkId]) {
        currentRound[drinkId]++;
      } else {
        currentRound[drinkId] = 1;
      }
      updateCurrentRoundDisplay();
    }

    function updateCurrentRoundDisplay() {
      currentRoundList.innerHTML = '';
      let total = 0;
      for (const drinkId in currentRound) {
        const count = currentRound[drinkId];
        const drink = drinks.find(d => d.id == drinkId); // Assuming 'drinks' is passed to the EJS view
        if (drink) {
          const li = document.createElement('li');
          li.textContent = `${drink.name} x ${count}`;
          currentRoundList.appendChild(li);
          total += drink.price * count;
        }
      }
      currentRoundTotal.textContent = total.toFixed(2);
    }

    submitRoundBtn.addEventListener('click', async () => {
      if (Object.keys(currentRound).length === 0) {
        alert('Bitte füge zuerst Getränke zur Runde hinzu!');
        return;
      }

      const drinkRoundsData = Object.keys(currentRound).map(drinkId => ({
        drink_id: parseInt(drinkId),
        quantity: currentRound[drinkId]
      }));

      try {
        const response = await fetch('/drinkrounds/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ rounds: drinkRoundsData })
        });

        if (response.ok) {
          alert('Getränkerunde erfolgreich gespeichert!');
          currentRound = {}; // Reset round
          updateCurrentRoundDisplay();
          drawBeerMat();
        } else {
          alert('Fehler beim Speichern der Getränkerunde.');
        }
      } catch (error) {
        console.error('Fehler beim Senden der Daten:', error);
        alert('Fehler beim Senden der Daten.');
      }
    });
  });
</script>

<style>
  .drink-selection {
    margin-bottom: 20px;
  }
  .drink-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .drink-item {
    padding: 10px 15px;
    border: 1px solid #ccc;
    border-radius: 5px;
    background-color: #f9f9f9;
    cursor: pointer;
    font-size: 1rem;
  }
  .drink-item.active {
    background-color: #aaddaa;
    border-color: #5cb85c;
    color: #fff;
  }
  .beer-mat-container {
    position: relative;
    width: 100%;
    padding-bottom: 75%; /* 4:3 Aspect Ratio */
    height: 0;
    background-color: #f0e6c8;
    border: 2px solid #a09b8f;
    box-sizing: border-box;
  }
  #beerMatCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    touch-action: none; /* Disable default touch actions */
  }
  .instructions {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #555;
    font-size: 1.2em;
    text-align: center;
    pointer-events: none;
  }
  #currentRoundList {
    list-style: none;
    padding: 0;
  }
  #currentRoundList li {
    margin-bottom: 5px;
  }
  #submitRoundBtn {
    margin-top: 15px;
    width: 100%;
  }
</style>
