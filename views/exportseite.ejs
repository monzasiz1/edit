<%- include('partials/page_hero', {
      kicker: 'Export',
      title: 'Exportfunktionen',
      subtitle: 'Lade deine Strafen als PDF oder CSV herunter.',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>',
      actions: [
        { href: '/dashboard', label: 'Zur\u00fcck', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
      ]
    }) %>

<div class="ex-wrap">

  <section class="ex-card">
    <header class="ex-card-head">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Meine Strafen</span>
    </header>
    <div class="ex-card-body">
      <p class="ex-desc">Exportiere deine persönlichen Strafen als PDF oder CSV.</p>
      <div class="ex-actions">
        <a href="/export/meine-pdf" class="ex-btn ex-btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          PDF herunterladen
        </a>
        <a href="/export/meine-csv" class="ex-btn ex-btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          CSV herunterladen
        </a>
      </div>
    </div>
  </section>

  <% if (user && user.is_admin) { %>
  <section class="ex-card ex-card-admin">
    <header class="ex-card-head">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
      <span>Admin · Alle Mitglieder</span>
    </header>
    <div class="ex-card-body">
      <p class="ex-desc">Exportiere alle Strafen aller Mitglieder als PDF oder CSV.</p>
      <div class="ex-actions">
        <a href="/export/alle-pdf" class="ex-btn ex-btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          PDF (Alle Mitglieder)
        </a>
        <a href="/export/alle-csv" class="ex-btn ex-btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          CSV (Alle Mitglieder)
        </a>
      </div>

      <div class="ex-divider"></div>

      <div class="ex-sub">
        <div class="ex-sub-title">Einzelne Mitglieder exportieren</div>
        <p class="ex-desc">Exportiere die Strafen eines bestimmten Mitglieds über die Nutzerverwaltung.</p>
        <a href="/users" class="ex-btn ex-btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Zur Nutzerverwaltung
        </a>
      </div>
    </div>
  </section>
  <% } %>
</div>

<style>
  html, body {
    background: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .ex-wrap {
    max-width: 560px;
    margin: 0 auto;
    padding: 0.4rem 1rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ex-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    overflow: hidden;
  }
  .ex-card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
  }
  .ex-card-head svg { color: #94a3b8; }

  .ex-card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ex-desc {
    margin: 0;
    font-size: 0.86rem;
    color: #64748b;
    line-height: 1.45;
  }

  .ex-actions {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .ex-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    flex: 1 1 200px;
    min-width: 0;
    padding: 0.7rem 1rem;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.08s;
  }
  .ex-btn:active { transform: scale(0.99); }

  .ex-btn-primary {
    background: #15803d;
    color: #fff;
    border: 1px solid #15803d;
  }
  .ex-btn-primary:hover { background: #166534; border-color: #166534; }

  .ex-btn-secondary {
    background: #fff;
    color: #0f172a;
    border: 1px solid #e2e8f0;
  }
  .ex-btn-secondary:hover { background: #f8fafc; border-color: #cbd5e1; }
  .ex-btn-secondary svg { color: #64748b; }

  .ex-divider {
    height: 1px;
    background: #f1f5f9;
    margin: 0.5rem 0;
  }

  .ex-sub-title {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 0.4rem;
  }
  .ex-sub { display: flex; flex-direction: column; gap: 0.6rem; }
  .ex-sub .ex-btn { flex: 0 0 auto; align-self: flex-start; }

  @media (max-width: 600px) {
    .ex-wrap { padding: 0.4rem 0.6rem 2.5rem; }
    .ex-card-body { padding: 0.85rem; }
    .ex-actions { flex-direction: column; }
    .ex-btn { flex: 1 1 auto; }
    .ex-sub .ex-btn { align-self: stretch; }
  }
</style>
