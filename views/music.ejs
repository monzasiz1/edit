<%- include('partials/page_hero', {
      kicker: 'Musikverein',
      title: 'Notenverwaltung',
      subtitle: 'Alphabethisch geordnete Stücke hochladen und herunterladen.',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l10-2v13"/><circle cx="19" cy="17" r="3"/></svg>',
      actions: [
        { href: '/dashboard', label: 'Zurück', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
      ]
    }) %>

<div class="music-page">
  <% if (messageSuccess) { %>
    <div class="message success"><%= messageSuccess %></div>
  <% } %>
  <% if (messageError) { %>
    <div class="message error"><%= messageError %></div>
  <% } %>

  <% if (showInstrumentHome) { %>
    <section class="music-home">
      <div class="music-home-intro">
        <h2>Notenübersicht</h2>
        <p>Wähle zuerst ein Instrument, dann kannst du Stimmen filtern und neue Stücke hochladen.</p>
      </div>
      <div class="music-home-grid">
        <a href="/music?instrument=Flöten" class="music-instrument-card">
          <span class="music-card-title">Flöten</span>
          <span class="music-card-subtitle">Für alle Flöten-Stücke</span>
          <span class="music-card-count"><%= instrumentCounts.Flöten || 0 %> Stücke</span>
        </a>
        <a href="/music?instrument=Trommeln" class="music-instrument-card">
          <span class="music-card-title">Trommeln</span>
          <span class="music-card-subtitle">Rhythmus und Schlagwerk</span>
          <span class="music-card-count"><%= instrumentCounts.Trommeln || 0 %> Stücke</span>
        </a>
        <a href="/music?instrument=Lyra" class="music-instrument-card">
          <span class="music-card-title">Lyra</span>
          <span class="music-card-subtitle">Saiten und Melodie</span>
          <span class="music-card-count"><%= instrumentCounts.Lyra || 0 %> Stücke</span>
        </a>
        <a href="/music?instrument=Andere" class="music-instrument-card">
          <span class="music-card-title">Andere</span>
          <span class="music-card-subtitle">Alle weiteren Instrumente</span>
          <span class="music-card-count"><%= instrumentCounts.Andere || 0 %> Stücke</span>
        </a>
      </div>
      <div class="music-home-summary">
        <span class="music-badge"><%= instrumentCounts.all || 0 %> Stücke insgesamt</span>
      </div>
    </section>
  <% } else { %>
    <section class="music-grid">
      <article class="music-panel music-panel--upload">
        <div class="music-panel-head compact">
          <div>
            <h2>Stück hochladen</h2>
            <p>Für <strong><%= selectedInstrument %></strong> hochladen und Stimmen ergänzen.</p>
          </div>
          <a href="/music" class="music-back-link">Zurück zur Instrumentenübersicht</a>
        </div>

        <details class="music-upload-panel">
          <summary>Upload-Formular anzeigen / verbergen</summary>
          <form action="/music/upload" method="POST" enctype="multipart/form-data" class="music-form">
            <input type="hidden" name="instrument" value="<%= selectedInstrument %>" />
            <label>
              <span>Titel</span>
              <input type="text" name="title" placeholder="Beispiel: Marsch der Kameradschaft" required />
            </label>
            <label>
              <span>Stimme / Besetzung</span>
              <% const hasFixedParts = (availableParts || []).filter(part => part && part.trim()).length > 0; %>
              <% if (hasFixedParts) { %>
                <select name="part">
                  <option value=""><%= 'Wähle eine Stimme oder Besetzung' %></option>
                  <% availableParts.forEach(part => { if (part && part.trim()) { %>
                    <option value="<%= part %>"><%= part %></option>
                  <% } }); %>
                </select>
              <% } else { %>
                <input type="text" name="part" placeholder="Beispiel: Sopran 1, Altflöte, Bass" />
              <% } %>
            </label>
            <label>
              <span>Komponist / Arrangeur</span>
              <input type="text" name="composer" placeholder="Beispiel: Max Mustermann" />
            </label>
            <label>
              <span>Beschreibung</span>
              <textarea name="description" rows="3" placeholder="Kurzbeschreibung oder Besetzung"></textarea>
            </label>
            <label class="file-upload-label">
              <span>Datei wählen</span>
              <input type="file" name="scoreFile" accept=".pdf,image/*,audio/*" required />
            </label>
            <button type="submit" class="music-btn music-btn-primary">Hochladen</button>
          </form>

          <% if (user.is_admin) { %>
            <div class="music-admin-cta">
              <a href="/music/admin" class="music-btn music-btn-secondary">Admin-Bereich öffnen</a>
            </div>
          <% } %>
        </details>

      <article class="music-panel music-panel--list">
        <div class="music-panel-head">
          <div>
            <h2><%= selectedInstrument %></h2>
            <p>Wähle eine Stimme, um die Liste zu filtern. Klick auf den Titel zum Öffnen.</p>
          </div>
          <span class="music-badge"><%= pieces.length %> Stück<%= pieces.length === 1 ? '' : 'e' %></span>
        </div>

        <div class="music-filters">
          <form action="/music" method="GET" class="music-search-form">
            <input type="hidden" name="instrument" value="<%= selectedInstrument %>" />
            <% if (selectedPart) { %>
              <input type="hidden" name="part" value="<%= selectedPart %>" />
            <% } %>
            <label class="music-search-label">
              <span>Stück suchen</span>
              <input type="search" name="search" value="<%= selectedSearch || '' %>" placeholder="Suche nach Titel" />
            </label>
            <button type="submit" class="music-btn music-btn-outline">Suchen</button>
          </form>

          <% if (showPartTabs) { %>
            <div class="music-filter-tabs">
              <% const parts = availableParts || ['']; %>
              <% parts.forEach(part => { %>
                <a href="/music?instrument=<%= encodeURIComponent(selectedInstrument) %>&part=<%= encodeURIComponent(part) %>"
                   class="music-tab <%= selectedPart === part ? 'active' : '' %>">
                  <%= part === '' ? 'Alle Stimmen' : part %>
                </a>
              <% }); %>
            </div>
          <% } else { %>
            <div class="music-filter-note">Keine Stimmenfilter für dieses Instrument.</div>
          <% } %>
        </div>

        <div class="music-list">
          <% if (pieces.length === 0) { %>
            <div class="music-empty">Für diese Auswahl sind noch keine Stücke eingetragen.</div>
          <% } else { %>
            <% pieces.forEach(piece => { %>
              <article class="music-item">
                <div class="music-item-main">
                  <div class="music-item-title-group">
                    <strong>
                      <a class="music-item-link" href="/music/file/<%= piece.id %>" target="_blank" rel="noopener">
                        <%= piece.title %>
                      </a>
                    </strong>
                    <div class="music-item-subtitle">
                      <span><%= piece.composer || 'Unbekannt' %></span>
                      <% if (piece.part) { %><span class="music-chip music-chip--secondary"><%= piece.part %></span><% } %>
                    </div>
                  </div>
                </div>
                <div class="music-item-description"><%= piece.description || 'Keine Beschreibung' %></div>
                <div class="music-item-footer">
                  <div class="music-item-meta">
                    <span>von <strong><%= piece.uploaded_by_name || 'Unbekannt' %></strong></span>
                  </div>
                  <div class="music-item-actions">
                    <a class="music-link" href="/music/view/<%= piece.id %>?instrument=<%= encodeURIComponent(selectedInstrument) %>&part=<%= encodeURIComponent(selectedPart) %>" target="_blank" rel="noopener">Öffnen</a>
                    <a class="music-link music-link--secondary" href="/music/file/<%= piece.id %>" download="<%= piece.original_name %>">Download</a>
                    <% if (user && (user.is_admin || piece.uploaded_by === user.id)) { %>
                      <a class="music-link music-link--tertiary" href="/music/edit/<%= piece.id %>">Bearbeiten</a>
                      <form action="/music/delete/<%= piece.id %>" method="POST" class="music-link-form" onsubmit="return confirm('Stück wirklich löschen?');">
                        <button type="submit" class="music-link music-link--danger">Löschen</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              </article>
            <% }) %>
          <% } %>
        </div>
      </article>
    </section>
  <% } %>
</div>

<style>
  .music-page {
    padding: 0.75rem 0.75rem 1.2rem;
    max-width: 1080px;
    margin: 0 auto;
    background: #f1f6f8;
  }

  .music-home {
    display: grid;
    gap: 0.75rem;
  }
  .music-home-intro {
    background: #ffffff;
    border-radius: 20px;
    padding: 1.05rem 0.95rem;
    box-shadow: 0 18px 44px rgba(25, 73, 104, 0.08);
    border: 1px solid rgba(92, 156, 197, 0.14);
  }
  .music-home-intro h2 {
    margin: 0 0 0.3rem;
    font-size: 1.45rem;
    letter-spacing: -0.03em;
    color: #0f3d57;
  }
  .music-home-intro p {
    margin: 0;
    color: #4c6978;
    line-height: 1.7;
  }

  .music-home-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }
  .music-instrument-card {
    display: grid;
    gap: 0.55rem;
    padding: 1.4rem;
    border-radius: 26px;
    background: linear-gradient(180deg, #f6fbfd 0%, #ffffff 100%);
    border: 1px solid rgba(105, 161, 206, 0.18);
    box-shadow: 0 18px 44px rgba(31, 67, 96, 0.09);
    text-decoration: none;
    color: #0e3445;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .music-instrument-card:hover {
    transform: translateY(-5px);
    border-color: rgba(13, 87, 140, 0.3);
    box-shadow: 0 22px 54px rgba(31, 67, 96, 0.16);
  }
  .music-card-title {
    font-size: 1.18rem;
    font-weight: 800;
    color: #0c3140;
  }
  .music-card-subtitle {
    color: #3f6577;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .music-card-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    background: rgba(12, 88, 149, 0.16);
    color: #0f4b7c;
    font-size: 0.9rem;
    font-weight: 700;
    margin-top: 0.35rem;
    box-shadow: inset 0 1px 3px rgba(12, 88, 149, 0.12);
  }
  .music-instrument-card::before {
    content: '';
    display: block;
    height: 6px;
    width: 56px;
    border-radius: 999px;
    background: linear-gradient(90deg, #1d79b8, #6ac5ff);
  }

  .music-home-summary {
    display: flex;
    justify-content: flex-end;
  }

  .message {
    border-radius: 16px;
    padding: 0.95rem 1rem;
    margin: 0 0 1.2rem;
    font-weight: 600;
    line-height: 1.45;
  }
  .message.success { background: #e7f8f1; color: #105c45; border: 1px solid #c8f1e1; }
  .message.error { background: #ffe9e9; color: #9e2c2c; border: 1px solid #f1c7c7; }

  .music-grid {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    gap: 1.25rem;
  }

  .music-panel {
    background: #ffffff;
    border: 1px solid rgba(20, 56, 35, 0.1);
    border-radius: 22px;
    box-shadow: 0 16px 38px rgba(15, 35, 25, 0.08);
    overflow: hidden;
  }
  .music-panel--upload,
  .music-panel--list {
    padding: 1.35rem;
  }

  .music-panel h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.18rem, 2vw, 1.32rem);
    letter-spacing: -0.03em;
    color: #1f3e34;
  }
  .music-panel p {
    margin: 0 0 1.1rem;
    color: #546d64;
    line-height: 1.6;
  }

  .music-form {
    display: grid;
    gap: 0.95rem;
  }
  .music-form,
  .music-form * {
    box-sizing: border-box;
  }
  .music-form label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: #385147;
  }
  .music-upload-panel {
    display: grid;
    gap: 1rem;
    border-top: 1px solid rgba(20, 56, 35, 0.08);
    margin-top: 1rem;
    padding-top: 1rem;
  }
  .music-upload-panel summary {
    cursor: pointer;
    font-weight: 700;
    color: #1f3e34;
    list-style: none;
    margin-bottom: 0.35rem;
  }
  .music-upload-panel summary::-webkit-details-marker {
    display: none;
  }
  .music-upload-panel summary::before {
    content: '▶';
    display: inline-block;
    margin-right: 0.5rem;
    transform: rotate(0deg);
    transition: transform 0.2s ease;
  }
  .music-upload-panel[open] summary::before {
    transform: rotate(90deg);
  }
  .music-search-form {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .music-search-label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: #385147;
  }
  .music-search-form input[type="search"] {
    width: 100%;
    border: 1px solid #dbe5db;
    border-radius: 14px;
    padding: 0.88rem 1rem;
    font: inherit;
    background: #f6faf6;
    color: #1d342b;
  }
  .music-btn-outline {
    width: fit-content;
    padding: 0.85rem 1rem;
    border: 1px solid #1f593f;
    background: transparent;
    color: #1f593f;
  }
  .music-filter-note {
    color: #3b5f72;
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: 16px;
    background: #f5f8f8;
    border: 1px solid rgba(31, 89, 63, 0.08);
  }
  .music-form select,
  .music-form input,
  .music-form textarea {
    width: 100%;
    border: 1px solid #dbe5db;
    border-radius: 14px;
    padding: 0.88rem 1rem;
    font: inherit;
    background: #f6faf6;
    color: #1d342b;
  }
  .music-form textarea { resize: vertical; min-height: 88px; }

  .file-upload-label span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px dashed #c3dcc8;
    border-radius: 14px;
    color: #355748;
    background: rgba(236, 251, 242, 0.8);
    cursor: pointer;
  }

  .music-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 100%;
    padding: 0.92rem 1rem;
    border-radius: 14px;
    border: none;
    background: #1f593f;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.16s ease, background 0.16s ease;
  }
  .music-btn:hover { background: #184c36; transform: translateY(-1px); }

  .music-panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .music-panel-head.compact {
    align-items: flex-start;
    gap: 0.75rem;
  }

  .music-back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(34, 51, 47, 0.12);
    background: #f6fbf7;
    color: #203c33;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    min-width: 180px;
  }
  .music-back-link:hover {
    background: #e9f3ee;
  }

  .music-admin-password-panel {
    margin-top: 1.4rem;
    padding: 1.2rem;
    border-radius: 18px;
    background: #f5f9f2;
    border: 1px solid rgba(49, 105, 77, 0.12);
  }
  .music-admin-password-panel h3 {
    margin: 0 0 0.85rem;
    color: #173926;
    font-size: 0.99rem;
  }

  .music-filters {
    display: grid;
    gap: 0.65rem;
    margin-bottom: 0.8rem;
  }
  .music-filter-group,
  .music-filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    overflow-x: auto;
    padding-bottom: 0.15rem;
  }
  .music-filter-group::-webkit-scrollbar,
  .music-filter-tabs::-webkit-scrollbar { display: none; }

  .music-filter-pill,
  .music-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    color: #344c41;
    background: #f4fbf8;
    border: 1px solid rgba(31, 89, 63, 0.16);
    transition: background 0.18s, color 0.18s, transform 0.15s;
    white-space: nowrap;
    font-size: 0.82rem;
  }
  .music-filter-pill:hover,
  .music-tab:hover { transform: translateY(-1px); }
  .music-filter-pill.active,
  .music-tab.active {
    background: #185540;
    color: #ffffff;
    border-color: transparent;
    box-shadow: 0 6px 16px rgba(24, 85, 64, 0.14);
  }

  .music-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: #e4f0ff;
    color: #0f4d8a;
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
  }

  .music-list {
    display: grid;
    gap: 0.55rem;
  }

  .music-item {
    padding: 0.78rem;
    border: 1px solid rgba(15, 77, 139, 0.08);
    border-radius: 1rem;
    background: #ffffff;
    box-shadow: 0 8px 18px rgba(15, 35, 25, 0.04);
  }
  .music-item-main {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.55rem;
  }
  .music-item-title-group {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }
  .music-item-main strong {
    display: block;
    font-size: 0.98rem;
    color: #121a1a;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .music-item-subtitle {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    color: #55696b;
    font-size: 0.82rem;
  }
  .music-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .music-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background: #eef6ed;
    color: #21583d;
    font-size: 0.8rem;
  }
  .music-chip--secondary {
    background: #eef3fc;
    color: #26405a;
  }
  .music-download,
  .music-edit,
  .music-delete-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.75rem;
    border-radius: 12px;
    color: #1f3e34;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    border: 1px solid rgba(15, 77, 139, 0.12);
    background: #f5fbff;
    transition: background 0.12s ease, transform 0.12s ease;
    font-size: 0.82rem;
    min-width: max-content;
  }
  .music-download:hover,
  .music-edit:hover { background: #d7ebff; }

  .music-delete-btn {
    border-color: rgba(220, 38, 38, 0.18);
    background: #fff2f2;
    color: #991b1b;
  }

  .music-delete-btn:hover { background: #fee2e2; }

  .music-edit {
    margin-left: 0.5rem;
  }

  .music-delete-form {
    display: inline-block;
    margin-left: 0.5rem;
  }

  .music-delete-btn {
    border-color: rgba(220, 38, 38, 0.22);
    background: #fff1f1;
    color: #b91c1c;
  }

  .music-delete-btn:hover {
    background: #fee2e2;
  }

  .music-item-description {
    margin: 0.3rem 0 0.6rem;
    color: #5c6f71;
    font-size: 0.8rem;
    line-height: 1.35;
    min-height: 1.9rem;
  }

  .music-item-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    align-items: center;
  }

  .music-item-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .music-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    color: #5f6d60;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .music-item-meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .music-item-link {
    color: #0f3e34;
    text-decoration: none;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .music-item-link:hover {
    color: #14523d;
    transform: translateX(2px);
    text-decoration: none;
  }

  .music-link,
  .music-link button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 77, 139, 0.12);
    background: #f8fcf8;
    color: #14523d;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.12s ease, transform 0.12s ease;
    min-width: max-content;
  }

  .music-link:hover,
  .music-link button:hover {
    background: #e9f7e9;
  }

  .music-link--secondary,
  .music-link--secondary button {
    background: #eef4ff;
    border-color: rgba(17, 56, 107, 0.14);
    color: #144070;
  }

  .music-link--secondary:hover,
  .music-link--secondary button:hover {
    background: #dfe8ff;
  }

  .music-link--tertiary,
