<%- include('partials/page_hero', {
      kicker: 'Musikverein',
      title: 'Notenverwaltung',
      subtitle: 'Alphabethisch geordnete Stücke hochladen und herunterladen.',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l10-2v13"/><circle cx="19" cy="17" r="3"/></svg>',
      actions: [
        { href: '/dashboard', label: 'Zurück', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
      ]
    }) %>

<div class="music-page">
  <% if (messageSuccess) { %>
    <div class="message success"><%= messageSuccess %></div>
  <% } %>
  <% if (messageError) { %>
    <div class="message error"><%= messageError %></div>
  <% } %>

  <section class="music-grid">
    <article class="music-panel music-panel--upload">
      <h2>Stück hochladen</h2>
      <p>Füge neue Noten oder Audio-Dateien hinzu. Titel ist Pflicht, der Rest optional.</p>
      <form action="/music/upload" method="POST" enctype="multipart/form-data" class="music-form">
        <label>
          <span>Titel</span>
          <input type="text" name="title" placeholder="Beispiel: Marsch der Kameradschaft" required />
        </label>
        <label>
          <span>Instrument</span>
          <select name="instrument" required>
            <option value="">Instrument wählen</option>
            <option value="Flöten">Flöten</option>
            <option value="Trommeln">Trommeln</option>
            <option value="Lyra">Lyra</option>
            <option value="Andere">Andere</option>
          </select>
        </label>
        <label>
          <span>Stimme / Besetzung</span>
          <input type="text" name="part" placeholder="Beispiel: Sopran 1, Altflöte, Bass" />
        </label>
        <label>
          <span>Komponist / Arrangeur</span>
          <input type="text" name="composer" placeholder="Beispiel: Max Mustermann" />
        </label>
        <label>
          <span>Beschreibung</span>
          <textarea name="description" rows="3" placeholder="Kurzbeschreibung oder Besetzung"></textarea>
        </label>
        <label class="file-upload-label">
          <span>Datei wählen</span>
          <input type="file" name="scoreFile" accept=".pdf,image/*,audio/*" required />
        </label>
        <button type="submit" class="music-btn music-btn-primary">Stück hochladen</button>
      </form>

      <% if (user.is_admin) { %>
      <div class="music-admin-password-panel">
        <h3>Passwort für Notenbereich setzen</h3>
        <form action="/music/password" method="POST" class="music-form">
          <label>
            <span>Neues Passwort</span>
            <input type="password" name="newPassword" placeholder="Neues Passwort eingeben" required />
          </label>
          <button type="submit" class="music-btn music-btn-secondary">Passwort speichern</button>
        </form>
      </div>
      <% } %>
    </article>

    <article class="music-panel music-panel--list">
      <div class="music-panel-head">
        <div>
          <h2>Hochgeladene Stücke</h2>
          <p>Nach Instrumenten und Stimmen filtern oder neue Stücke eintragen.</p>
        </div>
        <span class="music-badge"><%= pieces.length %> Stück<%= pieces.length === 1 ? '' : 'e' %></span>
      </div>

      <div class="music-filters">
        <div class="music-filter-group">
          <% const instruments = ['Alle Instrumente', 'Flöten', 'Trommeln', 'Lyra']; %>
          <% instruments.forEach(inst => { %>
            <% const value = inst === 'Alle Instrumente' ? '' : inst; %>
            <a href="/music?<%= selectedPart ? 'part=' + encodeURIComponent(selectedPart) + '&' : '' %>instrument=<%= encodeURIComponent(value) %>"
               class="music-filter-pill <%= selectedInstrument === value ? 'active' : '' %>">
              <%= inst %>
            </a>
          <% }); %>
        </div>
        <div class="music-filter-tabs">
          <% const parts = ['', 'Sopran 1', 'Sopran 2', 'Sopran 3', 'Altflöte', 'Tenor', 'Bass']; %>
          <% parts.forEach(part => { %>
            <a href="/music?<%= selectedInstrument ? 'instrument=' + encodeURIComponent(selectedInstrument) + '&' : '' %>part=<%= encodeURIComponent(part) %>"
               class="music-tab <%= selectedPart === part ? 'active' : '' %>">
              <%= part === '' ? 'Alle Stimmen' : part %>
            </a>
          <% }); %>
        </div>
      </div>

      <div class="music-list">
        <% if (pieces.length === 0) { %>
          <div class="music-empty">Noch keine Stücke vorhanden. Lade jetzt dein erstes Stück hoch.</div>
        <% } else { %>
          <% pieces.forEach(piece => { %>
            <article class="music-item">
              <div class="music-item-main">
                <div class="music-item-title-group">
                  <strong><%= piece.title %></strong>
                  <div class="music-item-subtitle">
                    <span><%= piece.composer || 'Unbekannt' %></span>
                    <% if (piece.instrument || piece.part) { %>
                      <span class="music-tag-row">
                        <% if (piece.instrument) { %><span class="music-chip"><%= piece.instrument %></span><% } %>
                        <% if (piece.part) { %><span class="music-chip music-chip--secondary"><%= piece.part %></span><% } %>
                      </span>
                    <% } %>
                  </div>
                </div>
                <a class="music-download" href="<%= piece.filename %>" download="<%= piece.original_name %>">Download</a>
              </div>
              <div class="music-item-meta">
                <span><%= piece.description || 'Keine Beschreibung' %></span>
                <span>von <strong><%= piece.uploaded_by_name || 'Unbekannt' %></strong></span>
              </div>
            </article>
          <% }) %>
        <% } %>
      </div>
    </article>
  </section>
</div>

<style>
  .music-page {
    padding: 0 0.85rem 2rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  .message {
    border-radius: 16px;
    padding: 0.95rem 1rem;
    margin: 0 0 1.2rem;
    font-weight: 600;
    line-height: 1.45;
  }
  .message.success { background: #e7f8f1; color: #105c45; border: 1px solid #c8f1e1; }
  .message.error { background: #ffe9e9; color: #9e2c2c; border: 1px solid #f1c7c7; }

  .music-grid {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    gap: 1.25rem;
  }

  .music-panel {
    background: #ffffff;
    border: 1px solid rgba(20, 56, 35, 0.1);
    border-radius: 22px;
    box-shadow: 0 16px 38px rgba(15, 35, 25, 0.08);
    overflow: hidden;
  }
  .music-panel--upload,
  .music-panel--list {
    padding: 1.35rem;
  }

  .music-panel h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.18rem, 2vw, 1.32rem);
    letter-spacing: -0.03em;
    color: #1f3e34;
  }
  .music-panel p {
    margin: 0 0 1.1rem;
    color: #546d64;
    line-height: 1.6;
  }

  .music-form {
    display: grid;
    gap: 0.95rem;
  }
  .music-form label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: #385147;
  }
  .music-form select,
  .music-form input,
  .music-form textarea {
    width: 100%;
    border: 1px solid #dbe5db;
    border-radius: 14px;
    padding: 0.88rem 1rem;
    font: inherit;
    background: #f6faf6;
    color: #1d342b;
  }
  .music-form textarea { resize: vertical; min-height: 88px; }

  .file-upload-label span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px dashed #c3dcc8;
    border-radius: 14px;
    color: #355748;
    background: rgba(236, 251, 242, 0.8);
    cursor: pointer;
  }

  .music-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.92rem 1rem;
    border-radius: 14px;
    border: none;
    background: #1f593f;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.16s ease, background 0.16s ease;
  }
  .music-btn:hover { background: #184c36; transform: translateY(-1px); }

  .music-panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .music-admin-password-panel {
    margin-top: 1.4rem;
    padding: 1.2rem;
    border-radius: 18px;
    background: #f5f9f2;
    border: 1px solid rgba(49, 105, 77, 0.12);
  }
  .music-admin-password-panel h3 {
    margin: 0 0 0.85rem;
    color: #173926;
    font-size: 0.99rem;
  }

  .music-filters {
    display: grid;
    gap: 0.9rem;
    margin-bottom: 1rem;
  }
  .music-filter-group,
  .music-filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    overflow-x: auto;
    padding-bottom: 0.15rem;
  }
  .music-filter-group::-webkit-scrollbar,
  .music-filter-tabs::-webkit-scrollbar { display: none; }

  .music-filter-pill,
  .music-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.62rem 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    color: #324a3f;
    background: #edf6ee;
    border: 1px solid rgba(76, 122, 92, 0.14);
    transition: background 0.16s, color 0.16s, transform 0.15s;
    white-space: nowrap;
  }
  .music-filter-pill:hover,
  .music-tab:hover { transform: translateY(-1px); }
  .music-filter-pill.active,
  .music-tab.active {
    background: #1f593f;
    color: #ffffff;
    border-color: transparent;
  }

  .music-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.4rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: #eaf4ff;
    color: #0f4e7f;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .music-list {
    display: grid;
    gap: 0.95rem;
  }

  .music-item {
    padding: 0.95rem 0.95rem 0.85rem;
    border: 1px solid #dfe7e1;
    border-radius: 18px;
    background: #fbfcfb;
  }
  .music-item-main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.95rem;
    margin-bottom: 0.75rem;
  }
  .music-item-title-group {
    display: grid;
    gap: 0.3rem;
  }
  .music-item-main strong {
    display: block;
    font-size: 1rem;
    color: #14291f;
  }
  .music-item-subtitle {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    color: #4f6558;
    font-size: 0.88rem;
  }
  .music-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .music-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background: #eef6ed;
    color: #21583d;
    font-size: 0.8rem;
  }
  .music-chip--secondary {
    background: #eef3fc;
    color: #26405a;
  }
  .music-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.9rem;
    border-radius: 14px;
    background: #eef6ff;
    color: #0f4d8a;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(15, 77, 139, 0.16);
    white-space: nowrap;
  }
  .music-download:hover { background: #d9e9ff; }

  .music-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    color: #5f6d60;
    font-size: 0.88rem;
  }

  .music-empty {
    padding: 1.6rem;
    border: 1px dashed rgba(15, 77, 139, 0.2);
    border-radius: 18px;
    color: #42575e;
    background: rgba(240, 249, 255, 0.82);
    text-align: center;
  }

  @media (max-width: 940px) {
    .music-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 780px) {
    .music-panel--upload,
    .music-panel--list { padding: 1.1rem; }
  }

  @media (max-width: 620px) {
    .music-page { padding: 0 0.75rem 1.6rem; }
    .music-panel { border-radius: 18px; }
    .music-item-main { flex-direction: column; align-items: stretch; }
    .music-download { width: 100%; justify-content: center; }
  }
</style>
