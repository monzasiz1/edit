<style>
  .dra-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .dra-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .dra-head h1 {
    margin: 0;
    font-size: 1.3rem;
    color: #1f4a30;
  }
  .dra-back {
    font-size: 0.85rem;
    color: #2d8f55;
    text-decoration: none;
    font-weight: 700;
  }
  .dra-back:hover { text-decoration: underline; }
  .dra-summary {
    background: #eef6ea;
    border: 1.4px solid #cfe0c4;
    border-radius: 1rem;
    padding: 0.9rem 1.1rem;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.92rem;
    color: #1f4a30;
  }
  .dra-summary strong { font-size: 1.05rem; }
  .dra-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .dra-card {
    background: #fafcf9;
    border: 1.4px solid #dbe6d2;
    border-radius: 1.1rem;
    padding: 0.9rem 1.1rem;
  }
  .dra-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    margin-bottom: 0.5rem;
  }
  .dra-card-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
  }
  .dra-user {
    font-weight: 800;
    color: #1f4a30;
  }
  .dra-date {
    font-size: 0.8rem;
    color: #6f8678;
  }
  .dra-total {
    font-weight: 800;
    color: #2d8f55;
  }
  .dra-card-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .dra-delete-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 0.6em;
    background: #fdecec;
    color: #c0282a;
    cursor: pointer;
    padding: 0;
    transition: background 0.15s, opacity 0.15s;
  }
  .dra-delete-btn:hover:not(:disabled) { background: #fadbdb; }
  .dra-delete-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .dra-delete-btn svg { width: 15px; height: 15px; }
  .dra-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .dra-item {
    background: #fff;
    border: 1px solid #e2ebd9;
    border-radius: 0.7em;
    padding: 0.3em 0.7em;
    font-size: 0.85rem;
    color: #2a3e32;
  }
  .dra-empty {
    text-align: center;
    color: #8a9485;
    font-style: italic;
    padding: 2rem 1rem;
  }
  #dra-msg {
    margin-top: 0.2rem;
    font-size: 0.85rem;
    text-align: center;
  }
  #dra-msg.dr-ok { color: #2d8f55; }
  #dra-msg.dr-err { color: #c0282a; }
</style>

<div class="dra-wrap">
  <div class="dra-head">
    <h1>📚 Bierdeckel-Archiv</h1>
    <a class="dra-back" href="/drinkrounds">← Zurück zur Getränkerunde</a>
  </div>

  <%
    var grandTotal = 0;
    batches.forEach(function (b) { grandTotal += parseFloat(b.total); });
  %>

  <div class="dra-summary">
    <div>Gespeicherte Runden: <strong id="dra-count"><%= batches.length %></strong></div>
    <div>Gesamtsumme: <strong id="dra-grandtotal">€<%= grandTotal.toFixed(2) %></strong></div>
  </div>

  <div id="dra-msg"></div>

  <ul class="dra-list" id="dra-list">
    <% if (batches.length === 0) { %>
      <li class="dra-empty" id="dra-empty-item">Noch keine Runden gespeichert.</li>
    <% } else { %>
      <% batches.forEach(function (b) { %>
        <li class="dra-card" data-id="<%= b.id %>" data-total="<%= parseFloat(b.total) %>">
          <div class="dra-card-head">
            <div class="dra-card-meta">
              <span class="dra-user"><%= b.full_name || b.username || 'Unbekannt' %></span>
              <span class="dra-date"><%= new Date(b.created_at).toLocaleString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
            <div class="dra-card-actions">
              <span class="dra-total">€<%= parseFloat(b.total).toFixed(2) %></span>
              <button type="button" class="dra-delete-btn" aria-label="Löschen" title="Bierdeckel löschen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="5" rx="1"/><path d="M4 9v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9"/><line x1="10" y1="13" x2="14" y2="13"/></svg>
              </button>
            </div>
          </div>
          <div class="dra-items">
            <% b.items.forEach(function (it) { %>
              <span class="dra-item"><%= it.quantity %> &times; <%= it.name %></span>
            <% }); %>
          </div>
        </li>
      <% }); %>
    <% } %>
  </ul>
</div>

<script>
(function () {
  var listEl = document.getElementById('dra-list');
  var countEl = document.getElementById('dra-count');
  var grandTotalEl = document.getElementById('dra-grandtotal');
  var msgEl = document.getElementById('dra-msg');

  function showMsg(text, ok) {
    msgEl.textContent = text;
    msgEl.className = ok ? 'dr-ok' : 'dr-err';
  }

  function recalcSummary() {
    var cards = listEl.querySelectorAll('.dra-card');
    var total = 0;
    cards.forEach(function (c) { total += parseFloat(c.dataset.total) || 0; });
    countEl.textContent = cards.length;
    grandTotalEl.textContent = '€' + total.toFixed(2);

    if (cards.length === 0 && !document.getElementById('dra-empty-item')) {
      var empty = document.createElement('li');
      empty.className = 'dra-empty';
      empty.id = 'dra-empty-item';
      empty.textContent = 'Noch keine Runden gespeichert.';
      listEl.appendChild(empty);
    }
  }

  listEl.addEventListener('click', function (e) {
    var btn = e.target.closest('.dra-delete-btn');
    if (!btn) return;

    var card = btn.closest('.dra-card');
    var id = card.dataset.id;

    if (!confirm('Diesen Bierdeckel wirklich unwiderruflich löschen?')) return;

    btn.disabled = true;
    msgEl.textContent = '';
    msgEl.className = '';

    fetch('/drinkrounds/archive/' + id, { method: 'DELETE' })
      .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
      .then(function (result) {
        if (result.ok) {
          card.remove();
          recalcSummary();
          showMsg('Bierdeckel gelöscht.', true);
        } else {
          btn.disabled = false;
          showMsg(result.data.error || 'Fehler beim Löschen.', false);
        }
      })
      .catch(function () {
        btn.disabled = false;
        showMsg('Netzwerkfehler beim Löschen.', false);
      });
  });
})();
</script>
