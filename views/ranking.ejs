
<style>
  :root {
    --apple-green: #4CAF50;
    --apple-green-light: #8BC34A;
    --apple-green-lighter: #AED581;
    --apple-bg: #ffffff;
    --glass: rgba(255,255,255,0.85);
    --shadow-card: 0 12px 42px 0 #B9C9B244, 0 2px 14px 0 #C2D6BC22;
    --radius-xl: 2.25rem;
    --text-color: #21332a;
    --text-muted: #5a6b51;
    --face-size: 2.25em;
  }

  body {
    background: var(--apple-bg);
  }

  .ranking-title-ios {
    font-weight: 900;
    font-size: 2.6rem;
    background: linear-gradient(90deg, var(--apple-green) 15%, var(--apple-green-light) 60%, var(--apple-green-lighter) 90%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-align: center;
    margin: 2rem 0 1.8rem;
    animation: fadein-ios 1.3s ease forwards;
    opacity: 0;
    transform: translateY(32px);
  }

  @keyframes fadein-ios {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ranking-table-wrap {
    width: 100%;
    max-width: 580px;
    background: var(--glass);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(18px) saturate(120%);
    border: 1.5px solid #dbe9d7;
    padding: 1.5rem;
    overflow-x: hidden;
    margin: 0 auto 2rem;
  }

  .ranking-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
  }

  .ranking-table th,
  .ranking-table td {
    text-align: left;
    padding: 0.75em 0.4em;
    font-size: 1rem;
  }

  .ranking-table th {
    color: var(--apple-green);
    font-weight: 800;
    border-bottom: 2px solid #b4d0a3;
  }

  .ranking-table td {
    color: var(--text-color);
    font-weight: 600;
    border-bottom: 1px solid #e6f0de;
  }

  .ranking-table tr:last-child td {
    border-bottom: none;
  }

  .user-info {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.7em;
  }

  .user-face {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e4f0dc 60%, #c5dfb9 100%);
    font-weight: 900;
    width: var(--face-size);
    height: var(--face-size);
    font-size: 1.05rem;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  .user-face img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .highlight-user {
    background: linear-gradient(92deg, #e0f4d6 74%, #d1eac8 100%);
    font-weight: 900;
    border-radius: 1.2em;
    animation: ownin 0.85s ease;
  }

  .amount-strong {
    font-weight: 900;
    color: #2e6f2b;
    font-size: 1.1em;
  }

  .you-tag {
    font-size: 0.75rem;
    background: var(--apple-green);
    color: #fff;
    padding: 0.25em 0.7em;
    border-radius: 1em;
    margin-left: 0.5em;
    font-weight: 700;
  }

  .blurred .user-face,
  .blurred .user-name,
  .blurred .amount-blur {
    filter: blur(6px) grayscale(0.3);
    opacity: 0.45;
  }

  .back-to-dashboard {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .btn-back {
    background: linear-gradient(135deg, var(--apple-green), var(--apple-green-light));
    color: #fff;
    font-weight: 900;
    font-size: 1rem;
    padding: 0.6em 1.8em;
    border-radius: 2em;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(76, 175, 80, 0.45);
    transition: all 0.25s ease;
  }

  .btn-back:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, var(--apple-green-light), var(--apple-green-lighter));
  }

  @keyframes ownin {
    0% { opacity: 0; transform: translateY(28px) scale(0.96); }
    100% { opacity: 1; transform: none; }
  }

  @media (max-width: 680px) {
    .ranking-table-wrap { max-width: 100%; margin: 0 0 2rem 0; border-radius: 1rem; }
  }
  @media (max-width: 540px) {
    html { font-size: 15px; }
    .ranking-title-ios {
      font-size: 2rem;
    }
    .ranking-table th,
    .ranking-table td {
      font-size: 0.9rem;
      padding: 0.55em 0.3em;
    }
    .user-face {
      width: 1.9em;
      height: 1.9em;
    }
    .btn-back {
      font-size: 0.95rem;
      padding: 0.5em 1.2em;
    }
  }

  @media (max-width: 420px) {
    .user-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2em;
    }
    .you-tag {
      margin-left: 0;
    }
    .ranking-table-wrap {
      padding: 1rem;
    }
  }
</style>

<section class="rank-hero" role="banner">
  <a href="/dashboard" class="rank-hero-back" aria-label="Zurück">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
  </a>

  <div class="rank-hero-bg" aria-hidden="true">
    <span class="rank-hero-stripes"></span>
    <span class="rank-hero-scan"></span>
    <span class="rank-hero-orb rank-hero-orb-1"></span>
    <span class="rank-hero-orb rank-hero-orb-2"></span>
    <span class="rank-hero-orb rank-hero-orb-3"></span>
    <span class="rank-hero-vignette"></span>
  </div>

  <div class="rank-hero-stamp" aria-hidden="true">Hall of Shame</div>

  <div class="rank-hero-trophy" aria-hidden="true">
    <span class="rank-hero-glow"></span>
    <span class="rank-hero-glow rank-hero-glow-red"></span>
    <span class="rank-hero-ring"></span>
    <svg class="rank-hero-trophy-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2"/>
      <path d="M18 9h2a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-2"/>
      <path d="M6 3h12v6a6 6 0 0 1-12 0V3z"/>
      <line x1="12" y1="15" x2="12" y2="19"/>
      <path d="M8 21h8l-1-2H9z"/>
      <path d="M9.5 6.2L11 7.4 12 6l1 1.4 1.5-1.2"/>
    </svg>
    <span class="rank-hero-ember rank-hero-ember-1"></span>
    <span class="rank-hero-ember rank-hero-ember-2"></span>
    <span class="rank-hero-ember rank-hero-ember-3"></span>
    <span class="rank-hero-ember rank-hero-ember-4"></span>
    <span class="rank-hero-ember rank-hero-ember-5"></span>
  </div>

  <h1 class="rank-hero-title">
    <span class="rank-hero-title-shadow" aria-hidden="true">Strafen-Ranking</span>
    <span class="rank-hero-title-text">Strafen-Ranking</span>
  </h1>

  <p class="rank-hero-warn">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <span>Letzter Platz zahlt am meisten</span>
  </p>
</section>

<style>
  .rank-hero {
    position: relative;
    max-width: 720px;
    margin: 0 auto 1.5rem;
    padding: 2.5rem 1.5rem 1.7rem;
    border-radius: 24px;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(255,80,40,0.22) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 100%, rgba(180,30,30,0.28) 0%, transparent 55%),
      linear-gradient(135deg, #050505 0%, #1a0606 45%, #2a0a0a 100%);
    color: #fff;
    box-shadow:
      0 22px 60px rgba(0,0,0,0.55),
      0 4px 16px rgba(120,20,20,0.35),
      inset 0 0 0 1px rgba(255,180,80,0.08);
    isolation: isolate;
  }
  .rank-hero-back {
    position: absolute;
    top: 1rem; left: 1rem;
    z-index: 4;
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.18s, color 0.18s, transform 0.15s;
  }
  .rank-hero-back:hover { background: rgba(255,255,255,0.16); color: #fff; transform: translateX(-2px); }

  .rank-hero-bg {
    position: absolute; inset: 0; z-index: 0;
    pointer-events: none;
  }
  /* Warnungs-Streifen (Hazard) im Hintergrund */
  .rank-hero-stripes {
    position: absolute;
    inset: -20%;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255,200,80,0.045) 0 22px,
      transparent 22px 44px
    );
    opacity: 0.6;
    transform: rotate(-2deg);
  }
  /* Scanline / Grid */
  .rank-hero-scan {
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0 1px, transparent 1px 3px);
    mix-blend-mode: overlay;
    opacity: 0.5;
  }
  .rank-hero-vignette {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.55) 100%);
    pointer-events: none;
  }
  .rank-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(42px);
    opacity: 0.6;
  }
  .rank-hero-orb-1 {
    width: 260px; height: 260px;
    top: -110px; right: -70px;
    background: radial-gradient(circle, #ff6a2a 0%, transparent 70%);
    animation: rankOrbFloat 9s ease-in-out infinite;
  }
  .rank-hero-orb-2 {
    width: 200px; height: 200px;
    bottom: -80px; left: -40px;
    background: radial-gradient(circle, #c81a1a 0%, transparent 70%);
    animation: rankOrbFloat 11s ease-in-out infinite reverse;
  }
  .rank-hero-orb-3 {
    width: 140px; height: 140px;
    top: 25%; left: 50%;
    background: radial-gradient(circle, #ffaa44 0%, transparent 65%);
    opacity: 0.35;
    animation: rankOrbFloat 13s ease-in-out infinite;
  }
  @keyframes rankOrbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(14px, -10px) scale(1.07); }
  }

  /* Stamp "Hall of Shame" diagonal hinten */
  .rank-hero-stamp {
    position: absolute;
    z-index: 1;
    top: 12px;
    right: -18px;
    transform: rotate(8deg);
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255,180,80,0.28);
    border: 2px solid rgba(255,180,80,0.32);
    padding: 0.22rem 0.55rem 0.18rem;
    border-radius: 4px;
    pointer-events: none;
    text-shadow: 0 0 8px rgba(255,150,50,0.25);
  }

  /* Pokal */
  .rank-hero-trophy {
    position: relative;
    z-index: 2;
    width: 92px;
    height: 92px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-hero-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,180,60,0.55) 0%, rgba(255,140,30,0.2) 45%, transparent 70%);
    filter: blur(8px);
    animation: rankGlowPulse 2.6s ease-in-out infinite;
  }
  .rank-hero-glow-red {
    inset: -22px;
    background: radial-gradient(circle, rgba(220,38,38,0.5) 0%, rgba(150,20,20,0.25) 40%, transparent 75%);
    animation-duration: 3.4s;
    animation-direction: alternate;
    opacity: 0.85;
  }
  @keyframes rankGlowPulse {
    0%, 100% { transform: scale(1); opacity: 0.75; }
    50%      { transform: scale(1.18); opacity: 1; }
  }
  .rank-hero-ring {
    position: absolute;
    inset: -6px;
    border: 1.5px solid rgba(255,180,80,0.4);
    border-radius: 50%;
    box-shadow:
      0 0 18px rgba(255,140,40,0.35),
      inset 0 0 12px rgba(255,140,40,0.25);
    animation: rankRingSpin 14s linear infinite;
  }
  @keyframes rankRingSpin {
    to { transform: rotate(360deg); }
  }
  .rank-hero-trophy-svg {
    position: relative;
    z-index: 1;
    width: 68px;
    height: 68px;
    color: #ffd166;
    filter:
      drop-shadow(0 0 6px rgba(255,180,60,0.7))
      drop-shadow(0 6px 14px rgba(180,40,20,0.55))
      drop-shadow(0 1px 0 rgba(255,255,255,0.2));
    animation: rankTrophyBob 3.6s ease-in-out infinite;
  }
  @keyframes rankTrophyBob {
    0%, 100% { transform: translateY(0) rotate(-1.5deg); }
    50%      { transform: translateY(-4px) rotate(2deg); }
  }
  .rank-hero-ember {
    position: absolute;
    width: 5px; height: 5px;
    background: radial-gradient(circle, #ffd166 0%, #ff6a2a 50%, transparent 80%);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(255,140,40,0.9);
    opacity: 0;
    animation: rankEmber 4s ease-out infinite;
  }
  .rank-hero-ember-1 { left: 22%; bottom: 18%; animation-delay: 0s; }
  .rank-hero-ember-2 { left: 48%; bottom: 12%; animation-delay: 0.8s; }
  .rank-hero-ember-3 { left: 70%; bottom: 22%; animation-delay: 1.6s; }
  .rank-hero-ember-4 { left: 35%; bottom: 28%; animation-delay: 2.4s; width: 4px; height: 4px; }
  .rank-hero-ember-5 { left: 60%; bottom: 8%;  animation-delay: 3.2s; width: 3px; height: 3px; }
  @keyframes rankEmber {
    0%   { opacity: 0; transform: translate(0, 0) scale(0.6); }
    15%  { opacity: 1; }
    100% { opacity: 0; transform: translate(var(--ex, 6px), -42px) scale(0.2); }
  }

  /* Titel */
  .rank-hero-title {
    position: relative;
    z-index: 2;
    margin: 0 0 0.55rem;
    text-align: center;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 6vw, 2.85rem);
    letter-spacing: -0.035em;
    line-height: 1;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-hero-title-text,
  .rank-hero-title-shadow {
    grid-area: 1 / 1;
    display: inline-block;
    line-height: 1;
  }
  .rank-hero-title {
    display: grid;
    place-items: center;
  }
  .rank-hero-title-shadow {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(220,38,38,0.55);
    text-shadow:
      3px 3px 0 rgba(150,15,15,0.55),
      0 0 30px rgba(220,38,38,0.35);
    transform: translate(2px, 2px);
    filter: blur(0.4px);
    user-select: none;
  }
  .rank-hero-title-text {
    background:
      linear-gradient(180deg,
        #fff3c4 0%,
        #ffd166 35%,
        #ff8c2a 65%,
        #c11d1d 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 2px 0 rgba(120,15,15,0.7))
      drop-shadow(0 0 18px rgba(255,140,40,0.45));
    animation: rankTitleFlicker 5.5s steps(1) infinite;
  }
  @keyframes rankTitleFlicker {
    0%, 60%, 100% { opacity: 1; }
    62%           { opacity: 0.78; }
    64%           { opacity: 1; }
    78%           { opacity: 0.88; }
    80%           { opacity: 1; }
  }

  .rank-hero-warn {
    position: relative;
    z-index: 2;
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.7rem;
    border: 1px solid rgba(255,180,80,0.3);
    background: rgba(255,80,40,0.08);
    color: #ffcc88;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 4px;
    width: fit-content;
    margin: 0 auto;
  }
  .rank-hero-warn svg { color: #ffaa44; }

  @media (max-width: 560px) {
    .rank-hero { padding: 2.1rem 1rem 1.5rem; border-radius: 20px; }
    .rank-hero-trophy { width: 78px; height: 78px; margin-bottom: 0.8rem; }
    .rank-hero-trophy-svg { width: 58px; height: 58px; }
    .rank-hero-back { top: 0.7rem; left: 0.7rem; width: 32px; height: 32px; }
    .rank-hero-stamp { font-size: 0.6rem; right: -14px; }
    .rank-hero-warn { font-size: 0.62rem; padding: 0.2rem 0.55rem; }
  }
</style>

<div class="ranking-table-wrap">
  <table class="ranking-table" aria-label="Strafen Ranking Tabelle">
    <thead>
      <tr>
        <th scope="col">Platz</th>
        <th scope="col">Benutzer</th>
        <th scope="col">Betrag</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user, index) => { %>
        <% const canSeeFullEntry = isAdmin || !rankingBlurEnabled || user.id === userId; %>
        <% if (canSeeFullEntry) { %>
          <tr<% if (user.id === userId) { %> class="highlight-user"<% } %>>
            <td><%= index + 1 %></td>
            <td>
              <div class="user-info">
                <span class="user-face" aria-label="Avatar von <%= user.username %>">
                  <% if(user.avatar){ %>
                    <img src="<%= user.avatar %>" alt="Avatar von <%= user.username %>" />
                  <% } else { %>
                    <%= user.username.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
                    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
                      <circle cx="16" cy="16" r="16" fill="#d7ebce"/>
                      <ellipse cx="16" cy="13" rx="6" ry="5" fill="#b5e2b3"/>
                      <ellipse cx="16" cy="24" rx="8.5" ry="5.5" fill="#c1e1c1"/>
                    </svg>
                  <% } %>
                </span>
                <span class="user-name"><%= user.username %></span>
                <% if (user.id === userId) { %>
                  <span class="you-tag" aria-label="Du">Du</span>
                <% } %>
              </div>
            </td>
            <td><span class="amount-strong"><%= user.total_penalty_amount.toFixed(2) %> €</span></td>
          </tr>
        <% } else { %>
          <tr class="blurred" aria-hidden="true">
            <td><%= index + 1 %></td>
            <td>
              <div class="user-info">
                <span class="user-face"></span>
                <span class="user-name"></span>
              </div>
            </td>
            <td class="amount-blur"></td>
          </tr>
        <% } %>
      <% }); %>
    </tbody>
  </table>
</div>

<div class="back-to-dashboard">
  <a href="/dashboard" class="btn-back" aria-label="Zurück zum Dashboard">🔙 Zurück zum Dashboard</a>
</div>
