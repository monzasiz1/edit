
<style>
  :root {
    --apple-green: #4CAF50;
    --apple-green-light: #8BC34A;
    --apple-green-lighter: #AED581;
    --apple-bg: linear-gradient(112deg,#F7FAF8 0%,#eef7ee 100%);
    --glass: rgba(255,255,255,0.85);
    --shadow-card: 0 12px 42px 0 #B9C9B244, 0 2px 14px 0 #C2D6BC22;
    --radius-xl: 2.25rem;
    --text-color: #21332a;
    --text-muted: #5a6b51;
    --face-size: 2.25em;
  }

  body {
    background: var(--apple-bg);
  }

  .ranking-title-ios {
    font-weight: 900;
    font-size: 2.6rem;
    background: linear-gradient(90deg, var(--apple-green) 15%, var(--apple-green-light) 60%, var(--apple-green-lighter) 90%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-align: center;
    margin: 2rem 0 1.8rem;
    animation: fadein-ios 1.3s ease forwards;
    opacity: 0;
    transform: translateY(32px);
  }

  @keyframes fadein-ios {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ranking-table-wrap {
    width: 100%;
    max-width: 580px;
    background: var(--glass);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(18px) saturate(120%);
    border: 1.5px solid #dbe9d7;
    padding: 1.5rem;
    overflow-x: hidden;
    margin: 0 auto 2rem;
  }

  .ranking-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
  }

  .ranking-table th,
  .ranking-table td {
    text-align: left;
    padding: 0.75em 0.4em;
    font-size: 1rem;
  }

  .ranking-table th {
    color: var(--apple-green);
    font-weight: 800;
    border-bottom: 2px solid #b4d0a3;
  }

  .ranking-table td {
    color: var(--text-color);
    font-weight: 600;
    border-bottom: 1px solid #e6f0de;
  }

  .ranking-table tr:last-child td {
    border-bottom: none;
  }

  .user-info {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.7em;
  }

  .user-face {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e4f0dc 60%, #c5dfb9 100%);
    font-weight: 900;
    width: var(--face-size);
    height: var(--face-size);
    font-size: 1.05rem;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  .user-face img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .highlight-user {
    background: linear-gradient(92deg, #e0f4d6 74%, #d1eac8 100%);
    font-weight: 900;
    border-radius: 1.2em;
    animation: ownin 0.85s ease;
  }

  .amount-strong {
    font-weight: 900;
    color: #2e6f2b;
    font-size: 1.1em;
  }

  .you-tag {
    font-size: 0.75rem;
    background: var(--apple-green);
    color: #fff;
    padding: 0.25em 0.7em;
    border-radius: 1em;
    margin-left: 0.5em;
    font-weight: 700;
  }

  .blurred .user-face,
  .blurred .user-name,
  .blurred .amount-blur {
    filter: blur(6px) grayscale(0.3);
    opacity: 0.45;
  }

  .back-to-dashboard {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .btn-back {
    background: linear-gradient(135deg, var(--apple-green), var(--apple-green-light));
    color: #fff;
    font-weight: 900;
    font-size: 1rem;
    padding: 0.6em 1.8em;
    border-radius: 2em;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(76, 175, 80, 0.45);
    transition: all 0.25s ease;
  }

  .btn-back:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, var(--apple-green-light), var(--apple-green-lighter));
  }

  @keyframes ownin {
    0% { opacity: 0; transform: translateY(28px) scale(0.96); }
    100% { opacity: 1; transform: none; }
  }

  @media (max-width: 680px) {
    .ranking-table-wrap { max-width: 100%; margin: 0 0 2rem 0; border-radius: 1rem; }
  }
  @media (max-width: 540px) {
    html { font-size: 15px; }
    .ranking-title-ios {
      font-size: 2rem;
    }
    .ranking-table th,
    .ranking-table td {
      font-size: 0.9rem;
      padding: 0.55em 0.3em;
    }
    .user-face {
      width: 1.9em;
      height: 1.9em;
    }
    .btn-back {
      font-size: 0.95rem;
      padding: 0.5em 1.2em;
    }
  }

  @media (max-width: 420px) {
    .user-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2em;
    }
    .you-tag {
      margin-left: 0;
    }
    .ranking-table-wrap {
      padding: 1rem;
    }
  }
</style>

<section class="rank-hero" role="banner">
  <a href="/dashboard" class="rank-hero-back" aria-label="Zurück">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
  </a>
  <div class="rank-hero-bg" aria-hidden="true">
    <span class="rank-hero-orb rank-hero-orb-1"></span>
    <span class="rank-hero-orb rank-hero-orb-2"></span>
    <span class="rank-hero-orb rank-hero-orb-3"></span>
  </div>
  <div class="rank-hero-trophy" aria-hidden="true">
    <span class="rank-hero-glow"></span>
    <svg class="rank-hero-trophy-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2"/>
      <path d="M18 9h2a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-2"/>
      <path d="M6 3h12v6a6 6 0 0 1-12 0V3z"/>
      <line x1="12" y1="15" x2="12" y2="19"/>
      <path d="M8 21h8l-1-2H9z"/>
      <path d="M9.5 6.2L11 7.4 12 6l1 1.4 1.5-1.2"/>
    </svg>
    <span class="rank-hero-spark rank-hero-spark-1"></span>
    <span class="rank-hero-spark rank-hero-spark-2"></span>
    <span class="rank-hero-spark rank-hero-spark-3"></span>
  </div>
  <h1 class="rank-hero-title">
    <span class="rank-hero-title-text">Strafen-Ranking</span>
  </h1>
</section>

<style>
  .rank-hero {
    position: relative;
    max-width: 720px;
    margin: 0 auto 1.5rem;
    padding: 2.3rem 1.5rem 1.6rem;
    border-radius: 24px;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(255,225,150,0.32) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 100%, rgba(120,255,180,0.22) 0%, transparent 55%),
      linear-gradient(135deg, #0a2418 0%, #0f3a26 45%, #1a5e3f 100%);
    color: #fff;
    box-shadow: 0 18px 48px rgba(10,36,24,0.32), 0 4px 14px rgba(10,36,24,0.18);
    isolation: isolate;
  }
  .rank-hero-back {
    position: absolute;
    top: 1rem; left: 1rem;
    z-index: 4;
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.18s, color 0.18s, transform 0.15s;
  }
  .rank-hero-back:hover { background: rgba(255,255,255,0.18); color: #fff; transform: translateX(-2px); }

  .rank-hero-bg {
    position: absolute; inset: 0; z-index: 0;
    pointer-events: none;
  }
  .rank-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(38px);
    opacity: 0.55;
  }
  .rank-hero-orb-1 {
    width: 220px; height: 220px;
    top: -90px; right: -50px;
    background: radial-gradient(circle, #ffd76a 0%, transparent 70%);
    animation: rankOrbFloat 9s ease-in-out infinite;
  }
  .rank-hero-orb-2 {
    width: 180px; height: 180px;
    bottom: -70px; left: -30px;
    background: radial-gradient(circle, #4ade80 0%, transparent 70%);
    animation: rankOrbFloat 11s ease-in-out infinite reverse;
  }
  .rank-hero-orb-3 {
    width: 120px; height: 120px;
    top: 30%; left: 55%;
    background: radial-gradient(circle, #facc15 0%, transparent 65%);
    opacity: 0.3;
    animation: rankOrbFloat 13s ease-in-out infinite;
  }
  @keyframes rankOrbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(14px, -10px) scale(1.05); }
  }

  /* Pokal */
  .rank-hero-trophy {
    position: relative;
    z-index: 2;
    width: 84px;
    height: 84px;
    margin: 0 auto 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-hero-glow {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,215,100,0.55) 0%, rgba(255,200,80,0.18) 45%, transparent 70%);
    filter: blur(6px);
    animation: rankGlowPulse 2.8s ease-in-out infinite;
  }
  @keyframes rankGlowPulse {
    0%, 100% { transform: scale(1); opacity: 0.85; }
    50%      { transform: scale(1.12); opacity: 1; }
  }
  .rank-hero-trophy-svg {
    position: relative;
    z-index: 1;
    width: 64px;
    height: 64px;
    color: #ffd76a;
    filter: drop-shadow(0 4px 12px rgba(255,180,40,0.5)) drop-shadow(0 1px 0 rgba(255,255,255,0.18));
    animation: rankTrophyBob 4s ease-in-out infinite;
  }
  @keyframes rankTrophyBob {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50%      { transform: translateY(-3px) rotate(2deg); }
  }
  .rank-hero-spark {
    position: absolute;
    width: 4px; height: 4px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px 2px rgba(255,235,150,0.9);
    opacity: 0;
    animation: rankSpark 3.2s ease-in-out infinite;
  }
  .rank-hero-spark-1 { top: 8px;  left: 14px; animation-delay: 0s; }
  .rank-hero-spark-2 { top: 22px; right: 8px; animation-delay: 1.1s; }
  .rank-hero-spark-3 { bottom: 18px; left: 24px; animation-delay: 2.1s; width: 3px; height: 3px; }
  @keyframes rankSpark {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    20%, 60% { opacity: 1; transform: scale(1); }
  }

  /* Titel */
  .rank-hero-title {
    position: relative;
    z-index: 2;
    margin: 0;
    text-align: center;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    font-weight: 900;
    font-size: clamp(1.85rem, 5.2vw, 2.55rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .rank-hero-title-text {
    display: inline-block;
    background:
      linear-gradient(120deg,
        #fff5d6 0%,
        #ffd76a 28%,
        #ffe89e 55%,
        #ffd76a 80%,
        #fff5d6 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 2px 18px rgba(255,200,80,0.18);
    animation: rankShine 6s linear infinite;
  }
  @keyframes rankShine {
    0%   { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  @media (max-width: 560px) {
    .rank-hero { padding: 2rem 1rem 1.4rem; border-radius: 20px; }
    .rank-hero-trophy { width: 72px; height: 72px; margin-bottom: 0.6rem; }
    .rank-hero-trophy-svg { width: 56px; height: 56px; }
    .rank-hero-back { top: 0.7rem; left: 0.7rem; width: 32px; height: 32px; }
  }
</style>

<div class="ranking-table-wrap">
  <table class="ranking-table" aria-label="Strafen Ranking Tabelle">
    <thead>
      <tr>
        <th scope="col">Platz</th>
        <th scope="col">Benutzer</th>
        <th scope="col">Betrag</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user, index) => { %>
        <% const canSeeFullEntry = isAdmin || !rankingBlurEnabled || user.id === userId; %>
        <% if (canSeeFullEntry) { %>
          <tr<% if (user.id === userId) { %> class="highlight-user"<% } %>>
            <td><%= index + 1 %></td>
            <td>
              <div class="user-info">
                <span class="user-face" aria-label="Avatar von <%= user.username %>">
                  <% if(user.avatar){ %>
                    <img src="<%= user.avatar %>" alt="Avatar von <%= user.username %>" />
                  <% } else { %>
                    <%= user.username.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
                    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
                      <circle cx="16" cy="16" r="16" fill="#d7ebce"/>
                      <ellipse cx="16" cy="13" rx="6" ry="5" fill="#b5e2b3"/>
                      <ellipse cx="16" cy="24" rx="8.5" ry="5.5" fill="#c1e1c1"/>
                    </svg>
                  <% } %>
                </span>
                <span class="user-name"><%= user.username %></span>
                <% if (user.id === userId) { %>
                  <span class="you-tag" aria-label="Du">Du</span>
                <% } %>
              </div>
            </td>
            <td><span class="amount-strong"><%= user.total_penalty_amount.toFixed(2) %> €</span></td>
          </tr>
        <% } else { %>
          <tr class="blurred" aria-hidden="true">
            <td><%= index + 1 %></td>
            <td>
              <div class="user-info">
                <span class="user-face"></span>
                <span class="user-name"></span>
              </div>
            </td>
            <td class="amount-blur"></td>
          </tr>
        <% } %>
      <% }); %>
    </tbody>
  </table>
</div>

<div class="back-to-dashboard">
  <a href="/dashboard" class="btn-back" aria-label="Zurück zum Dashboard">🔙 Zurück zum Dashboard</a>
</div>
