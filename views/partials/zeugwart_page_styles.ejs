<style>
  /* ── Apple Dashboard Container ─────────────────── */
  .apple-dashboard {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 0.25rem 2rem;
  }

  /* ── Hero Header (Strikeboard-Style) ───────────── */
  .page-hero {
    position: relative;
    padding: 1.4rem 1.5rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    border-radius: 1.35rem 1.35rem 2rem 2rem;
    margin: -0.55rem -0.25rem 1.6rem;
    border: 1px solid rgba(160, 212, 183, 0.42);
    box-shadow: 0 15px 34px rgba(18, 66, 43, 0.34), 0 4px 12px rgba(0, 0, 0, 0.1);
    animation: pageHeroFade 0.7s cubic-bezier(.4,0,0,1.12);
  }
  @keyframes pageHeroFade {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-hero-clip {
    position: absolute; inset: 0; border-radius: inherit;
    overflow: hidden; pointer-events: none; z-index: 0;
  }
  .page-hero-orb {
    position: absolute; border-radius: 50%; pointer-events: none;
    opacity: 0.36; filter: blur(36px);
  }
  .page-hero-orb-1 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #a8f4d2 0%, transparent 70%);
    top: -50px; right: -30px;
  }
  .page-hero-orb-2 {
    width: 140px; height: 140px;
    background: radial-gradient(circle, #b8e8ff 0%, transparent 70%);
    bottom: -30px; left: 8%;
  }
  .page-hero::after {
    content: ''; position: absolute; left: 1.2rem; right: 1.2rem; top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.55), rgba(255,255,255,0.02));
    pointer-events: none; z-index: 2;
  }
  .page-hero-content {
    position: relative; z-index: 10;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap;
  }
  .page-hero-title-wrap { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .page-hero-kicker {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.7);
  }
  .page-hero-title {
    font-size: 1.85rem; font-weight: 900; margin: 0;
    letter-spacing: -0.8px; line-height: 1.1; color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.18);
    display: inline-flex; align-items: center; gap: 0.55rem;
  }
  .page-hero-title svg { width: 26px; height: 26px; flex-shrink: 0; opacity: 0.92; }
  .page-hero-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
  .page-hero-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: rgba(255,255,255,0.18); color: #fff;
    border: 1px solid rgba(255,255,255,0.28); border-radius: 2em;
    padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.02em; text-decoration: none; cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    -webkit-tap-highlight-color: transparent; white-space: nowrap;
    font-family: inherit;
  }
  .page-hero-btn:hover {
    background: rgba(255,255,255,0.28);
    box-shadow: 0 10px 26px rgba(0,0,0,0.2);
    transform: translateY(-1px); color: #fff;
  }
  .page-hero-btn:active { transform: scale(0.96); }
  .page-hero-btn.primary { background: #fff; color: #1a7a45; border-color: rgba(255,255,255,0.6); }
  .page-hero-btn.primary:hover { background: #f0fff7; color: #145d34; }
  .page-hero-btn.ghost { background: transparent; border-color: rgba(255,255,255,0.4); }
  .page-hero-btn svg { width: 14px; height: 14px; }

  @media (max-width: 640px) {
    .page-hero { padding: 1.1rem 1.1rem; border-radius: 1.1rem 1.1rem 1.6rem 1.6rem; margin-bottom: 1.2rem; }
    .page-hero-content { flex-direction: column; align-items: stretch; gap: 0.85rem; }
    .page-hero-title { font-size: 1.45rem; }
    .page-hero-title svg { width: 22px; height: 22px; }
    .page-hero-actions { width: 100%; }
    .page-hero-btn { flex: 1 1 auto; justify-content: center; padding: 0.55rem 0.7rem; font-size: 0.82rem; }
  }
  @media (max-width: 380px) {
    .page-hero-actions { flex-direction: column; }
    .page-hero-btn { width: 100%; }
  }

  /* ── Cards ─────────────────────────────────────── */
  .dev-card {
    background: #fff;
    border: 1px solid #e1eae3;
    border-radius: 1.1rem;
    padding: 1.4rem 1.5rem;
    box-shadow: 0 4px 18px rgba(60,120,80,0.07), 0 1px 4px rgba(0,0,0,0.03);
    margin-bottom: 1.2rem;
  }

  /* ── Form Elements ─────────────────────────────── */
  .apple-form-group { margin-bottom: 1.1rem; }
  .apple-form-group label {
    display: block;
    font-weight: 600;
    color: #2a3e32;
    margin-bottom: 0.4rem;
    font-size: 0.93rem;
  }
  .apple-input,
  input.apple-input,
  select.apple-input,
  textarea.apple-input {
    width: 100%;
    padding: 0.7rem 0.95rem;
    border: 2px solid #d4dfcf;
    border-radius: 10px;
    font-size: 1rem;
    font-family: inherit;
    background: #fff;
    color: #1b2e2b;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .apple-input:focus,
  textarea.apple-input:focus,
  select.apple-input:focus {
    outline: none;
    border-color: #3da973;
    box-shadow: 0 0 0 4px rgba(61, 169, 115, 0.15);
  }
  textarea.apple-input { resize: vertical; min-height: 80px; }

  /* ── Alerts ────────────────────────────────────── */
  .apple-alert {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.1rem;
    border-radius: 12px;
    border: 1.5px solid transparent;
    font-weight: 600;
  }
  .alert-success { background: #e8f6ed; border-color: #b7dcc4; color: #145d34; }
  .alert-error   { background: #fef2f2; border-color: #fecaca; color: #b91c1c; }

  /* ── Buttons ───────────────────────────────────── */
  .dev-btn-primary {
    display: inline-block;
    padding: 0.7rem 1.4rem;
    background: #3da973;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-family: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
    box-shadow: 0 3px 10px rgba(61, 169, 115, 0.25);
  }
  .dev-btn-primary:hover {
    background: #2d8f55;
    transform: translateY(-1px);
    box-shadow: 0 5px 14px rgba(61, 169, 115, 0.35);
  }
  .dev-btn-danger {
    display: inline-block;
    padding: 0.55rem 1.1rem;
    background: #fff;
    color: #b91c1c;
    border: 1.5px solid #fecaca;
    border-radius: 10px;
    font-weight: 600;
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.18s;
  }
  .dev-btn-danger:hover { background: #fef2f2; border-color: #f87171; }
  .dev-btn-ghost {
    display: inline-block;
    padding: 0.55rem 1.1rem;
    background: #fff;
    color: #2a3e32;
    border: 1.5px solid #d4dfcf;
    border-radius: 10px;
    font-weight: 600;
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.18s;
  }
  .dev-btn-ghost:hover { background: #f3f7f4; border-color: #b7dcc4; }
</style>
