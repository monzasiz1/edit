<div class="penalties-export">
  <%- include('partials/page_hero', {
        kicker: 'Admin',
        title: 'Alle Strafen',
        subtitle: 'Tabellenansicht aller Strafen aller Mitglieder.',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
        actions: [
          { href: '/penalties/add', label: 'Neue Strafe', variant: 'primary', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' },
          { href: '/penalties', label: 'Zur\u00fcck', variant: 'ghost', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>' }
        ]
      }) %>

  <div class="only-desktop">
    <table class="responsive-table penalties-table">
      <thead>
        <tr>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4b7a5e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Nutzer</th>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7db3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> Datum</th>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Grund</th>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e05a5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Veranstaltung</th>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22a06b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg> Betrag</th>
          <th><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg> Aktion</th>
        </tr>
      </thead>
      <tbody>
        <% let sum = 0; %>
        <% penalties.forEach(p => { sum += parseFloat(p.amount) || 0; %>
          <tr>
            <td data-label="Nutzer"><%= p.username %></td>
            <td data-label="Datum">
              <%= p.date
                ? (typeof p.date === 'string'
                    ? new Date(p.date).toLocaleDateString('de-DE')
                    : p.date.toLocaleDateString('de-DE'))
                : '' %>
            </td>
            <td data-label="Grund"><%= p.type %></td>
            <td data-label="Veranstaltung"><%= p.event %></td>
            <td data-label="Betrag" style="text-align:right;"><%= Number(p.amount).toFixed(2) %> €</td>
            <td data-label="Aktion">
              <a href="/penalties/edit/<%= p.id %>" class="btn btn-small"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Bearbeiten</a>
              <form action="/penalties/delete/<%= p.id %>" method="POST" style="display:inline">
                <button class="btn btn-small btn-delete" onclick="return confirm('Wirklich löschen?')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3em;vertical-align:middle" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Löschen</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <tr class="sum-row">
          <td colspan="4" style="text-align:right; font-weight:bold;">Summe</td>
          <td style="text-align:right; font-weight:bold;"><%= sum.toFixed(2) %> €</td>
          <td></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Mobile Card Ansicht -->
  <div class="penalty-cards only-mobile">
    <a href="/penalties/add" class="btn btn-add" style="margin-bottom: 1em;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:0.35em;vertical-align:middle" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Neue Strafe</a>
    <% let mobileSum = 0; %>
    <% penalties.forEach(p => { mobileSum += parseFloat(p.amount) || 0; %>
      <div class="penalty-card penalty-card-mobile">
        <div class="penalty-row"><span class="penalty-label"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4b7a5e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span><span><%= p.username %></span></div>
        <div class="penalty-row"><span class="penalty-label"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7db3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
          <span>
            <%= p.date
              ? (typeof p.date === 'string'
                  ? new Date(p.date).toLocaleDateString('de-DE')
                  : p.date.toLocaleDateString('de-DE'))
              : '' %>
          </span>
        </div>
        <div class="penalty-row"><span class="penalty-label"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span><span><%= p.type %></span></div>
        <div class="penalty-row"><span class="penalty-label"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#e05a5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span><span><%= p.event %></span></div>
        <div class="penalty-row"><span class="penalty-label"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22a06b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span><span><%= Number(p.amount).toFixed(2) %> €</span></div>
        <div class="penalty-actions-bottomright">
          <a href="/penalties/edit/<%= p.id %>" class="icon-btn" title="Bearbeiten"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></a>
          <form action="/penalties/delete/<%= p.id %>" method="POST" style="display:inline">
            <button class="icon-btn" title="Löschen" onclick="return confirm('Wirklich löschen?')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
          </form>
        </div>
      </div>
    <% }) %>
    <div class="penalty-card sum-row" style="background:#e4e7dc;">
      <div class="penalty-row" style="font-weight:bold; justify-content:space-between;">
        <span>Gesamtsumme</span>
        <span><%= mobileSum.toFixed(2) %> €</span>
      </div>
    </div>
  </div>
</div>
