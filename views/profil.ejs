      /* Items innerhalb eines Slots */
      .equip-slot-items {
        list-style: none;
        margin: 0.5rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .equip-item {
        position: relative;
        padding: 0.45rem 0.65rem 0.5rem 0.85rem;
        background: #fafdfb;
        border-radius: 10px;
        border-left: 3px solid #c5e8d2;
        min-width: 0;
      }
      .equip-slot-other .equip-item { border-left-color: #d8e2df; }

      .equip-item-name {
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        font-size: 0.92rem;
        font-weight: 600;
        color: #1b2e2b;
        line-height: 1.25;
        word-break: break-word;
      }
      .equip-qty {
        font-size: 0.78rem;
        font-weight: 700;
        color: #fff;
        background: #1a7a45;
        padding: 0.05rem 0.4rem;
        border-radius: 999px;
        flex-shrink: 0;
      }
      .equip-item-desc {
        margin-top: 0.18rem;
        font-size: 0.8rem;
        color: #4b5563;
        line-height: 1.4;
      }
      .equip-item-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.35rem;
      }
      .equip-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        font-size: 0.7rem;
        font-weight: 600;
        line-height: 1;
        padding: 0.22rem 0.45rem 0.22rem 0.4rem;
        border-radius: 6px;
        background: #f1f5f4;
        color: #475569;
        border: 1px solid #e1eae3;
      }
      .equip-tag .equip-tag-k {
        font-size: 0.62rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #94a3b8;
      }
      .equip-tag .equip-tag-v {
        color: #1b2e2b;
        font-weight: 700;
      }
      .equip-tag.equip-tag-warn {
        background: #fff4e6;
        border-color: #fde2a8;
      }
      .equip-tag.equip-tag-warn .equip-tag-k { color: #b45309; }
      .equip-tag.equip-tag-warn .equip-tag-v { color: #92400e; }

      .equip-item-notes {
        margin-top: 0.35rem;
        padding: 0.32rem 0.55rem;
        background: #fffdf5;
        border: 1px dashed #f0d99a;
        border-radius: 6px;
        font-size: 0.76rem;
        font-style: italic;
        color: #8a6a14;
        line-height: 1.35;
      }

      /* Mobile: kompaktere Polsterung */
      @media (max-width: 640px) {
        .equip-figure-wrap {
          padding: 0.6rem 0.7rem 0.85rem;
        }
        .equip-figure {
          padding: 0.6rem 0.4rem 0.4rem;
          margin-bottom: 0.85rem;
        }
        .equip-puppet-wrap {
          max-width: 260px;
          margin: 0 auto;
        }
        .equip-slot-list {
          grid-template-columns: 1fr;
        }
        .equip-summary {
          padding: 0.55rem 0.6rem;
        }
        .equip-summary-stat { padding: 0 0.3rem; }
      }
    </style>

    <script>
    (function () {
      var wrap    = document.getElementById('equip-puppet-wrap');
      var tooltip = document.getElementById('puppet-tooltip');
      var tipBody = document.getElementById('puppet-tooltip-body');
      var tipClose= document.getElementById('puppet-tooltip-close');
      if (!wrap || !tooltip) return;

      // Equipment-Daten lesen
      var dataEl = document.getElementById('equip-slots-data');
      var equipData = {};
      try { equipData = JSON.parse(dataEl ? dataEl.textContent : '{}'); } catch(e) {}

      var hideTimer = null;

      function esc(s) {
        return String(s || '')
          .replace(/&/g,'&amp;').replace(/</g,'&lt;')
          .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function buildHtml(slot, label) {
        var items = (equipData[slot] || []).slice();
        // handLeft / handRight bekommen auch allgemeine 'hands'-Items
        if (slot === 'handLeft' || slot === 'handRight') {
          (equipData.hands || []).forEach(function(i) { items.push(i); });
        }
        var h = '<div class="puppet-tooltip-header">' +
                  '<span class="puppet-tooltip-label">' + esc(label) + '</span>' +
                  (items.length ? '<span class="puppet-tooltip-count">' + items.length + '</span>' : '') +
                '</div>';
        h += '<div class="puppet-tooltip-body-inner">';
        if (!items.length) {
          h += '<span class="puppet-tooltip-empty">Kein Equipment zugewiesen</span>';
        } else {
          h += '<ul>';
          items.forEach(function(it) {
            h += '<li><strong>' + esc(it.name) + (it.quantity > 1 ? ' &times;' + it.quantity : '') + '</strong>';
            if (it.description)   h += '<small>' + esc(it.description) + '</small>';
            if (it.serial_number) h += '<small>SN: ' + esc(it.serial_number) + '</small>';
            h += '</li>';
          });
          h += '</ul>';
        }
        h += '</div>';
        return h;
      }

      function position(dot) {
        var wR = wrap.getBoundingClientRect();
        var dR = dot.getBoundingClientRect();
        var dLeft = dR.left - wR.left + dR.width / 2;
        var dTop  = dR.top  - wR.top  + dR.height / 2;
        var wW = wrap.offsetWidth;
        var wH = wrap.offsetHeight;

        // Horizontal: Tooltip links oder rechts vom Dot
        tooltip.style.left = tooltip.style.right = '';
        if (dLeft < wW * 0.55) {
          tooltip.style.left = Math.min(dLeft + 14, wW - 220) + 'px';
        } else {
          tooltip.style.right = Math.min(wW - dLeft + 14, wW - 220) + 'px';
        }
        // Vertikal: oben oder unten
        tooltip.style.top = tooltip.style.bottom = '';
        if (dTop < wH * 0.55) {
          tooltip.style.top = (dTop + 10) + 'px';
        } else {
          tooltip.style.bottom = (wH - dTop + 10) + 'px';
        }
      }

      function show(dot) {
        cancelHide();
        tipBody.innerHTML = buildHtml(dot.dataset.slot, dot.dataset.label || dot.dataset.slot);
        position(dot);
        tooltip.classList.add('visible');
        tooltip.setAttribute('aria-hidden', 'false');
        wrap.querySelectorAll('.puppet-dot').forEach(function(d) { d.classList.remove('active'); });
        dot.classList.add('active');
      }

      function hide() {
        tooltip.classList.remove('visible');
        tooltip.setAttribute('aria-hidden', 'true');
        wrap.querySelectorAll('.puppet-dot.active').forEach(function(d) { d.classList.remove('active'); });
      }

      function scheduleHide() { hideTimer = setTimeout(hide, 120); }
      function cancelHide()   { clearTimeout(hideTimer); }

      wrap.querySelectorAll('.puppet-dot.equipped').forEach(function(dot) {
        // Desktop Hover
        dot.addEventListener('mouseenter', function() { show(dot); });
        dot.addEventListener('mouseleave', function(e) {
          if (!tooltip.contains(e.relatedTarget)) scheduleHide();
        });
        // Alle Geräte: Tap/Click
        dot.addEventListener('click', function(e) {
          e.stopPropagation();
          dot.classList.contains('active') ? hide() : show(dot);
        });
        // Tastatur
        dot.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); show(dot); }
          if (e.key === 'Escape') hide();
        });
      });

      // Tooltip selbst: Maus drauf → nicht schließen
      tooltip.addEventListener('mouseenter', cancelHide);
      tooltip.addEventListener('mouseleave', scheduleHide);

      // Schließ-Button
      if (tipClose) tipClose.addEventListener('click', function(e) { e.stopPropagation(); hide(); });

      // Klick außerhalb
      document.addEventListener('click', hide);
      wrap.addEventListener('click', function(e) { e.stopPropagation(); });
    })();
    </script>

    <!-- Zugewiesenes Equipment -->
    <% if (assignedEquipment && assignedEquipment.length > 0) { %>
      <details class="profil-card">
        <summary class="profil-card-title">
          <svg class="profil-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
          Mein zugewiesenes Equipment
          <svg class="profil-card-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="profil-card-body">

        <ul class="profil-equipment-grid">
          <% assignedEquipment.forEach(item => { %>
            <li class="profil-equipment-card">
              <div class="profil-equipment-icon">
                <% if (item.category_icon_svg) { %>
                  <span class="profil-equipment-icon-svg" aria-hidden="true"><%- item.category_icon_svg %></span>
                <% } else if (item.category_icon_emoji) { %>
                  <span class="profil-equipment-icon-emoji" aria-hidden="true"><%= item.category_icon_emoji %></span>
                <% } else { %>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                  </svg>
                <% } %>
              </div>
              <div class="profil-equipment-body">
                <div class="profil-equipment-head">
                  <strong class="profil-equipment-name"><%= item.name %></strong>
                  <% if (item.quantity > 1) { %>
                    <span class="profil-equipment-qty">×<%= item.quantity %></span>
                  <% } %>
                </div>
                <% if (item.category_name) { %>
                  <span class="profil-equipment-cat"><%= item.category_name %></span>
                <% } %>
                <% if (item.description) { %>
                  <span class="profil-equipment-meta"><%= item.description %></span>
                <% } %>
                <div class="profil-equipment-tags">
                  <% if (item.serial_number) { %>
                    <span class="profil-equipment-tag">SN: <%= item.serial_number %></span>
                  <% } %>
                  <% if (item.condition && item.condition !== 'gut') { %>
                    <span class="profil-equipment-tag profil-equipment-tag-warn">Zustand: <%= item.condition %></span>
                  <% } %>
                </div>
                <% if (item.notes) { %>
                  <span class="profil-equipment-notes"><%= item.notes %></span>
                <% } %>
                <% if (item.assignment_id) { %>
                  <div class="profil-equipment-actions">
                    <% if (item.pending_defect) { %>
                      <span class="profil-equipment-pending" title="Defekt-Meldung wartet auf den Zeugwart">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Defekt gemeldet
                      </span>
                    <% } else { %>
                      <button type="button" class="profil-equipment-action profil-equipment-action-warn"
                              data-eq-request="defect"
                              data-assignment-id="<%= item.assignment_id %>"
                              data-equipment-name="<%= item.name %>">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Defekt melden
                      </button>
                    <% } %>
                    <% if (item.pending_return) { %>
                      <span class="profil-equipment-pending" title="Rückgabe ist beim Zeugwart angemeldet">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                        Rückgabe angemeldet
                      </span>
                    <% } else { %>
                      <button type="button" class="profil-equipment-action"
                              data-eq-request="return"
                              data-assignment-id="<%= item.assignment_id %>"
                              data-equipment-name="<%= item.name %>">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                        Rückgabe anmelden
                      </button>
                    <% } %>
                  </div>
                <% } %>
              </div>
            </li>
          <% }) %>
        </ul>
        </div>
      </details>
    <% } %>

    <!-- Meine Rollen -->
    <% if (userRoles && userRoles.length > 0) { %>
      <details class="profil-card">
        <summary class="profil-card-title">
          <svg class="profil-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Meine Rollen
          <svg class="profil-card-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="profil-card-body">

        <div class="profil-roles-wrap">
          <% userRoles.forEach(role => { %>
            <span class="profil-role-chip <%= role.is_admin ? 'profil-role-chip-admin' : (role.is_board ? 'profil-role-chip-board' : '') %>">
              <%= role.name %>
              <% if (role.is_admin) { %><span class="profil-role-badge profil-role-badge-admin">Admin</span><% } %>
              <% if (role.is_board) { %><span class="profil-role-badge profil-role-badge-board">Vorstand</span><% } %>
            </span>
          <% }) %>
        </div>

        <% if (userRoles.some(r => r.description)) { %>
          <ul class="profil-roles-desc">
            <% userRoles.filter(r => r.description).forEach(role => { %>
              <li><strong><%= role.name %>:</strong> <%= role.description %></li>
            <% }) %>
          </ul>
        <% } %>
        </div>
      </details>
    <% } %>

    <!-- Letzte Aktivitäten -->
    <details class="profil-card">
      <summary class="profil-card-title">
        <svg class="profil-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        Letzte Aktivitäten
        <svg class="profil-card-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="profil-card-body">

      <ul class="profil-activity">
        <% if (recentActivities && recentActivities.length > 0) { %>
          <%
            const ACT_ICONS = {
              'Notiz':      { color: '#3b82f6', bg: '#dbeafe', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>' },
              'Aufgabe':    { color: '#16a34a', bg: '#dcfce7', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' },
              'Warnung':    { color: '#d97706', bg: '#fef3c7', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' },
              'Erinnerung': { color: '#7c3aed', bg: '#ede9fe', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>' },
              'Belohnung':  { color: '#ca8a04', bg: '#fef9c3', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>' }
            };
            const ACT_DEFAULT = { color: '#dc2626', bg: '#fee2e2', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>' };
          %>
          <% recentActivities.forEach(activity => { %>
            <% const ic = ACT_ICONS[activity.type] || ACT_DEFAULT; %>
            <li class="profil-activity-item" style="border-left-color: <%= ic.color %>;">
              <div class="profil-activity-icon" style="background: <%= ic.bg %>; color: <%= ic.color %>;">
                <%- ic.svg %>
              </div>
              <div class="profil-activity-content">
                <p class="profil-activity-text"><%= activity.text %></p>
                <span class="profil-activity-time"><%= activity.time %></span>
              </div>
            </li>
          <% }); %>
        <% } else { %>
          <li class="profil-activity-item">
            <div class="profil-activity-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <path d="M12 17h.01"/>
              </svg>
            </div>
            <div class="profil-activity-content">
              <p class="profil-activity-text">Noch keine Aktivitäten</p>
              <span class="profil-activity-time">Beginne mit dem ersten Eintrag!</span>
            </div>
          </li>
        <% } %>
      </ul>
      </div>
    </details>

  </div>

  <!-- Hidden Avatar Upload Form -->
  <form id="avatar-form" action="/profil/avatar" method="POST" enctype="multipart/form-data" style="display:none;">
    <input type="file" id="avatar-input" name="avatar" accept="image/*" class="profil-avatar-input" />
  </form>

</div>

<script>
  // Karten bleiben standardmaessig geschlossen (Nutzer klappt selbst auf)
  (function () {
    document.querySelectorAll('details.profil-card').forEach(function (card) {
      card.open = false;
    });
  })();

  // Avatar Upload Handling
  const avatarInputEl = document.getElementById('avatar-input');
  const avatarBtn = document.getElementById('profil-avatar-upload-btn');
  const avatarEl = document.getElementById('profil-avatar');

  function openAvatarPicker(ev) {
    if (ev) { ev.preventDefault(); ev.stopPropagation(); }
    if (avatarInputEl) avatarInputEl.click();
  }
  if (avatarBtn) avatarBtn.addEventListener('click', openAvatarPicker);
  if (avatarEl) {
    avatarEl.addEventListener('click', openAvatarPicker);
    avatarEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') openAvatarPicker(e);
    });
  }

  avatarInputEl.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      // Basic validation
      if (file.size > 5 * 1024 * 1024) { // 5MB limit
        alert('Datei zu groß! Max. 5MB erlaubt.');
        return;
      }
      if (!file.type.startsWith('image/')) {
        alert('Bitte nur Bilddateien auswählen.');
        return;
      }

      // Show loading state
      const avatar = document.getElementById('profil-avatar');
      avatar.innerHTML = '<div style="width:40px;height:40px;border:3px solid #fff;border-top:3px solid transparent;border-radius:50%;animation:spin 1s linear infinite;"></div>';
      document.getElementById('avatar-form').submit();
    }
  });

  // Drag & Drop für Avatar
  const avatar = document.getElementById('profil-avatar');
  avatar.addEventListener('dragover', function(e) {
    e.preventDefault();
    avatar.style.borderColor = '#3d8c5e';
  });
  avatar.addEventListener('dragleave', function(e) {
    e.preventDefault();
    avatar.style.borderColor = 'rgba(255,255,255,0.3)';
  });
  avatar.addEventListener('drop', function(e) {
    e.preventDefault();
    avatar.style.borderColor = 'rgba(255,255,255,0.3)';
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      document.getElementById('avatar-input').files = files;
      document.getElementById('avatar-input').dispatchEvent(new Event('change'));
    }
  });

  // Loading Animation
  const style = document.createElement('style');
  style.textContent = '@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }';
  document.head.appendChild(style);
</script>

<!-- Equipment Request Modal (Defekt melden / Rueckgabe anmelden) -->
<div class="eqreq-backdrop" id="eqReqModal" role="dialog" aria-modal="true" aria-hidden="true">
  <form class="eqreq-modal" id="eqReqForm" method="post" action="/equipment/request" autocomplete="off">
    <div class="eqreq-head">
      <strong id="eqReqTitle">Anfrage senden</strong>
      <button type="button" class="eqreq-close" id="eqReqClose" aria-label="Schließen">&times;</button>
    </div>
    <div class="eqreq-body">
      <p class="eqreq-sub" id="eqReqSub">Der Zeugwart wird benachrichtigt.</p>
      <label class="eqreq-label" for="eqReqNote">Anmerkung (optional)</label>
      <textarea id="eqReqNote" name="note" rows="3" maxlength="1000" placeholder="z. B. Riss am Ärmel, Knopf fehlt …"></textarea>
      <input type="hidden" name="type" id="eqReqType" value="">
      <input type="hidden" name="assignment_id" id="eqReqAssignmentId" value="">
    </div>
    <div class="eqreq-actions">
      <button type="button" class="eqreq-btn eqreq-btn-ghost" id="eqReqCancel">Abbrechen</button>
      <button type="submit" class="eqreq-btn eqreq-btn-primary" id="eqReqSubmit">Senden</button>
    </div>
  </form>
</div>

<style>
  .eqreq-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15,35,25,0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1100;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .eqreq-backdrop.open { display: flex; opacity: 1; }
  .eqreq-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 18px 42px rgba(10,30,20,0.35), 0 6px 18px rgba(10,30,20,0.18);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(12px) scale(0.985);
    opacity: 0;
    transition: transform 0.28s cubic-bezier(0.22,0.61,0.36,1), opacity 0.22s ease;
  }
  .eqreq-backdrop.open .eqreq-modal { transform: translateY(0) scale(1); opacity: 1; }
  .eqreq-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.95rem 1.15rem;
    background: linear-gradient(145deg, #1a3d2a, #2d6a45 60%, #3d8c5e);
    color: #fff;
  }
  .eqreq-head strong { color: #fff; font-size: 1rem; }
  .eqreq-close {
    background: rgba(255,255,255,0.15); border: none; color: #fff;
    width: 32px; height: 32px; border-radius: 50%;
    font-size: 1.3rem; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.18s;
  }
  .eqreq-close:hover { background: rgba(255,255,255,0.3); }
  .eqreq-body { padding: 1.05rem 1.15rem 0.4rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .eqreq-sub { font-size: 0.85rem; color: #4b5563; margin: 0; line-height: 1.4; }
  .eqreq-label { font-size: 0.78rem; font-weight: 700; color: #1a3d2a; }
  .eqreq-body textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid #cfe5d8;
    border-radius: 0.65rem;
    font-family: inherit;
    font-size: 0.92rem;
    resize: vertical;
    min-height: 70px;
  }
  .eqreq-body textarea:focus { outline: 2px solid #3da973; outline-offset: -1px; border-color: #3da973; }
  .eqreq-actions {
    display: flex; gap: 0.55rem; justify-content: flex-end;
    padding: 0.85rem 1.15rem 1rem;
  }
  .eqreq-btn {
    padding: 0.55rem 1.1rem;
    border-radius: 0.65rem;
    border: none;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    font-size: 0.92rem;
    transition: background 0.18s, color 0.18s;
  }
  .eqreq-btn-ghost {
    background: #f1f8f3; color: #1a7a45; border: 1px solid #cfe5d8;
  }
  .eqreq-btn-ghost:hover { background: #e2efe6; }
  .eqreq-btn-primary {
    background: #1a7a45; color: #fff;
  }
  .eqreq-btn-primary:hover { background: #156236; }
</style>

<script>
(function() {
  const modal      = document.getElementById('eqReqModal');
  const form       = document.getElementById('eqReqForm');
  const closeBtn   = document.getElementById('eqReqClose');
  const cancelBtn  = document.getElementById('eqReqCancel');
  const titleEl    = document.getElementById('eqReqTitle');
  const subEl      = document.getElementById('eqReqSub');
  const typeEl     = document.getElementById('eqReqType');
  const assignIdEl = document.getElementById('eqReqAssignmentId');
  const noteEl     = document.getElementById('eqReqNote');
  const submitBtn  = document.getElementById('eqReqSubmit');

  if (!modal || modal.parentNode !== document.body) document.body.appendChild(modal);

  function openModal(type, assignmentId, equipmentName) {
    typeEl.value = type;
    assignIdEl.value = assignmentId;
    noteEl.value = '';
    if (type === 'defect') {
      titleEl.textContent = 'Defekt melden';
      subEl.textContent = '„' + equipmentName + '" als defekt melden. Der Zeugwart bekommt eine Meldung.';
      submitBtn.textContent = 'Defekt melden';
    } else {
      titleEl.textContent = 'Rückgabe anmelden';
      subEl.textContent = '„' + equipmentName + '" zurückgeben. Der Zeugwart wird informiert und nimmt es entgegen.';
      submitBtn.textContent = 'Rückgabe anmelden';
    }
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => noteEl.focus({ preventScroll: true }), 60);
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-eq-request]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openModal(
        btn.getAttribute('data-eq-request'),
        btn.getAttribute('data-assignment-id'),
        btn.getAttribute('data-equipment-name') || 'Equipment'
      );
    });
  });
  closeBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });
})();
</script>
