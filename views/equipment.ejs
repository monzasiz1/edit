    <div class="qr-modal-head">
      <strong>Equipment scannen</strong>
      <button type="button" class="qr-modal-close" id="qrClose" aria-label="Schließen">✕</button>
    </div>
    <div class="qr-modal-body">
      <div class="qr-video-wrap">
        <video id="qrVideo" playsinline muted></video>
        <div class="qr-frame"></div>
        <div class="qr-hint" id="qrHint">Kamera wird gestartet…</div>
      </div>
      <form id="qrManualForm" class="qr-manual">
        <label for="qrManualInput">Seriennummer / Code manuell eingeben</label>
