<style>
  /* Equipment Liste – mobile first */
  .eq-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
    align-items: stretch;
  }
  .eq-toolbar .eq-search,
  .eq-toolbar .eq-cat {
    flex: 1 1 140px;
    min-width: 0;
    padding: 0.55rem 0.8rem;
    border: 1px solid #d4dfcf;
    border-radius: 0.7rem;
    background: #fff;
    font-size: 0.92rem;
    color: #1b2e2b;
    outline: none;
    transition: border-color 0.16s, box-shadow 0.16s;
  }
  .eq-toolbar .eq-search:focus,
  .eq-toolbar .eq-cat:focus {
    border-color: #3da973;
    box-shadow: 0 0 0 3px rgba(61,169,115,0.15);
  }
  .eq-toolbar button,
  .eq-toolbar a.eq-reset {
    flex-shrink: 0;
  }

  .eq-meta {
    font-size: 0.82rem;
    color: #6b7280;
    margin-bottom: 0.85rem;
  }
  .eq-meta strong { color: #1a7a45; }

  .eq-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.7rem;
    margin: 0 0 1.1rem;
  }
  .eq-stat {
    position: relative;
    background: #fff;
    border: 1px solid #e2efe6;
    border-radius: 14px;
    padding: 0.75rem 0.9rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    box-shadow: 0 1px 2px rgba(15, 40, 28, 0.04);
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .eq-stat:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(15, 40, 28, 0.08);
    border-color: #cfe5d8;
  }
  .eq-stat::before {
    content: '';
    position: absolute;
    left: 0; top: 12px; bottom: 12px;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: #cfe5d8;
  }
  .eq-stat[data-tone="primary"]::before { background: linear-gradient(180deg, #3da973, #1a7a45); }
  .eq-stat[data-tone="warn"]::before    { background: linear-gradient(180deg, #f0a83c, #d97706); }
  .eq-stat[data-tone="ok"]::before      { background: linear-gradient(180deg, #4ec97e, #198a4c); }
  .eq-stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #6b7280;
  }
  .eq-stat-val {
    font-size: 1.55rem;
    font-weight: 800;
    line-height: 1.1;
    color: #1a3d2a;
    font-variant-numeric: tabular-nums;
  }
  .eq-stat[data-tone="warn"] .eq-stat-val { color: #b8650a; }
  .eq-stat[data-tone="ok"]   .eq-stat-val { color: #198a4c; }
  .eq-stat-sub {
    font-size: 0.72rem;
    color: #6b7280;
  }
  @media (max-width: 600px) {
    .eq-stats { grid-template-columns: repeat(2, 1fr); gap: 0.55rem; }
    .eq-stat { padding: 0.6rem 0.7rem 0.65rem; }
    .eq-stat-val { font-size: 1.3rem; }
  }

  /* Statistik-Modal */
  .eq-stats-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 28, 22, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .eq-stats-modal-backdrop.open { display: flex; opacity: 1; }
  .eq-stats-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: 720px;
    max-height: calc(100dvh - 1.5rem);
    box-shadow: 0 16px 40px rgba(10, 30, 20, 0.35), 0 6px 18px rgba(10, 30, 20, 0.18);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: translateY(12px) scale(0.985);
    opacity: 0;
    transition: transform 0.28s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.22s ease;
  }
  .eq-stats-modal-backdrop.open .eq-stats-modal { transform: translateY(0) scale(1); opacity: 1; }
  .eq-stats-modal-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.2rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    color: #fff;
    flex-shrink: 0;
  }
  .eq-stats-modal-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex: 1;
  }
  .eq-stats-modal-title svg { width: 18px; height: 18px; }
  .eq-stats-modal-close {
    background: rgba(255,255,255,0.15);
    border: 0;
    color: #fff;
    width: 32px; height: 32px;
    border-radius: 50%;
    font-size: 1.3rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.18s;
  }
  .eq-stats-modal-close:hover { background: rgba(255,255,255,0.3); }
  .eq-stats-modal .eq-stats {
    margin: 0;
    padding: 1.1rem;
    overflow-y: auto;
  }

  /* Inbox-Modal */
  .eq-inbox-backdrop {
    position: fixed; inset: 0;
    background: rgba(15,28,22,0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .eq-inbox-backdrop.open { display: flex; opacity: 1; }
  .eq-inbox-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: 760px;
    max-height: calc(100dvh - 1.5rem);
    overflow: hidden;
    display: flex; flex-direction: column;
    box-shadow: 0 16px 40px rgba(10,30,20,0.35), 0 6px 18px rgba(10,30,20,0.18);
    transform: translateY(12px) scale(0.985);
    opacity: 0;
    transition: transform 0.28s cubic-bezier(0.22,0.61,0.36,1), opacity 0.22s ease;
  }
  .eq-inbox-backdrop.open .eq-inbox-modal { transform: translateY(0) scale(1); opacity: 1; }
  .eq-inbox-head {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.2rem;
    background: linear-gradient(145deg, #b8590a 0%, #d97f1a 60%, #f0a042 100%);
    color: #fff; flex-shrink: 0;
  }
  .eq-inbox-title { margin: 0; flex: 1; display: flex; align-items: center; gap: 0.55rem; font-size: 1.05rem; font-weight: 800; }
  .eq-inbox-title svg { width: 18px; height: 18px; }
  .eq-inbox-close {
    background: rgba(255,255,255,0.15); border: 0; color: #fff;
    width: 32px; height: 32px; border-radius: 50%;
    font-size: 1.3rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.18s;
  }
  .eq-inbox-close:hover { background: rgba(255,255,255,0.3); }
  .eq-inbox-summary {
    display: flex; flex-wrap: wrap; gap: 0.45rem;
    padding: 0.85rem 1.1rem;
    background: #fffaf2;
    border-bottom: 1px solid #f3e6cb;
  }
  .eq-inbox-chip {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    background: #fff;
    border: 1px solid #e2efe6;
    color: #1a3d2a;
  }
  .eq-inbox-chip .eq-inbox-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: currentColor;
  }
  .eq-inbox-chip-warn   { color: #92500a; background: #fff7e6; border-color: #fde2a8; }
  .eq-inbox-chip-info   { color: #1a4d7a; background: #eaf4ff; border-color: #c7dffb; }
  .eq-inbox-chip-danger { color: #b21414; background: #fde8e8; border-color: #f6c6c6; }
  .eq-inbox-body {
    overflow-y: auto;
    padding: 0.6rem 0.8rem 1rem;
  }
  .eq-inbox-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.55rem;
  }
  .eq-inbox-item {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: 0.65rem;
    align-items: start;
    padding: 0.75rem 0.85rem;
    border: 1px solid #e2efe6;
    background: #fff;
    border-radius: 0.85rem;
  }
  .eq-inbox-item.is-defect { border-left: 4px solid #d97f1a; }
  .eq-inbox-item.is-return { border-left: 4px solid #2d6a45; }
  .eq-inbox-item-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: #f1f8f3; color: #2d6a45;
    display: flex; align-items: center; justify-content: center;
  }
  .eq-inbox-item.is-defect .eq-inbox-item-icon { background: #fff7e6; color: #b8590a; }
  .eq-inbox-item-icon svg { width: 18px; height: 18px; }
  .eq-inbox-item-main { min-width: 0; }
  .eq-inbox-item-title { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .eq-inbox-item-title strong { font-size: 0.95rem; color: #1a3d2a; }
  .eq-inbox-item-type {
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.1rem 0.55rem; border-radius: 999px;
    background: #eef6f1; color: #1a7a45;
  }
  .eq-inbox-item.is-defect .eq-inbox-item-type { background: #fff7e6; color: #b8590a; }
  .eq-inbox-item-sub { font-size: 0.8rem; color: #4b5563; display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.15rem; }
  .eq-inbox-item-note {
    font-size: 0.82rem; color: #1a3d2a; font-style: italic;
    background: #f7fbf8; border: 1px dashed #cfe5d8;
    padding: 0.35rem 0.55rem; border-radius: 0.5rem;
    margin-top: 0.35rem;
  }
  .eq-inbox-item-actions { display: flex; flex-direction: column; gap: 0.3rem; }
  .eq-inbox-btn {
    font-family: inherit; font-weight: 700; font-size: 0.8rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.55rem;
    border: 0; cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }
  .eq-inbox-btn-primary { background: #1a7a45; color: #fff; }
  .eq-inbox-btn-primary:hover { background: #156236; }
  .eq-inbox-btn-ghost { background: #f1f8f3; color: #1a7a45; border: 1px solid #cfe5d8; }
  .eq-inbox-btn-ghost:hover { background: #e2efe6; }
  .eq-inbox-empty {
    display: flex; align-items: center; gap: 0.55rem;
    padding: 1.1rem;
    color: #1a7a45;
    background: #f1f8f3;
    border: 1px dashed #cfe5d8;
    border-radius: 0.75rem;
    font-weight: 600;
    margin: 0.4rem 0.2rem;
  }
  .eq-inbox-empty svg { width: 20px; height: 20px; }
  @media (max-width: 640px) {
    .eq-inbox-item { grid-template-columns: 32px 1fr; }
    .eq-inbox-item-actions { grid-column: 1 / -1; flex-direction: row; }
    .eq-inbox-btn { flex: 1; }
  }

  .eq-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.65rem;
  }
  .eq-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.85rem 0.9rem;
    background: linear-gradient(135deg, #f7fbf8 0%, #eef6f1 100%);
    border: 1px solid #d9ead9;
    border-radius: 0.95rem;
    box-shadow: 0 2px 6px rgba(60,120,80,0.05);
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .eq-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(60,120,80,0.13);
    border-color: #b8d8c0;
  }
  .eq-card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    text-indent: -9999px;
    overflow: hidden;
    outline: none;
  }
  .eq-card-link:focus-visible {
    box-shadow: 0 0 0 3px rgba(61,169,115,0.35);
  }
  /* Interaktive Elemente ueber dem Stretched-Link halten */
  .eq-card-actions,
  .eq-assigned-toggle,
  .eq-assignee {
    position: relative;
    z-index: 2;
  }

  .eq-card-head {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .eq-card-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: linear-gradient(135deg, #3da973 0%, #2d8f55 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(45,143,85,0.28);
  }
  .eq-card-icon svg { width: 20px; height: 20px; color: #fff; }
  .eq-card-title {
    flex: 1;
    min-width: 0;
  }
  .eq-card-title strong {
    display: block;
    font-size: 0.95rem;
    color: #15301f;
    line-height: 1.25;
    word-break: normal;
    overflow-wrap: anywhere;
  }
  .eq-card-cat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #3da973;
    margin-top: 0.12rem;
  }
  .eq-card-cat svg { width: 12px; height: 12px; }

  .eq-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
  }
  .eq-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: #4b5563;
    background: #fff;
    border: 1px solid #e2efe6;
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    white-space: nowrap;
  }
  .eq-tag svg { width: 11px; height: 11px; }
  .eq-tag-cond-gut    { color: #1a7a45; background: #e6f4ec; border-color: #c5e8d2; }
  .eq-tag-cond-defekt { color: #b21414; background: #fde8e8; border-color: #f6c6c6; }
  .eq-tag-cond-andere { color: #92500a; background: #fff7e6; border-color: #fde2a8; }
  .eq-tag-qty   { color: #1a7a45; background: #e6f4ec; border-color: #c5e8d2; }

  .eq-card-assigned {
    display: flex;
    flex-wrap: wrap;
    gap: 0.28rem;
    margin-top: 0.15rem;
    width: 100%;
    min-width: 0;
  }
  .eq-card-assigned-label {
    width: 100%;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 0.1rem;
  }
  .eq-assigned-count {
    margin-left: 0.3rem;
    color: #9ca3af;
    font-weight: 600;
  }
  .eq-assignee-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.28rem;
    width: 100%;
    min-width: 0;
  }
  .eq-card-assigned.is-collapsible .eq-assignee-list {
    position: relative;
    max-height: 4.6rem; /* ~2 Reihen Chips */
    overflow: hidden;
    transition: max-height 0.25s ease;
  }
  .eq-card-assigned.is-collapsible.is-collapsed .eq-assignee-list::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 1.6rem;
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, #ffffff 90%);
    pointer-events: none;
  }
  .eq-card-assigned.is-collapsible:not(.is-collapsed) .eq-assignee-list {
    max-height: 9999px;
  }
  .eq-assigned-toggle {
    margin-top: 0.35rem;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: #f1f5f3;
    border: 1px solid #d6e3da;
    color: #1a7a45;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.12s, transform 0.1s;
  }
  .eq-assigned-toggle:hover { background: #e6f4ec; }
  .eq-assigned-toggle:active { transform: scale(0.97); }
  .eq-assigned-toggle svg { width: 12px; height: 12px; }
  .eq-card-assigned.is-collapsed .eq-assigned-toggle-less { display: none; }
  .eq-card-assigned:not(.is-collapsed) .eq-assigned-toggle-more { display: none; }
  .eq-assigned-toggle-more,
  .eq-assigned-toggle-less {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .eq-assignee {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: #eef6f1;
    border: 1px solid #cfe5d8;
    color: #1f4d33;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }
  .eq-assignee.is-holder { background: #f1ecfd; border-color: #d9ccfa; color: #4427a3; }
  .eq-assignee svg { width: 11px; height: 11px; flex-shrink: 0; }
  .eq-assignee-name {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .eq-assignee-qty { opacity: 0.7; font-weight: 500; flex-shrink: 0; }
  .eq-assignee-sn {
    flex-shrink: 0;
    max-width: 55%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 700;
    color: #1a7a45;
    background: #e6f4ec;
    border: 1px solid #c5e8d2;
    border-radius: 999px;
    padding: 0 0.45rem;
    font-size: 0.66rem;
    letter-spacing: 0.02em;
  }
  .eq-assignee.is-holder .eq-assignee-sn {
    color: #4427a3;
    background: #ede4fc;
    border-color: #d9ccfa;
  }

  .eq-card-actions {
    display: flex;
    gap: 0.35rem;
    margin-top: auto;
    flex-wrap: wrap;
  }
  .eq-action {
    flex: 1;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.42rem 0.6rem;
    border-radius: 0.55rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.14s, border-color 0.14s, transform 0.1s;
    white-space: nowrap;
  }
  .eq-action svg { width: 14px; height: 14px; }
  .eq-action-assign { background: #e6f4ec; color: #1a7a45; border-color: #c5e8d2; }
  .eq-action-assign:hover { background: #d3ecdc; transform: translateY(-1px); }
  .eq-action-edit   { background: #fff; color: #1b2e2b; border-color: #d4dfcf; }
  .eq-action-edit:hover { background: #f3f6f1; transform: translateY(-1px); }

  .eq-empty {
    padding: 2.4rem 1rem;
    text-align: center;
    color: #6b7280;
    background: #f9fafb;
    border: 1px dashed #d4dfcf;
    border-radius: 0.9rem;
  }
  .eq-empty svg { width: 38px; height: 38px; color: #cbd5d1; margin-bottom: 0.5rem; }
  .eq-empty p { margin: 0.3rem 0 0; font-size: 0.92rem; }

  /* MOBIL: kompakte Listen-Reihen statt Cards */
  @media (max-width: 640px) {
    .eq-grid {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .eq-card {
      padding: 0.55rem 0.65rem;
      gap: 0.4rem;
      border-radius: 0.7rem;
    }
    .eq-card-head { gap: 0.55rem; align-items: center; }
    .eq-card-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(45,143,85,0.22);
    }
    .eq-card-icon svg { width: 17px; height: 17px; }
    .eq-card-title strong { font-size: 0.9rem; line-height: 1.2; }
    .eq-card-cat { font-size: 0.6rem; margin-top: 0.05rem; }
    .eq-card-cat svg { width: 10px; height: 10px; }

    /* Tags & Aktionen in einer kompakten Zeile zusammenfassen */
    .eq-card-tags {
      gap: 0.25rem;
      padding-left: 42px; /* unter Titel ausrichten (Icon 32 + gap 10) */
    }
    .eq-tag {
      font-size: 0.65rem;
      padding: 0.05rem 0.45rem;
      gap: 0.22rem;
    }
    .eq-tag svg { width: 10px; height: 10px; }

    /* SN-Tag auf Mobil ausblenden (zu lang) */
    .eq-card-tags .eq-tag-sn { display: none; }

    .eq-card-actions {
      gap: 0.3rem;
      padding-left: 42px;
    }
    .eq-action {
      font-size: 0.72rem;
      padding: 0.32rem 0.5rem;
      gap: 0.22rem;
      border-radius: 0.45rem;
    }
    .eq-action svg { width: 12px; height: 12px; }
  }

  /* ── Mitglieder-Übersicht ─────────────────────────────────────── */
  .eq-section-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
    margin: 1.4rem 0 0.55rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .eq-section-title svg { width: 14px; height: 14px; color: #94a3b8; }

  /* Aufklappbare Sektionen */
  .eq-collapse { display: block; }
  .eq-collapse > summary { list-style: none; cursor: pointer; user-select: none; }
  .eq-collapse > summary::-webkit-details-marker { display: none; }
  .eq-collapse-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    transition: background 0.15s, border-color 0.15s;
  }
  .eq-collapse-summary:hover { background: #f1f5f9; border-color: #cbd5e1; }
  .eq-collapse-chev {
    width: 14px; height: 14px;
    color: #94a3b8;
    margin-left: auto;
    transition: transform 0.22s ease;
  }
  .eq-collapse[open] > summary .eq-collapse-chev { transform: rotate(180deg); }

  .users-grid {
    list-style: none;
    margin: 0 0 0.5rem 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.55rem;
  }
  @media (max-width: 480px) {
    .users-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.45rem; }
  }
  @media (max-width: 340px) {
    .users-grid { grid-template-columns: 1fr; }
  }

  .user-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 0.55rem;
    background: linear-gradient(135deg, #ffffff 0%, #f3faf6 100%);
    border: 1px solid #d9ead9;
    border-radius: 0.85rem;
    box-shadow: 0 2px 6px rgba(60,120,80,0.04);
    cursor: pointer;
    transition: transform 0.16s, box-shadow 0.16s, border-color 0.16s;
    text-align: center;
    color: inherit;
    font: inherit;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }
  .user-tile:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(60,120,80,0.14);
    border-color: #b8d8c0;
  }
  .user-tile-avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3da973 0%, #2d8f55 100%);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(45,143,85,0.22);
  }
  .user-tile-avatar img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .user-tile-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #15301f;
    line-height: 1.25;
    word-break: normal;
    overflow-wrap: anywhere;
  }
  .user-tile-count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: #1a7a45;
    background: #e6f4ec;
    border: 1px solid #c5e8d2;
    border-radius: 999px;
    padding: 0.12rem 0.55rem;
  }
  /* Holder-Tiles (Lagerort / Fahrzeug) */
  .holder-tile-avatar {
    background: linear-gradient(135deg, #6b7c93 0%, #4a5a6f 100%) !important;
    box-shadow: 0 3px 10px rgba(74,90,111,0.25) !important;
  }
  .holder-tile-avatar svg { width: 26px; height: 26px; color: #fff; }
  .holder-tile[data-holder-type="vehicle"] .holder-tile-avatar {
    background: linear-gradient(135deg, #d97757 0%, #b15a3b 100%) !important;
    box-shadow: 0 3px 10px rgba(177,90,59,0.25) !important;
  }
  .user-tile-count svg { width: 11px; height: 11px; }

  /* ── Modal mit Puppe ──────────────────────────────────────────── */
  .ueq-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 28, 22, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .ueq-modal-backdrop.open { display: flex; opacity: 1; }
  .ueq-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: none;
    box-shadow: 0 16px 40px rgba(10, 30, 20, 0.35), 0 6px 18px rgba(10, 30, 20, 0.18);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: auto;
    max-height: calc(100dvh - 1.5rem);
    transform: translateY(12px) scale(0.985);
    opacity: 0;
    transition: transform 0.28s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.22s ease;
    will-change: transform, opacity;
  }
  .ueq-modal-backdrop.open .ueq-modal { transform: translateY(0) scale(1); opacity: 1; }
  .ueq-modal.dragging { transition: none; }
  .ueq-modal.closing { transform: translateY(12px) scale(0.985); opacity: 0; }

  /* ── Desktop: groesseres zentriertes Fenster ──────────────────── */
  @media (min-width: 769px) {
    .ueq-modal-backdrop { padding: 2rem 1.5rem; }
    .ueq-modal {
      width: min(1100px, 100%);
      max-height: 90vh;
      border-radius: 20px;
      box-shadow: 0 28px 70px rgba(10, 30, 20, 0.4), 0 10px 26px rgba(10, 30, 20, 0.22);
    }
    .ueq-modal-head { cursor: default; touch-action: auto; }
    .ueq-modal-head .drag-handle { display: none; }
    .ueq-modal-head { padding: 1.25rem 1.5rem 1.1rem !important; }
  }
  @media (max-width: 768px) {
    .ueq-modal-head .drag-handle { display: none; }
    .ueq-modal-head {
      padding-top: 1rem;
      cursor: default;
      touch-action: auto;
    }
  }

  .ueq-modal-head {
    position: relative;
    padding: calc(env(safe-area-inset-top, 0px) + 1.2rem) 1.1rem 1rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    overflow: hidden;
    touch-action: none;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    flex-shrink: 0;
  }
  .ueq-modal-head:active { cursor: grabbing; }
  .ueq-modal-head .drag-handle {
    position: absolute;
    top: calc(env(safe-area-inset-top, 0px) + 0.45rem);
    left: 50%;
    transform: translateX(-50%);
    width: 42px; height: 4px;
    background: rgba(255,255,255,0.55);
    border-radius: 999px;
    z-index: 2;
  }
  .ueq-modal-head::before {
    content: '';
    position: absolute;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle, #a8f4d2 0%, transparent 70%);
    opacity: 0.32;
    filter: blur(30px);
    top: -60px; right: -40px;
    pointer-events: none;
  }
  .ueq-modal-head::after {
    content: '';
    position: absolute;
    left: 1rem; right: 1rem; top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.5), rgba(255,255,255,0.02));
    pointer-events: none;
  }
  .ueq-modal-head > * { position: relative; z-index: 1; }
  .ueq-modal-head .avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.16);
    border: 2px solid rgba(255,255,255,0.45);
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800;
    font-size: 0.95rem;
    flex-shrink: 0;
  }
  .ueq-modal-head .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .ueq-modal-head .info { flex: 1; min-width: 0; }
  .ueq-modal-head .info strong {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.3px;
    line-height: 1.2;
    text-shadow: 0 2px 8px rgba(0,0,0,0.18);
    word-break: normal;
    overflow-wrap: anywhere;
  }
  .ueq-modal-head .info span {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
    margin-top: 0.1rem;
  }
  .ueq-modal-close {
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.28);
    color: #fff;
    width: 34px; height: 34px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.05rem;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.1s;
  }
  .ueq-modal-close:hover { background: rgba(255,255,255,0.3); }
  .ueq-modal-close:active { transform: scale(0.94); }

  .ueq-modal-body {
    padding: 1rem 1rem calc(env(safe-area-inset-bottom, 0px) + 1.2rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    flex: 1;
    display: grid;
    grid-template-columns: minmax(260px, 320px) 1fr;
    gap: 1.5rem;
    align-items: start;
    justify-items: center;
    background:
      radial-gradient(ellipse at top, #f4faf6 0%, transparent 60%),
      #ffffff;
  }
  @media (min-width: 769px) {
    .ueq-modal-body {
      padding: 1.5rem 1.75rem 1.75rem;
      grid-template-columns: minmax(280px, 340px) 1fr;
      gap: 2rem;
      column-gap: 2rem;
    }
    .ueq-modal-body > .ueq-puppet-wrap {
      position: sticky;
      top: 0;
      padding-right: 1.5rem;
      border-right: 1px solid #eaf0eb;
    }
  }
  @media (max-width: 768px) {
    .ueq-modal-body { grid-template-columns: 1fr; justify-items: stretch; gap: 1rem; }
    .ueq-puppet-wrap { justify-self: center; max-width: 280px; }
  }

  /* Holder-Ansicht (Lager/Fahrzeug) hat keine Puppe -> volle Breite fuer Items */
  .ueq-modal-body.is-holder-view {
    grid-template-columns: 1fr !important;
    justify-items: stretch;
  }
  .ueq-modal-body.is-holder-view > .ueq-puppet-wrap {
    display: none !important;
    border-right: none !important;
    padding-right: 0 !important;
  }

  .ueq-puppet-wrap {
    position: relative;
    display: inline-block;
    width: 100%;
    max-width: 360px;
    margin: 0 auto;
  }
  @media (max-width: 600px) {
    .ueq-puppet-wrap { max-width: 320px; }
  }
  .ueq-puppet-wrap img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
    user-select: none;
  }
  .ueq-dot {
    position: absolute;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: rgba(150, 150, 150, 0.45);
    border: 2px solid #fff;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    transform: translate(-50%, -50%);
    pointer-events: none;
    transition: transform 0.15s, box-shadow 0.15s;
    display: none;
  }
  .ueq-dot.equipped {
    display: block;
    background: radial-gradient(circle at 35% 30%, #5cd590 0%, #2d8f55 100%);
    box-shadow: 0 0 0 3px rgba(61,169,115,0.25), 0 2px 6px rgba(0,0,0,0.25);
    cursor: pointer;
    pointer-events: auto;
  }
  .ueq-dot.equipped:hover,
  .ueq-dot.equipped:focus {
    transform: translate(-50%, -50%) scale(1.25);
    box-shadow: 0 0 0 5px rgba(61,169,115,0.3), 0 2px 10px rgba(61,169,115,0.45);
    outline: none;
  }
  .ueq-dot.active {
    transform: translate(-50%, -50%) scale(1.4);
    background: #1a7a45;
    box-shadow: 0 0 0 6px rgba(61,169,115,0.35), 0 0 18px rgba(61,169,115,0.55);
    z-index: 2;
  }
  /* Positionen wie in profil.ejs */
  .ueq-dot[data-slot="head"]      { left: 50%; top: 10%; }
  .ueq-dot[data-slot="neck"]      { left: 50%; top: 19%; }
  .ueq-dot[data-slot="torso"]     { left: 50%; top: 33%; }
  .ueq-dot[data-slot="handLeft"]  { left: 28%; top: 46%; }
  .ueq-dot[data-slot="handRight"] { left: 68%; top: 46%; }
  .ueq-dot[data-slot="legs"]      { left: 50%; top: 65%; }
  .ueq-dot[data-slot="feet"]      { left: 50%; top: 88%; }

  .ueq-items {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
  }
  .ueq-items-wrap { width: 100%; min-width: 0; }
  .ueq-filter {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0.6rem;
  }
  .ueq-filter[hidden] { display: none; }
  .ueq-filter-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ueq-filter-input-wrap > svg {
    position: absolute;
    left: 0.7rem;
    width: 16px; height: 16px;
    color: #6b8a76;
    pointer-events: none;
  }
  .ueq-filter-input {
    flex: 1;
    padding: 0.55rem 2.2rem 0.55rem 2.2rem;
    border: 1px solid #cfe5d8;
    border-radius: 999px;
    background: #fff;
    font-size: 0.92rem;
    font-family: inherit;
    color: #1a3d2a;
    transition: border-color 0.18s, box-shadow 0.18s;
    width: 100%;
  }
  .ueq-filter-input:focus {
    outline: none;
    border-color: #3da973;
    box-shadow: 0 0 0 3px rgba(61,169,115,0.18);
  }
  .ueq-filter-clear {
    position: absolute;
    right: 0.45rem;
    width: 24px; height: 24px;
    border: none;
    border-radius: 50%;
    background: #e2efe6;
    color: #1a3d2a;
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .ueq-filter-clear:hover { background: #cfe5d8; }
  .ueq-filter-meta {
    font-size: 0.74rem;
    color: #6b8a76;
    padding: 0 0.4rem;
    min-height: 1.1em;
  }
  .ueq-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    background: #f8fbf6;
    border: 1px solid #e2efe6;
    border-radius: 11px;
    transition: background 0.18s, border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  }
  .ueq-item:hover {
    background: #f1f7f3;
    border-color: #cfe5d8;
  }
  .ueq-item.highlight {
    background: #e6f4ec;
    border-color: #3da973;
    box-shadow: 0 0 0 3px rgba(61,169,115,0.18);
  }
  @media (min-width: 769px) {
    .ueq-items {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 0.55rem;
    }
    .ueq-item { padding: 0.7rem 0.85rem; }
  }
  .ueq-item-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid #e2efe6;
    color: #3da973;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ueq-item-icon svg { width: 17px; height: 17px; }
  .ueq-item-body { flex: 1; min-width: 0; }
  .ueq-item-body strong {
    display: block;
    font-size: 0.88rem;
    color: #15301f;
    word-break: normal;
    overflow-wrap: anywhere;
    line-height: 1.2;
  }
  .ueq-item-body small {
    font-size: 0.72rem;
    color: #6b7280;
  }
  .ueq-item-qty {
    font-size: 0.7rem;
    font-weight: 700;
    color: #1a7a45;
    background: #e6f4ec;
    border: 1px solid #c5e8d2;
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
    flex-shrink: 0;
  }
  .ueq-empty-list {
    color: #9ca3af;
    font-size: 0.85rem;
    text-align: center;
    padding: 1rem;
  }

  @media (max-width: 380px) {
    .eq-toolbar { flex-direction: column; }
    .eq-toolbar button, .eq-toolbar a.eq-reset { width: 100%; }
    .eq-card-tags, .eq-card-actions { padding-left: 0; }
  }

  /* ── Hero Header (Strikeboard-Style) ────────────────────────── */
  .page-hero {
    position: relative;
    padding: 1.4rem 1.5rem 1.4rem 1.5rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    border-radius: 1.35rem 1.35rem 2rem 2rem;
    margin: -0.55rem -0.25rem 1.6rem;
    overflow: visible;
    border: 1px solid rgba(160, 212, 183, 0.42);
    box-shadow: 0 15px 34px rgba(18, 66, 43, 0.34), 0 4px 12px rgba(0, 0, 0, 0.1);
    animation: pageHeroFade 0.7s cubic-bezier(.4,0,0,1.12);
  }
  @keyframes pageHeroFade {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-hero-clip {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .page-hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.36;
    filter: blur(36px);
  }
  .page-hero-orb-1 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #a8f4d2 0%, transparent 70%);
    top: -50px; right: -30px;
  }
  .page-hero-orb-2 {
    width: 140px; height: 140px;
    background: radial-gradient(circle, #b8e8ff 0%, transparent 70%);
    bottom: -30px; left: 8%;
  }
  .page-hero::after {
    content: '';
    position: absolute;
    left: 1.2rem; right: 1.2rem; top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.55), rgba(255,255,255,0.02));
    pointer-events: none;
    z-index: 2;
  }
  .page-hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .page-hero-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .page-hero-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }
  .page-hero-title {
    font-size: 1.85rem;
    font-weight: 900;
    margin: 0;
    letter-spacing: -0.8px;
    line-height: 1.1;
    color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.18);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .page-hero-title svg {
    width: 26px; height: 26px;
    flex-shrink: 0;
    opacity: 0.92;
  }
  .page-hero-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .page-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.18);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 2em;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    -webkit-tap-highlight-color: transparent;
    white-space: nowrap;
  }
  .page-hero-btn:hover {
    background: rgba(255,255,255,0.28);
    box-shadow: 0 10px 26px rgba(0,0,0,0.2);
    transform: translateY(-1px);
    color: #fff;
  }
  .page-hero-btn:active { transform: scale(0.96); }
  .page-hero-btn.primary {
    background: #fff;
    color: #1a7a45;
    border-color: rgba(255,255,255,0.6);
  }
  .page-hero-btn.primary:hover { background: #f0fff7; color: #145d34; }
  .page-hero-btn.ghost {
    background: transparent;
    border-color: rgba(255,255,255,0.4);
  }
  .page-hero-btn svg { width: 14px; height: 14px; }
  .page-hero-btn.has-badge {
    background: linear-gradient(135deg, #ffb547 0%, #ff7a45 100%);
    color: #fff;
    border-color: rgba(255,255,255,0.65);
    animation: heroBtnPulse 2.4s ease-in-out infinite;
  }
  .page-hero-btn.has-badge:hover { color: #fff; background: linear-gradient(135deg, #ffa224, #ff5e22); }
  .page-hero-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    margin-left: 0.15rem;
    border-radius: 999px;
    background: #fff;
    color: #b8590a;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
  }
  @keyframes heroBtnPulse {
    0%, 100% { box-shadow: 0 6px 18px rgba(255, 122, 69, 0.45); }
    50%      { box-shadow: 0 6px 24px rgba(255, 122, 69, 0.75); }
  }
  .show-on-mobile { display: none !important; }
  @media (max-width: 640px) {
    .hide-on-mobile { display: none !important; }
    .show-on-mobile { display: inline-flex !important; }
  }

  /* Zeugwart-Sheet (Mobile) */
  .eq-sheet-backdrop {
    position: fixed; inset: 0;
    background: rgba(15,28,22,0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1100;
    display: none;
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .eq-sheet-backdrop.open { display: block; opacity: 1; }
  .eq-sheet {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    background: #fff;
    border-radius: 1.4rem 1.4rem 0 0;
    padding: 0.6rem 0.9rem 1.4rem;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.22,0.61,0.36,1);
    box-shadow: 0 -8px 32px rgba(10,30,20,0.3);
    max-height: 85dvh;
    overflow-y: auto;
  }
  .eq-sheet-backdrop.open .eq-sheet { transform: translateY(0); }
  .eq-sheet-handle {
    width: 44px; height: 5px;
    border-radius: 999px;
    background: #d1e0d6;
    margin: 0.4rem auto 0.85rem;
  }
  .eq-sheet-title {
    font-size: 0.78rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: #6b7c70;
    padding: 0 0.35rem 0.5rem;
  }
  .eq-sheet-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .eq-sheet-item {
    display: flex; align-items: center; gap: 0.75rem;
    width: 100%;
    padding: 0.8rem 0.85rem;
    background: #f7fbf8;
    border: 1px solid #e2efe6;
    border-radius: 0.85rem;
    color: #1a3d2a;
    text-decoration: none;
    font-weight: 700; font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: background 0.18s, border-color 0.18s;
  }
  .eq-sheet-item:hover, .eq-sheet-item:active {
    background: #eef6f1; border-color: #cfe5d8;
  }
  .eq-sheet-item-icon {
    width: 34px; height: 34px;
    background: #fff; border: 1px solid #cfe5d8;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #1a7a45; flex-shrink: 0;
  }
  .eq-sheet-item-icon svg { width: 18px; height: 18px; }
  .eq-sheet-item-text { flex: 1; min-width: 0; }
  .eq-sheet-item-sub { font-size: 0.75rem; font-weight: 600; color: #6b7c70; }
  .eq-sheet-badge {
    background: #ff7a45; color: #fff;
    font-size: 0.75rem; font-weight: 800;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  @media (max-width: 640px) {
    .page-hero { padding: 1.1rem 1.1rem; border-radius: 1.1rem 1.1rem 1.6rem 1.6rem; margin-bottom: 1.2rem; }
    .page-hero-content { flex-direction: column; align-items: stretch; gap: 0.85rem; }
    .page-hero-title { font-size: 1.45rem; }
    .page-hero-title svg { width: 22px; height: 22px; }
    .page-hero-actions { width: 100%; }
    .page-hero-btn { flex: 1 1 auto; justify-content: center; padding: 0.55rem 0.7rem; font-size: 0.82rem; }
  }
  @media (max-width: 380px) {
    .page-hero-actions { flex-direction: column; }
    .page-hero-btn { width: 100%; }
  }
</style>

<main class="apple-dashboard">
  <header class="page-hero">
    <div class="page-hero-clip">
      <div class="page-hero-orb page-hero-orb-1"></div>
      <div class="page-hero-orb page-hero-orb-2"></div>
    </div>
    <div class="page-hero-content">
      <div class="page-hero-title-wrap">
        <span class="page-hero-kicker">Equipment-Verwaltung</span>
        <h1 class="page-hero-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          Zeugwart
        </h1>
      </div>
      <div class="page-hero-actions">
        <button type="button" id="eqInboxBtn" class="page-hero-btn<%= (typeof inboxCounts !== 'undefined' && inboxCounts.total > 0) ? ' has-badge' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          Aufgaben
          <% if (typeof inboxCounts !== 'undefined' && inboxCounts.total > 0) { %>
            <span class="page-hero-badge"><%= inboxCounts.total %></span>
          <% } %>
        </button>
        <button type="button" id="eqStatsBtn" class="page-hero-btn hide-on-mobile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Statistik
        </button>
        <a href="/equipment/todos" class="page-hero-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          To-dos
        </a>
        <button type="button" id="qrScanBtn" class="page-hero-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3z"/><path d="M20 14v3"/><path d="M14 20h3"/><path d="M17 17h.01"/><path d="M20 20h.01"/></svg>
          Scannen
        </button>
        <a href="/equipment/add" class="page-hero-btn primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Neu
        </a>
        <a href="/equipment/categories" class="page-hero-btn hide-on-mobile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          Kategorien
        </a>
        <a href="/dashboard" class="page-hero-btn ghost hide-on-mobile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Zurück
        </a>
        <button type="button" id="eqMenuBtn" class="page-hero-btn show-on-mobile" aria-label="Mehr">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          Mehr
        </button>
      </div>
    </div>
  </header>

  <% if (success) { %>
    <div class="apple-alert alert-success" style="margin-bottom: 16px;"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="apple-alert alert-error" style="margin-bottom: 16px;"><%= error %></div>
  <% } %>

  <!-- Toolbar -->
  <form method="GET" action="/equipment" class="eq-toolbar">
    <input
      type="text"
      name="search"
      placeholder="Suchen…"
      value="<%= search %>"
      class="eq-search"
    />
    <select name="category" class="eq-cat">
      <option value="">Alle Kategorien</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat.id %>" <%= selectedCategory == cat.id ? 'selected' : '' %>>
          <%= cat.name %>
        </option>
      <% }) %>
    </select>
    <button type="submit" class="dev-btn-primary">Filter</button>
    <% if (search || selectedCategory) { %>
      <a href="/equipment" class="dev-btn-secondary eq-reset">Reset</a>
    <% } %>
  </form>

  <div class="eq-meta"><strong><%= equipment.length %></strong> Equipment-Einträge</div>

  <% if (typeof equipmentStats !== 'undefined' && equipmentStats) { %>
    <% const _entries = equipmentStats.totalEntries;
       const _pct = _entries > 0 ? Math.round((equipmentStats.assignedEntries / _entries) * 100) : 0; %>
    <div class="eq-stats-modal-backdrop" id="eqStatsModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="eqStatsTitle">
      <div class="eq-stats-modal" role="document">
        <div class="eq-stats-modal-head">
          <h2 class="eq-stats-modal-title" id="eqStatsTitle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Statistik
          </h2>
          <button type="button" class="eq-stats-modal-close" id="eqStatsClose" aria-label="Schliessen">&times;</button>
        </div>
        <section class="eq-stats" aria-label="Equipment-Statistik">
          <div class="eq-stat" data-tone="primary">
            <span class="eq-stat-label">Einträge</span>
            <span class="eq-stat-val"><%= equipmentStats.totalEntries %></span>
            <span class="eq-stat-sub"><%= equipmentStats.totalPieces %> Stück gesamt</span>
          </div>
          <div class="eq-stat" data-tone="warn">
            <span class="eq-stat-label">Zugewiesen</span>
            <span class="eq-stat-val"><%= equipmentStats.assignedEntries %></span>
            <span class="eq-stat-sub"><%= _pct %>% der Einträge</span>
          </div>
          <div class="eq-stat" data-tone="ok">
            <span class="eq-stat-label">Ohne Zuweisung</span>
            <span class="eq-stat-val"><%= equipmentStats.freeEntries %></span>
            <span class="eq-stat-sub">Einträge frei</span>
          </div>
          <div class="eq-stat">
            <span class="eq-stat-label">Stück ausgegeben</span>
            <span class="eq-stat-val"><%= equipmentStats.assignedPieces %></span>
            <span class="eq-stat-sub">Summe Zuweisungs-Mengen</span>
          </div>
          <div class="eq-stat">
            <span class="eq-stat-label">Kategorien</span>
            <span class="eq-stat-val"><%= equipmentStats.categoriesCount %></span>
            <span class="eq-stat-sub">aktiv</span>
          </div>
          <div class="eq-stat">
            <span class="eq-stat-label">Mitglieder</span>
            <span class="eq-stat-val"><%= equipmentStats.membersWithEquipment %></span>
            <span class="eq-stat-sub">mit Equipment</span>
          </div>
          <div class="eq-stat">
            <span class="eq-stat-label">Lagerorte</span>
            <span class="eq-stat-val"><%= equipmentStats.holdersInUse %></span>
            <span class="eq-stat-sub">in Nutzung</span>
          </div>
        </section>
      </div>
    </div>
  <% } %>

  <!-- Inbox-Modal: offene Anfragen + Langzeit-Ausgaben -->
  <% if (typeof inboxCounts !== 'undefined') { %>
    <div class="eq-inbox-backdrop" id="eqInboxModal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="eqInboxTitle">
      <div class="eq-inbox-modal" role="document">
        <div class="eq-inbox-head">
          <h2 class="eq-inbox-title" id="eqInboxTitle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            Aufgaben-Inbox
          </h2>
          <button type="button" class="eq-inbox-close" id="eqInboxClose" aria-label="Schliessen">&times;</button>
        </div>
        <div class="eq-inbox-summary">
          <span class="eq-inbox-chip eq-inbox-chip-warn">
            <span class="eq-inbox-dot"></span>
            <%= inboxCounts.defect %> Defekt-Meldung<%= inboxCounts.defect === 1 ? '' : 'en' %>
          </span>
          <span class="eq-inbox-chip eq-inbox-chip-info">
            <span class="eq-inbox-dot"></span>
            <%= inboxCounts.return %> Rückgabe<%= inboxCounts.return === 1 ? '' : 'n' %> angemeldet
          </span>
          <span class="eq-inbox-chip eq-inbox-chip-danger">
            <span class="eq-inbox-dot"></span>
            <%= inboxCounts.longOut %> Teile &gt; 90 Tage nicht zurück
          </span>
        </div>

        <div class="eq-inbox-body">
          <% if (inboxRequests && inboxRequests.length) { %>
            <ul class="eq-inbox-list">
              <% inboxRequests.forEach(r => {
                   const isDefect = r.type === 'defect';
                   const personName = r.full_name || r.username || 'Unbekannt';
                   const created = r.created_at ? new Date(r.created_at).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
              %>
                <li class="eq-inbox-item <%= isDefect ? 'is-defect' : 'is-return' %>">
                  <div class="eq-inbox-item-icon">
                    <% if (isDefect) { %>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <% } else { %>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
                    <% } %>
                  </div>
                  <div class="eq-inbox-item-main">
                    <div class="eq-inbox-item-title">
                      <strong><%= r.equipment_name || '—' %></strong>
                      <span class="eq-inbox-item-type"><%= isDefect ? 'Defekt' : 'Rückgabe' %></span>
                    </div>
                    <div class="eq-inbox-item-sub">
                      <span><%= personName %></span>
                      <% if (r.serial_number) { %><span>· SN: <%= r.serial_number %></span><% } %>
                      <% if (created) { %><span>· <%= created %></span><% } %>
                    </div>
                    <% if (r.note) { %>
                      <div class="eq-inbox-item-note">„<%= r.note %>"</div>
                    <% } %>
                  </div>
                  <div class="eq-inbox-item-actions">
                    <form method="post" action="/equipment/request/<%= r.id %>/resolve" style="display:inline-flex; gap:0.35rem;">
                      <button type="submit" name="action" value="done" class="eq-inbox-btn eq-inbox-btn-primary">Erledigt</button>
                      <button type="submit" name="action" value="reject" class="eq-inbox-btn eq-inbox-btn-ghost" title="Anfrage ablehnen">Ablehnen</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <div class="eq-inbox-empty">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Keine offenen Anfragen — alles sauber!</span>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Zeugwart-Sheet (Mobile-Menue) -->
  <div class="eq-sheet-backdrop" id="eqSheetBackdrop" aria-hidden="true">
    <div class="eq-sheet" role="dialog" aria-modal="true" aria-label="Zeugwart-Menü">
      <div class="eq-sheet-handle" aria-hidden="true"></div>
      <div class="eq-sheet-title">Zeugwart</div>
      <ul class="eq-sheet-list">
        <li>
          <button type="button" class="eq-sheet-item" data-sheet-action="inbox">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Aufgaben
              <span class="eq-sheet-item-sub">Defekte, Rückgaben, Langzeit-Ausgaben</span>
            </span>
            <% if (typeof inboxCounts !== 'undefined' && inboxCounts.total > 0) { %>
              <span class="eq-sheet-badge"><%= inboxCounts.total %></span>
            <% } %>
          </button>
        </li>
        <li>
          <button type="button" class="eq-sheet-item" data-sheet-action="stats">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Statistik
              <span class="eq-sheet-item-sub">Bestand, Zugewiesen, Frei</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="eq-sheet-item" data-sheet-action="scan">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3z"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Scannen
              <span class="eq-sheet-item-sub">QR / Seriennummer</span>
            </span>
          </button>
        </li>
        <li>
          <a href="/equipment/add" class="eq-sheet-item">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Neues Equipment
              <span class="eq-sheet-item-sub">Eintrag anlegen</span>
            </span>
          </a>
        </li>
        <li>
          <a href="/equipment/categories" class="eq-sheet-item">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Kategorien
              <span class="eq-sheet-item-sub">Verwalten</span>
            </span>
          </a>
        </li>
        <li>
          <a href="/dashboard" class="eq-sheet-item">
            <span class="eq-sheet-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            </span>
            <span class="eq-sheet-item-text">
              Zurück
              <span class="eq-sheet-item-sub">Dashboard</span>
            </span>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <% if (usersWithEquipment && usersWithEquipment.length) { %>
    <details class="eq-collapse" open>
    <summary class="eq-section-title eq-collapse-summary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
      Wer hat was? (<%= usersWithEquipment.length %>)
      <svg class="eq-collapse-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <ul class="users-grid">
      <% usersWithEquipment.forEach(u => {
           const displayName = u.full_name || u.username;
           const initials = (displayName || '?').split(/\s+/).map(s => s[0]).filter(Boolean).slice(0,2).join('').toUpperCase();
      %>
        <li>
          <button type="button" class="user-tile" data-user-id="<%= u.id %>">
            <span class="user-tile-avatar">
              <%= initials || '?' %>
            </span>
            <span class="user-tile-name"><%= displayName %></span>
            <span class="user-tile-count">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <%= u.count %>
            </span>
          </button>
        </li>
      <% }) %>
    </ul>
    <script type="application/json" id="users-equipment-data">
      <%- JSON.stringify(usersWithEquipment).replace(/<\/script/gi, '<\\/script') %>
    </script>
    </details>
  <% } %>

  <% if (typeof holdersWithEquipment !== 'undefined' && holdersWithEquipment && holdersWithEquipment.length) { %>
    <details class="eq-collapse" open>
    <summary class="eq-section-title eq-collapse-summary" style="margin-top: 1.2rem;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Lagerorte &amp; Fahrzeuge (<%= holdersWithEquipment.length %>)
      <svg class="eq-collapse-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <ul class="users-grid">
      <% holdersWithEquipment.forEach(h => {
           const isVehicle = h.holder_type === 'vehicle';
           const iconSvg = isVehicle
             ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h2l1.5-7h11L19 17h2"/><circle cx="7.5" cy="17.5" r="1.7"/><circle cx="16.5" cy="17.5" r="1.7"/></svg>'
             : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>';
      %>
        <li>
          <button type="button" class="user-tile holder-tile" data-holder-id="<%= h.id %>" data-holder-type="<%= h.holder_type %>">
            <span class="user-tile-avatar holder-tile-avatar">
              <%- iconSvg %>
            </span>
            <span class="user-tile-name"><%= h.name %></span>
            <span class="user-tile-count">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <%= h.count %>
            </span>
          </button>
        </li>
      <% }) %>
    </ul>
    <script type="application/json" id="holders-equipment-data">
      <%- JSON.stringify(holdersWithEquipment).replace(/<\/script/gi, '<\\/script') %>
    </script>
    </details>
  <% } %>


  <details class="eq-collapse" open>
  <summary class="eq-section-title eq-collapse-summary" style="margin-top: 1.4rem;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
    Alle Einträge<% if (equipment && equipment.length) { %> (<%= equipment.length %>)<% } %>
    <svg class="eq-collapse-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
  </summary>

  <% if (equipment.length === 0) { %>
    <div class="eq-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      <p>Kein Equipment gefunden</p>
    </div>
  <% } else { %>
    <ul class="eq-grid">
      <% equipment.forEach(item => { %>
        <li class="eq-card">
          <a class="eq-card-link" href="/equipment/<%= item.id %>/assign" aria-label="Zuweisungen von <%= item.name %> ansehen">Zuweisungen ansehen</a>
          <div class="eq-card-head">
            <div class="eq-card-icon">
              <% if (item.category_icon_svg) { %>
                <%- item.category_icon_svg %>
              <% } else { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <% } %>
            </div>
            <div class="eq-card-title">
              <strong><%= item.name %></strong>
              <% if (item.category_name) { %>
                <span class="eq-card-cat">
                  <%- item.category_icon_svg %>
                  <%= item.category_name %>
                </span>
              <% } %>
            </div>
          </div>

          <div class="eq-card-tags">
            <%
              const condClass = item.condition === 'gut' ? 'eq-tag-cond-gut'
                              : item.condition === 'defekt' ? 'eq-tag-cond-defekt'
                              : 'eq-tag-cond-andere';
            %>
            <span class="eq-tag <%= condClass %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <%= item.condition %>
            </span>
            <span class="eq-tag eq-tag-qty">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              <%= item.assigned_count %>/<%= item.quantity %>
            </span>
            <% if (item.serial_number) { %>
              <span class="eq-tag eq-tag-sn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 8h.01M11 8h.01M15 8h.01M7 12h10M7 16h6"/></svg>
                SN: <%= item.serial_number %>
              </span>
            <% } %>
          </div>

          <% if (item.assignments && item.assignments.length > 0) { %>
            <% const _assignCount = item.assignments.length; const _collapsible = _assignCount > 6; %>
            <div class="eq-card-assigned <%= _collapsible ? 'is-collapsible is-collapsed' : '' %>" data-assigned-wrap>
              <span class="eq-card-assigned-label">
                Zugewiesen an
                <span class="eq-assigned-count">(<%= _assignCount %>)</span>
              </span>
              <div class="eq-assignee-list" data-assignee-list>
              <% item.assignments.forEach(a => { %>
                <span class="eq-assignee <%= a.kind === 'holder' ? 'is-holder' : '' %>" title="<%= a.name %>">
                  <% if (a.kind === 'holder') { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V8l7-5 7 5v13"/><path d="M10 21v-6h4v6"/></svg>
                  <% } else { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <% } %>
                  <span class="eq-assignee-name"><%= a.name || '—' %></span>
                  <% if (a.serial_number) { %><span class="eq-assignee-sn">#<%= a.serial_number %></span><% } %>
                  <% if (a.quantity && a.quantity > 1) { %><span class="eq-assignee-qty">×<%= a.quantity %></span><% } %>
                </span>
              <% }) %>
              </div>
              <% if (_collapsible) { %>
                <button type="button" class="eq-assigned-toggle" data-assigned-toggle aria-expanded="false">
                  <span class="eq-assigned-toggle-more">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    Alle <%= _assignCount %> anzeigen
                  </span>
                  <span class="eq-assigned-toggle-less">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                    Einklappen
                  </span>
                </button>
              <% } %>
            </div>
          <% } %>

          <div class="eq-card-actions">
            <a href="/equipment/<%= item.id %>/assign" class="eq-action eq-action-assign">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              Zuweisen
            </a>
            <a href="/equipment/<%= item.id %>/edit" class="eq-action eq-action-edit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
              Bearbeiten
            </a>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
  </details>

  <!-- Modal: Equipment pro Mitglied -->
  <div class="ueq-modal-backdrop" id="ueqModal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="ueq-modal" role="document">
      <div class="ueq-modal-head">
        <span class="drag-handle" aria-hidden="true"></span>
        <span class="avatar" id="ueqAvatar"></span>
        <div class="info">
          <strong id="ueqName">—</strong>
          <span id="ueqCount">0 Items</span>
        </div>
        <button type="button" class="ueq-modal-close" id="ueqClose" aria-label="Schließen">✕</button>
      </div>
      <div class="ueq-modal-body">
        <div class="ueq-puppet-wrap">
          <img src="/puppe.png" alt="Equipment-Visualisierung">
          <div class="ueq-dot" data-slot="head"      title="Kopf"></div>
          <div class="ueq-dot" data-slot="neck"      title="Hals"></div>
          <div class="ueq-dot" data-slot="torso"     title="Oberkörper"></div>
          <div class="ueq-dot" data-slot="handLeft"  title="Linke Hand"></div>
          <div class="ueq-dot" data-slot="handRight" title="Rechte Hand"></div>
          <div class="ueq-dot" data-slot="legs"      title="Beine"></div>
          <div class="ueq-dot" data-slot="feet"      title="Füße"></div>
        </div>
        <div class="ueq-items-wrap">
          <div class="ueq-filter" id="ueqFilterWrap" hidden>
            <div class="ueq-filter-input-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="search" id="ueqFilterInput" class="ueq-filter-input" placeholder="Suchen: Name, Kategorie, Seriennummer …" autocomplete="off">
              <button type="button" class="ueq-filter-clear" id="ueqFilterClear" aria-label="Filter loeschen" hidden>✕</button>
            </div>
            <div class="ueq-filter-meta">
              <span id="ueqFilterCount"></span>
            </div>
          </div>
          <div class="ueq-items" id="ueqItems"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
// Toggle: Zuweisungs-Liste einklappen/ausklappen
(() => {
  document.addEventListener('click', (ev) => {
    const btn = ev.target.closest('[data-assigned-toggle]');
    if (!btn) return;
    const wrap = btn.closest('[data-assigned-wrap]');
    if (!wrap) return;
    const collapsed = wrap.classList.toggle('is-collapsed');
    btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
  });
})();

// Statistik-Modal Open/Close
(() => {
  const modal = document.getElementById('eqStatsModal');
  const openBtn = document.getElementById('eqStatsBtn');
  const closeBtn = document.getElementById('eqStatsClose');
  if (!modal || !openBtn) return;
  // an body anhaengen damit position:fixed sauber zur Viewport ist
  if (modal.parentNode !== document.body) document.body.appendChild(modal);
  const open = () => {
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };
  openBtn.addEventListener('click', open);
  if (closeBtn) closeBtn.addEventListener('click', close);
  modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) close();
  });
})();

// Inbox-Modal Open/Close
(() => {
  const modal = document.getElementById('eqInboxModal');
  const openBtn = document.getElementById('eqInboxBtn');
  const closeBtn = document.getElementById('eqInboxClose');
  if (!modal || !openBtn) return;
  if (modal.parentNode !== document.body) document.body.appendChild(modal);
  const open = () => {
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };
  openBtn.addEventListener('click', open);
  if (closeBtn) closeBtn.addEventListener('click', close);
  modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) close();
  });
  // Auto-open wenn URL #inbox enthaelt
  if (location.hash === '#inbox') open();
})();

// Zeugwart-Sheet (Mobile-Menu)
(() => {
  const sheet = document.getElementById('eqSheetBackdrop');
  const openBtn = document.getElementById('eqMenuBtn');
  if (!sheet || !openBtn) return;
  if (sheet.parentNode !== document.body) document.body.appendChild(sheet);
  const panel = sheet.querySelector('.eq-sheet');
  const open = () => {
    sheet.classList.add('open');
    sheet.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    sheet.classList.remove('open');
    sheet.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (panel) { panel.style.transform = ''; panel.style.transition = ''; }
  };
  openBtn.addEventListener('click', open);
  sheet.addEventListener('click', (e) => { if (e.target === sheet) close(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sheet.classList.contains('open')) close();
  });

  // Swipe-down zum Schliessen
  if (panel) {
    let startY = 0;
    let currentY = 0;
    let dragging = false;
    const onTouchStart = (e) => {
      if (panel.scrollTop > 0) return; // nur wenn ganz oben
      startY = e.touches[0].clientY;
      currentY = startY;
      dragging = true;
      panel.style.transition = 'none';
    };
    const onTouchMove = (e) => {
      if (!dragging) return;
      currentY = e.touches[0].clientY;
      const delta = currentY - startY;
      if (delta > 0) {
        // Browser-Scroll/Rubber-Band unterdruecken, sonst wandert der Hintergrund mit
        if (e.cancelable) e.preventDefault();
        panel.style.transform = `translateY(${delta}px)`;
      } else {
        panel.style.transform = '';
      }
    };
    const onTouchEnd = () => {
      if (!dragging) return;
      dragging = false;
      const delta = currentY - startY;
      panel.style.transition = '';
      if (delta > 90) {
        close();
      } else {
        panel.style.transform = '';
      }
    };
    panel.addEventListener('touchstart', onTouchStart, { passive: true });
    panel.addEventListener('touchmove', onTouchMove, { passive: false });
    panel.addEventListener('touchend', onTouchEnd);
    panel.addEventListener('touchcancel', onTouchEnd);
  }

  // Aktionen aus dem Sheet auf die Hero-Buttons mappen
  sheet.querySelectorAll('[data-sheet-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.getAttribute('data-sheet-action');
      close();
      setTimeout(() => {
        if (action === 'inbox') document.getElementById('eqInboxBtn')?.click();
        else if (action === 'stats') document.getElementById('eqStatsBtn')?.click();
        else if (action === 'scan') document.getElementById('qrScanBtn')?.click();
      }, 220);
    });
  });
})();
</script>

<script>
(() => {
  const dataEl = document.getElementById('users-equipment-data');
  const holdersEl = document.getElementById('holders-equipment-data');
  if (!dataEl && !holdersEl) return;
  let users = [];
  let holders = [];
  if (dataEl) { try { users = JSON.parse(dataEl.textContent); } catch (e) {} }
  if (holdersEl) { try { holders = JSON.parse(holdersEl.textContent); } catch (e) {} }

  const modal = document.getElementById('ueqModal');
  // Modal an <body> haengen, damit position:fixed nicht von einem transform-Parent gebrochen wird
  if (modal && modal.parentNode !== document.body) {
    document.body.appendChild(modal);
  }
  const closeBtn = document.getElementById('ueqClose');
  const avatarEl = document.getElementById('ueqAvatar');
  const nameEl = document.getElementById('ueqName');
  const countEl = document.getElementById('ueqCount');
  const itemsEl = document.getElementById('ueqItems');
  const dots = modal.querySelectorAll('.ueq-dot');

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  function initials(name) {
    return String(name || '?').split(/\s+/).map(s => s[0]).filter(Boolean).slice(0,2).join('').toUpperCase() || '?';
  }

  function openModal(userId) {
    const u = users.find(x => x.id === userId);
    if (!u) return;
    const display = u.full_name || u.username;
    nameEl.textContent = display;
    countEl.textContent = u.count + ' Item' + (u.count === 1 ? '' : 's');
    avatarEl.textContent = initials(display);

    // Dots aktivieren / deaktivieren
    const slots = u.slots || {};
    dots.forEach(dot => {
      const slot = dot.dataset.slot;
      let items = (slots[slot] || []).slice();
      if (slot === 'handLeft' || slot === 'handRight') {
        items = items.concat(slots.hands || []);
      }
      dot.classList.toggle('equipped', items.length > 0);
    });

    // Item-Liste rendern
    if (!u.items || !u.items.length) {
      itemsEl.innerHTML = '<div class="ueq-empty-list">Keine aktiven Zuweisungen</div>';
    } else {
      itemsEl.innerHTML = u.items.map(it => {
        const icon = it.category_icon_svg ||
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>';
        const meta = [
          it.category_name ? escapeHtml(it.category_name) : '',
          it.condition ? escapeHtml(it.condition) : '',
          it.serial_number ? 'SN: ' + escapeHtml(it.serial_number) : ''
        ].filter(Boolean).join(' · ');
        const slot = escapeHtml(it.slot || 'other');
        return '<div class="ueq-item" data-slot="' + slot + '">' +
                 '<div class="ueq-item-icon">' + icon + '</div>' +
                 '<div class="ueq-item-body">' +
                   '<strong>' + escapeHtml(it.name) + '</strong>' +
                   (meta ? '<small>' + meta + '</small>' : '') +
                 '</div>' +
                 (it.quantity > 1 ? '<span class="ueq-item-qty">×' + it.quantity + '</span>' : '') +
               '</div>';
      }).join('');
    }

    // Dot-Klick → Items in der Liste highlighten
    dots.forEach(dot => {
      dot.onclick = null;
      if (!dot.classList.contains('equipped')) return;
      dot.onclick = () => {
        const target = dot.dataset.slot;
        const slots = [target];
        if (target === 'handLeft' || target === 'handRight') slots.push('hands');
        modal.querySelectorAll('.ueq-dot.active').forEach(d => d.classList.remove('active'));
        dot.classList.add('active');
        let first = null;
        itemsEl.querySelectorAll('.ueq-item').forEach(el => {
          const match = slots.includes(el.dataset.slot);
          el.classList.toggle('highlight', match);
          if (match && !first) first = el;
        });
        if (first) first.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      };
    });

    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Puppet wieder einblenden (falls von Holder-View ausgeblendet)
    const puppet = modal.querySelector('.ueq-puppet-wrap');
    if (puppet) puppet.style.display = '';
    const body = modal.querySelector('.ueq-modal-body');
    if (body) body.classList.remove('is-holder-view');
    deactivateFilter();
  }

  function openHolderModal(holderId) {
    const h = holders.find(x => x.id === holderId);
    if (!h) return;
    const isVehicle = h.holder_type === 'vehicle';
    nameEl.textContent = h.name;
    countEl.textContent = h.count + ' Item' + (h.count === 1 ? '' : 's');
    avatarEl.innerHTML = isVehicle
      ? '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h2l1.5-7h11L19 17h2"/><circle cx="7.5" cy="17.5" r="1.7"/><circle cx="16.5" cy="17.5" r="1.7"/></svg>'
      : '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>';
    // Puppet ausblenden — Lagerort/Fahrzeug hat keinen Körper
    const puppet = modal.querySelector('.ueq-puppet-wrap');
    if (puppet) puppet.style.display = 'none';
    const bodyEl = modal.querySelector('.ueq-modal-body');
    if (bodyEl) bodyEl.classList.add('is-holder-view');
    // Items rendern
    if (!h.items || !h.items.length) {
      itemsEl.innerHTML = '<div class="ueq-empty-list">Keine aktiven Zuweisungen</div>';
    } else {
      itemsEl.innerHTML = h.items.map(it => {
        const icon = it.category_icon_svg ||
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>';
        const meta = [
          it.category_name ? escapeHtml(it.category_name) : '',
          it.condition ? escapeHtml(it.condition) : '',
          it.serial_number ? 'SN: ' + escapeHtml(it.serial_number) : ''
        ].filter(Boolean).join(' · ');
        return '<div class="ueq-item">' +
                 '<div class="ueq-item-icon">' + icon + '</div>' +
                 '<div class="ueq-item-body">' +
                   '<strong>' + escapeHtml(it.name) + '</strong>' +
                   (meta ? '<small>' + meta + '</small>' : '') +
                 '</div>' +
                 (it.quantity > 1 ? '<span class="ueq-item-qty">×' + it.quantity + '</span>' : '') +
               '</div>';
      }).join('');
    }
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    activateFilter(h.items ? h.items.length : 0);
  }

  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    const puppet = modal.querySelector('.ueq-puppet-wrap');
    if (puppet) puppet.style.display = '';
    const body = modal.querySelector('.ueq-modal-body');
    if (body) body.classList.remove('is-holder-view');
    deactivateFilter();
  }

  // ── Inline-Filter fuer das Modal (aktuell fuer Holder-View genutzt) ──
  const filterWrap   = document.getElementById('ueqFilterWrap');
  const filterInput  = document.getElementById('ueqFilterInput');
  const filterClear  = document.getElementById('ueqFilterClear');
  const filterCount  = document.getElementById('ueqFilterCount');
  function applyFilter() {
    if (!filterInput) return;
    const q = filterInput.value.trim().toLowerCase();
    if (filterClear) filterClear.hidden = !q;
    const items = itemsEl.querySelectorAll('.ueq-item');
    let shown = 0;
    items.forEach(el => {
      const txt = el.textContent.toLowerCase();
      const match = !q || txt.includes(q);
      el.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    if (filterCount) {
      const total = items.length;
      filterCount.textContent = q ? (shown + ' von ' + total + ' Treffer' + (shown === 1 ? '' : 'n')) : '';
    }
  }
  function activateFilter(totalCount) {
    if (!filterWrap || !filterInput) return;
    filterWrap.hidden = !(totalCount > 0);
    filterInput.value = '';
    if (filterClear) filterClear.hidden = true;
    if (filterCount) filterCount.textContent = '';
    // Sichtbarkeit zuruecksetzen
    itemsEl.querySelectorAll('.ueq-item').forEach(el => { el.style.display = ''; });
  }
  function deactivateFilter() {
    if (!filterWrap) return;
    filterWrap.hidden = true;
    if (filterInput) filterInput.value = '';
    if (filterClear) filterClear.hidden = true;
    if (filterCount) filterCount.textContent = '';
  }
  if (filterInput) filterInput.addEventListener('input', applyFilter);
  if (filterClear) filterClear.addEventListener('click', () => {
    filterInput.value = '';
    applyFilter();
    filterInput.focus();
  });

  document.querySelectorAll('.user-tile').forEach(tile => {
    tile.addEventListener('click', () => {
      if (tile.classList.contains('holder-tile')) {
        const id = parseInt(tile.dataset.holderId, 10);
        if (Number.isInteger(id)) openHolderModal(id);
      } else {
        const id = parseInt(tile.dataset.userId, 10);
        if (Number.isInteger(id)) openModal(id);
      }
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });

  // Swipe-down to dismiss (iOS-style)
  const sheet = modal.querySelector('.ueq-modal');
  const grabHead = modal.querySelector('.ueq-modal-head');
  let dragStartY = 0, dragCurrentY = 0, dragging = false, dragStartTime = 0;
  function onDragStart(e) {
    if (e.target.closest('.ueq-modal-close')) return;
    const t = e.touches ? e.touches[0] : e;
    dragStartY = t.clientY;
    dragCurrentY = 0;
    dragStartTime = Date.now();
    dragging = true;
    sheet.classList.add('dragging');
  }
  function onDragMove(e) {
    if (!dragging) return;
    const t = e.touches ? e.touches[0] : e;
    dragCurrentY = Math.max(0, t.clientY - dragStartY);
    sheet.style.transform = 'translateY(' + dragCurrentY + 'px)';
    if (e.cancelable) e.preventDefault();
  }
  function onDragEnd() {
    if (!dragging) return;
    dragging = false;
    sheet.classList.remove('dragging');
    const dt = Date.now() - dragStartTime;
    const velocity = dragCurrentY / Math.max(dt, 1);
    if (dragCurrentY > 120 || velocity > 0.6) {
      sheet.style.transform = 'translateY(100%)';
      setTimeout(() => { sheet.style.transform = ''; closeModal(); }, 260);
    } else {
      sheet.style.transform = '';
    }
  }
  grabHead.addEventListener('touchstart', onDragStart, { passive: true });
  grabHead.addEventListener('touchmove', onDragMove, { passive: false });
  grabHead.addEventListener('touchend', onDragEnd);
  grabHead.addEventListener('touchcancel', onDragEnd);
  grabHead.addEventListener('mousedown', (e) => {
    onDragStart(e);
    const mm = (ev) => onDragMove(ev);
    const mu = () => { onDragEnd(); document.removeEventListener('mousemove', mm); document.removeEventListener('mouseup', mu); };
    document.addEventListener('mousemove', mm);
    document.addEventListener('mouseup', mu);
  });
})();
</script>

<!-- ── QR / Seriennummer Scanner ─────────────────────────────────── -->
