    border-radius: 0.55rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .qr-status.error { background: #fde8e8; color: #b21414; border: 1px solid #f6c6c6; }
  .qr-status.info  { background: #eef6f1; color: #1f4d33; border: 1px solid #cfe5d8; }
  .qr-status.success { background: #e6f4ec; color: #1a7a45; border: 1px solid #c5e8d2; }
</style>

<script>
(function() {
  const btn       = document.getElementById('qrScanBtn');
  const modal     = document.getElementById('qrModal');
  const closeBtn  = document.getElementById('qrClose');
  const video     = document.getElementById('qrVideo');
  const hint      = document.getElementById('qrHint');
  const status    = document.getElementById('qrStatus');
  const manualForm = document.getElementById('qrManualForm');
  const manualInput = document.getElementById('qrManualInput');

  if (!btn) return;

  // an body anhaengen, damit position:fixed nicht durch transform-Parent gebrochen wird
  if (modal && modal.parentNode !== document.body) {
    document.body.appendChild(modal);
  }

  let stream = null;
  let scanning = false;
  let zxingLoading = null;
  let zxingReader = null;
  let zxingControls = null;
  let lastSubmitted = '';
  let lastSubmittedAt = 0;

  function setStatus(msg, kind) {
    if (!msg) { status.hidden = true; status.textContent = ''; return; }
    status.hidden = false;
    status.textContent = msg;
    status.className = 'qr-status ' + (kind || 'info');
  }

  function loadZXing() {
    if (window.ZXing) return Promise.resolve(window.ZXing);
    if (zxingLoading) return zxingLoading;
    // 1. lokale Kopie (immer offline verfuegbar)  2. jsdelivr  3. unpkg
    const sources = [
      '/vendor/zxing.min.js',
      'https://cdn.jsdelivr.net/npm/@zxing/library@latest/umd/index.min.js',
      'https://unpkg.com/@zxing/library@latest/umd/index.min.js'
    ];
    zxingLoading = (async () => {
      for (const src of sources) {
        try {
          await new Promise((resolve, reject) => {
            const s = document.createElement('script');
            s.src = src;
            s.async = true;
            s.onload = () => resolve();
            s.onerror = () => reject(new Error('load failed: ' + src));
            document.head.appendChild(s);
          });
          if (window.ZXing && window.ZXing.BrowserMultiFormatReader) return window.ZXing;
        } catch (e) {
          console.warn('[QR] ZXing-Quelle fehlgeschlagen:', src, e);
        }
      }
      throw new Error('Scanner-Bibliothek konnte aus keiner Quelle geladen werden');
    })();
    return zxingLoading;
  }

  async function startCamera() {
    setStatus('Scanner wird geladen…', 'info');
    hint.textContent = 'Scanner wird geladen…';
    let ZX;
    try {
      ZX = await loadZXing();
      if (!ZX || !ZX.BrowserMultiFormatReader) throw new Error('ZXing nicht geladen');
    } catch (e) {
      hint.textContent = 'Scanner konnte nicht geladen werden';
      setStatus('Offline oder CDN blockiert – bitte Code unten manuell eingeben.', 'error');
      return;
    }

    // HTTPS-Check (Kamera-API erfordert sichere Verbindung, ausser localhost)
    const isSecure = window.isSecureContext
      || location.protocol === 'https:'
      || ['localhost', '127.0.0.1'].includes(location.hostname);
    if (!isSecure) {
      hint.textContent = 'Kamera braucht HTTPS';
      setStatus('Kamera funktioniert nur ueber HTTPS. Bitte Code manuell eingeben.', 'error');
      return;
    }
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      hint.textContent = 'Kamera nicht unterstuetzt';
      setStatus('Dieser Browser unterstuetzt keinen Kamerazugriff. Bitte Code manuell eingeben.', 'error');
      return;
    }

    try {
      // Format-Hints: alle gaengigen Codes inkl. QR, Data Matrix, Aztec, PDF417, EAN, Code128 / 39
      const hints = new Map();
      try {
        const F = ZX.BarcodeFormat;
        const DF = ZX.DecodeHintType;
        if (F && DF) {
          hints.set(DF.POSSIBLE_FORMATS, [
            F.QR_CODE, F.DATA_MATRIX, F.AZTEC, F.PDF_417,
            F.CODE_128, F.CODE_39, F.CODE_93, F.CODABAR, F.ITF,
            F.EAN_13, F.EAN_8, F.UPC_A, F.UPC_E
          ]);
          hints.set(DF.TRY_HARDER, true);
        }
      } catch (e) { /* Hints optional */ }

      zxingReader = new ZX.BrowserMultiFormatReader(hints);
      hint.textContent = 'QR / Barcode in den Rahmen halten';
      setStatus('Kamera startet…', 'info');
      scanning = true;

      // Direkt per facingMode='environment' starten – funktioniert auch ohne vorherige
      // Permission und ohne Device-Labels (typisch fuer iOS Safari & Android Chrome).
      const constraints = {
        audio: false,
        video: {
          facingMode: { ideal: 'environment' },
          width:  { ideal: 1280 },
          height: { ideal: 720 }
        }
      };

      const callback = (result, err) => {
        if (!scanning) return;
        if (result && result.getText) handleCode(result.getText());
        // NotFoundException ist normal pro Frame – nicht loggen
      };

      try {
        if (typeof zxingReader.decodeFromConstraints === 'function') {
          zxingControls = await zxingReader.decodeFromConstraints(constraints, video, callback);
        } else {
          // Fallback aelteres ZXing: getUserMedia + decodeFromVideoElement
          stream = await navigator.mediaDevices.getUserMedia(constraints);
          video.srcObject = stream;
          await video.play().catch(() => {});
          zxingReader.decodeFromVideoElement(video, callback);
        }
      } catch (e1) {
        console.warn('[QR] Rueckkamera nicht verfuegbar, versuche Standard-Kamera', e1);
        // Fallback: irgendeine Kamera
        const fallback = { audio: false, video: true };
        if (typeof zxingReader.decodeFromConstraints === 'function') {
          zxingControls = await zxingReader.decodeFromConstraints(fallback, video, callback);
        } else {
          stream = await navigator.mediaDevices.getUserMedia(fallback);
          video.srcObject = stream;
          await video.play().catch(() => {});
          zxingReader.decodeFromVideoElement(video, callback);
        }
      }
      setStatus('');
    } catch (err) {
      console.error('[QR] Kamera-Start fehlgeschlagen', err);
      const name = err && err.name;
      let msg = 'Kamera nicht verfuegbar – bitte Seriennummer manuell eingeben.';
      if (name === 'NotAllowedError' || name === 'PermissionDeniedError') {
        msg = 'Kamera-Zugriff wurde abgelehnt. Bitte in den Browser-Einstellungen erlauben oder Code manuell eingeben.';
      } else if (name === 'NotFoundError' || name === 'DevicesNotFoundError') {
        msg = 'Keine Kamera gefunden. Bitte Seriennummer manuell eingeben.';
      } else if (name === 'NotReadableError' || name === 'TrackStartError') {
        msg = 'Kamera wird gerade von einer anderen App genutzt. Bitte schliessen und erneut versuchen.';
      } else if (name === 'OverconstrainedError') {
        msg = 'Rueckkamera nicht verfuegbar. Bitte Seriennummer manuell eingeben.';
      }
      hint.textContent = 'Kein Kamerazugriff';
      setStatus(msg, 'error');
    }
  }

  async function handleCode(value) {
    // Steuerzeichen, FNC1, Whitespace abschneiden
    let code = (value || '')
      .replace(/[\x00-\x1F\x7F\u200B-\u200F\uFEFF]/g, '')
      .trim();
    if (!code) return;
    const now = Date.now();
    if (code === lastSubmitted && now - lastSubmittedAt < 3000) return;
    lastSubmitted = code;
    lastSubmittedAt = now;
    scanning = false;
    hint.textContent = 'Code erkannt – wird gesucht…';
    setStatus('Suche „' + code + '“…', 'info');
    if (manualInput) manualInput.value = code;
    try { console.log('[QR] Scan:', JSON.stringify(value), '→', JSON.stringify(code)); } catch (e) {}

    try {
      const res = await fetch('/equipment/lookup?code=' + encodeURIComponent(code), {
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        const data = await res.json();
        setStatus('Gefunden – Weiterleitung zur Zuweisung…', 'success');
        stopCamera();
        window.location.href = data.assignUrl;
        return;
      }
      if (res.status === 404) {
        setStatus('Kein Equipment mit „' + code + '" gefunden. Code wurde unten eingefügt – kannst du anpassen oder mit Enter erneut suchen.', 'error');
        if (manualInput) {
          manualInput.focus();
          manualInput.select();
        }
      } else {
        setStatus('Fehler bei der Suche (Status ' + res.status + ').', 'error');
      }
    } catch (e) {
      setStatus('Netzwerkfehler bei der Suche.', 'error');
    }

    // Scanning nach kurzer Pause fortsetzen
    setTimeout(() => {
      if (modal.classList.contains('open')) {
        scanning = true;
        hint.textContent = 'Nächsten Code halten…';
      }
    }, 1200);
  }

  function stopCamera() {
    scanning = false;
    try {
      if (zxingControls && typeof zxingControls.stop === 'function') zxingControls.stop();
    } catch (e) {}
    zxingControls = null;
    try {
      if (zxingReader && typeof zxingReader.reset === 'function') zxingReader.reset();
    } catch (e) {}
    zxingReader = null;
    if (stream) {
      try { stream.getTracks().forEach(t => t.stop()); } catch (e) {}
      stream = null;
    }
    try { video.srcObject = null; } catch (e) {}
  }

  function openModal() {
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setStatus('');
    lastSubmitted = '';
    startCamera();
    setTimeout(() => manualInput && manualInput.focus({ preventScroll: true }), 50);
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    stopCamera();
  }

  btn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });

  manualForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const v = manualInput.value.trim();
    if (v) handleCode(v);
  });
})();
</script>

