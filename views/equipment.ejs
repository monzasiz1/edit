  }
  .qr-manual { display: flex; flex-direction: column; gap: 0.35rem; }
  .qr-manual label { font-size: 0.78rem; color: #4b5563; font-weight: 600; }
  .qr-manual-row { display: flex; gap: 0.45rem; }
  .qr-manual input {
    flex: 1; min-width: 0;
    padding: 0.55rem 0.8rem;
    border: 1px solid #d1e0d6;
