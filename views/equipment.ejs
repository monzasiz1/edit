  .qr-modal-backdrop.open .qr-modal { transform: translateY(0) scale(1); opacity: 1; }
  @media (min-width: 769px) {
    .qr-modal { max-width: 560px; }
  }
  .qr-modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.95rem 1.15rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    color: #fff;
    flex-shrink: 0;
  }
  .qr-modal-head strong, .qr-modal-head h2, .qr-modal-head h3 { color: #fff; }
  .qr-modal-close {
