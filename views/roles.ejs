<style>
  /* Rollen Liste – mobile first */
  .roles-meta {
    font-size: 0.82rem;
    color: #6b7280;
    margin-bottom: 0.85rem;
  }
  .roles-meta strong { color: #1a7a45; }

  .roles-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.65rem;
  }
  .role-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.9rem 0.95rem;
    background: linear-gradient(135deg, #f7fbf8 0%, #eef6f1 100%);
    border: 1px solid #d9ead9;
    border-radius: 0.95rem;
    box-shadow: 0 2px 6px rgba(60,120,80,0.05);
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .role-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(60,120,80,0.13);
    border-color: #b8d8c0;
  }

  .role-card-head {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
  }
  .role-card-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(45,143,85,0.22);
  }
  .role-card-icon svg { width: 22px; height: 22px; }
  .role-card-icon.is-admin   { background: linear-gradient(135deg, #d96363 0%, #a82a2a 100%); }
  .role-card-icon.is-board   { background: linear-gradient(135deg, #6b8de8 0%, #3a5ec0 100%); }
  .role-card-icon.is-default { background: linear-gradient(135deg, #3da973 0%, #2d8f55 100%); }

  .role-card-title {
    flex: 1;
    min-width: 0;
  }
  .role-card-title strong {
    display: block;
    font-size: 0.98rem;
    color: #15301f;
    line-height: 1.25;
    word-break: normal;
    overflow-wrap: anywhere;
  }
  .role-card-desc {
    display: block;
    font-size: 0.78rem;
    color: #6b7280;
    margin-top: 0.18rem;
    line-height: 1.35;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  .role-type {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    margin-top: 0.22rem;
  }
  .role-type.is-admin   { color: #a82a2a; background: #fde8e8; border: 1px solid #f6c6c6; }
  .role-type.is-board   { color: #3a5ec0; background: #e8edfb; border: 1px solid #c8d3f4; }
  .role-type.is-default { color: #1a7a45; background: #e6f4ec; border: 1px solid #c5e8d2; }

  .role-card-stats {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .role-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.74rem;
    font-weight: 600;
    color: #4b5563;
    background: #fff;
    border: 1px solid #e2efe6;
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
  }
  .role-stat svg { width: 12px; height: 12px; }
  .role-stat strong { color: #1a7a45; }

  .role-perms-label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6b8a76;
  }
  .role-perms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .role-perm {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: #1a7a45;
    background: #e6f4ec;
    border: 1px solid #c5e8d2;
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    white-space: nowrap;
  }
  .role-perm svg { width: 11px; height: 11px; }
  .role-perms-empty {
    font-size: 0.74rem;
    color: #9ca3af;
    font-style: italic;
  }

  .role-card-actions {
    display: flex;
    gap: 0.35rem;
    margin-top: auto;
  }
  .role-action {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.42rem 0.6rem;
    border-radius: 0.55rem;
    text-decoration: none;
    background: #fff;
    color: #1b2e2b;
    border: 1px solid #d4dfcf;
    transition: background 0.14s, transform 0.1s;
  }
  .role-action:hover { background: #f3f6f1; transform: translateY(-1px); }
  .role-action svg { width: 14px; height: 14px; }

  .roles-empty {
    padding: 2.4rem 1rem;
    text-align: center;
    color: #6b7280;
    background: #f9fafb;
    border: 1px dashed #d4dfcf;
    border-radius: 0.9rem;
  }
  .roles-empty svg { width: 38px; height: 38px; color: #cbd5d1; margin-bottom: 0.5rem; }
  .roles-empty p { margin: 0.3rem 0 0; font-size: 0.92rem; }

  @media (max-width: 460px) {
    .roles-grid { grid-template-columns: 1fr; }
  }

  /* ── Hero Header (Strikeboard-Style) ──────────── */
  .page-hero {
    position: relative;
    padding: 1.4rem 1.5rem;
    background: linear-gradient(145deg, #1a3d2a 0%, #2d6a45 60%, #3d8c5e 100%);
    border-radius: 1.35rem 1.35rem 2rem 2rem;
    margin: -0.55rem -0.25rem 1.6rem;
    border: 1px solid rgba(160, 212, 183, 0.42);
    box-shadow: 0 15px 34px rgba(18, 66, 43, 0.34), 0 4px 12px rgba(0, 0, 0, 0.1);
    animation: pageHeroFade 0.7s cubic-bezier(.4,0,0,1.12);
  }
  @keyframes pageHeroFade {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-hero-clip {
    position: absolute; inset: 0; border-radius: inherit;
    overflow: hidden; pointer-events: none; z-index: 0;
  }
  .page-hero-orb {
    position: absolute; border-radius: 50%; pointer-events: none;
    opacity: 0.36; filter: blur(36px);
  }
  .page-hero-orb-1 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #a8f4d2 0%, transparent 70%);
    top: -50px; right: -30px;
  }
  .page-hero-orb-2 {
    width: 140px; height: 140px;
    background: radial-gradient(circle, #b8e8ff 0%, transparent 70%);
    bottom: -30px; left: 8%;
  }
  .page-hero::after {
    content: ''; position: absolute; left: 1.2rem; right: 1.2rem; top: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.55), rgba(255,255,255,0.02));
    pointer-events: none; z-index: 2;
  }
  .page-hero-content {
    position: relative; z-index: 10;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap;
  }
  .page-hero-title-wrap { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .page-hero-kicker {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.7);
  }
  .page-hero-title {
    font-size: 1.85rem; font-weight: 900; margin: 0;
    letter-spacing: -0.8px; line-height: 1.1; color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.18);
    display: inline-flex; align-items: center; gap: 0.55rem;
  }
  .page-hero-title svg { width: 26px; height: 26px; flex-shrink: 0; opacity: 0.92; }
  .page-hero-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
  .page-hero-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: rgba(255,255,255,0.18); color: #fff;
    border: 1px solid rgba(255,255,255,0.28); border-radius: 2em;
    padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.02em; text-decoration: none; cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    -webkit-tap-highlight-color: transparent; white-space: nowrap;
  }
  .page-hero-btn:hover {
    background: rgba(255,255,255,0.28);
    box-shadow: 0 10px 26px rgba(0,0,0,0.2);
    transform: translateY(-1px); color: #fff;
  }
  .page-hero-btn:active { transform: scale(0.96); }
  .page-hero-btn.primary { background: #fff; color: #1a7a45; border-color: rgba(255,255,255,0.6); }
  .page-hero-btn.primary:hover { background: #f0fff7; color: #145d34; }
  .page-hero-btn.ghost { background: transparent; border-color: rgba(255,255,255,0.4); }
  .page-hero-btn svg { width: 14px; height: 14px; }

  @media (max-width: 640px) {
    .page-hero { padding: 1.1rem 1.1rem; border-radius: 1.1rem 1.1rem 1.6rem 1.6rem; margin-bottom: 1.2rem; }
    .page-hero-content { flex-direction: column; align-items: stretch; gap: 0.85rem; }
    .page-hero-title { font-size: 1.45rem; }
    .page-hero-title svg { width: 22px; height: 22px; }
    .page-hero-actions { width: 100%; }
    .page-hero-btn { flex: 1 1 auto; justify-content: center; padding: 0.55rem 0.7rem; font-size: 0.82rem; }
  }
  @media (max-width: 380px) {
    .page-hero-actions { flex-direction: column; }
    .page-hero-btn { width: 100%; }
  }
</style>

<main class="apple-dashboard">
  <header class="page-hero">
    <div class="page-hero-clip">
      <div class="page-hero-orb page-hero-orb-1"></div>
      <div class="page-hero-orb page-hero-orb-2"></div>
    </div>
    <div class="page-hero-content">
      <div class="page-hero-title-wrap">
        <span class="page-hero-kicker">Rechteverwaltung</span>
        <h1 class="page-hero-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Rollen
        </h1>
      </div>
      <div class="page-hero-actions">
        <a href="/roles/add" class="page-hero-btn primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Neue Rolle
        </a>
        <a href="/dashboard" class="page-hero-btn ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Zurück
        </a>
      </div>
    </div>
  </header>

  <% if (success) { %>
    <div class="apple-alert alert-success" style="margin-bottom: 16px;"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="apple-alert alert-error" style="margin-bottom: 16px;"><%= error %></div>
  <% } %>

  <div class="roles-meta"><strong><%= roles.length %></strong> Rollen definiert</div>

  <% if (roles.length === 0) { %>
    <div class="roles-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>Noch keine Rollen vorhanden</p>
    </div>
  <% } else { %>
    <ul class="roles-grid">
      <% roles.forEach(role => { %>
        <%
          const roleKind = role.is_admin ? 'is-admin' : (role.is_board ? 'is-board' : 'is-default');
          const roleLabel = role.is_admin ? 'Admin' : (role.is_board ? 'Vorstand' : 'Standard');
        %>
        <li class="role-card">
          <div class="role-card-head">
            <div class="role-card-icon <%= roleKind %>">
              <% if (role.is_admin) { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <% } else if (role.is_board) { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
              <% } else { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>
              <% } %>
            </div>
            <div class="role-card-title">
              <strong><%= role.name %></strong>
              <% if (role.description) { %>
                <span class="role-card-desc"><%= role.description %></span>
              <% } %>
              <span class="role-type <%= roleKind %>"><%= roleLabel %></span>
            </div>
          </div>

          <div class="role-card-stats">
            <span class="role-stat">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
              <strong><%= role.member_count %></strong>&nbsp;Mitglieder
            </span>
          </div>

          <%
            const perms = [];
            if (role.can_manage_members)   perms.push({ label: 'Mitglieder',  svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>' });
            if (role.can_manage_penalties) perms.push({ label: 'Aktionen',    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>' });
            if (role.can_manage_equipment) perms.push({ label: 'Equipment',   svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>' });
            if (role.can_manage_roles)     perms.push({ label: 'Rollen',      svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2 4 4 .5-3 3 1 4-4-2-4 2 1-4-3-3 4-.5z"/></svg>' });
          %>
          <% if (perms.length) { %>
            <div class="role-perms-label">Berechtigungen</div>
            <div class="role-perms">
              <% perms.forEach(p => { %>
                <span class="role-perm"><%- p.svg %><%= p.label %></span>
              <% }) %>
            </div>
          <% } else { %>
            <span class="role-perms-empty">Keine Sonderberechtigungen</span>
          <% } %>

          <div class="role-card-actions">
            <a href="/roles/<%= role.id %>/edit" class="role-action">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
              Bearbeiten
            </a>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</main>
